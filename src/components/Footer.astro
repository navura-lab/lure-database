---
import { getUI } from '../i18n/lib/t';
import { getBasePrefix } from '../i18n/lib/locale';
import type { Locale } from '../i18n/lib/t';

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? 'ja';
const ui = getUI(locale);
const prefix = getBasePrefix(locale);

// フッターのルアータイプ表示名（日英対応）
const typeLinks = [
  { slug: 'minnow', ja: 'ミノー', en: 'Minnow' },
  { slug: 'worm', ja: 'ワーム', en: 'Soft Plastic' },
  { slug: 'metal-jig', ja: 'メタルジグ', en: 'Metal Jig' },
  { slug: 'crankbait', ja: 'クランクベイト', en: 'Crankbait' },
  { slug: 'vibration', ja: 'バイブレーション', en: 'Vibration' },
  { slug: 'topwater', ja: 'トップウォーター', en: 'Topwater' },
  { slug: 'spinnerbait', ja: 'スピナーベイト', en: 'Spinnerbait' },
  { slug: 'swimbait', ja: 'スイムベイト', en: 'Swimbait' },
];

// フッターの対象魚表示名（日英対応）
const fishLinks = [
  { slug: 'black-bass', ja: 'ブラックバス', en: 'Largemouth Bass' },
  { slug: 'seabass', ja: 'シーバス', en: 'Seabass' },
  { slug: 'trout', ja: 'トラウト', en: 'Trout' },
  { slug: 'bluerunner', ja: '青物', en: 'Bluerunner' },
  { slug: 'aji', ja: 'アジ', en: 'Aji' },
  { slug: 'mebaru', ja: 'メバル', en: 'Mebaru' },
  { slug: 'hirame', ja: 'ヒラメ', en: 'Flounder' },
  { slug: 'kurodai', ja: 'クロダイ', en: 'Black Sea Bream' },
];
---

<footer class="border-t border-border mt-20" data-pagefind-ignore>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- サイトマップ風リンク -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-8 font-mono text-[11px] tracking-[1px]">

      <!-- タイプ -->
      <div>
        <h3 class="font-bold text-text mb-3 text-[13px]">{ui.footer.type}</h3>
        <ul class="space-y-2">
          {typeLinks.map(t => (
            <li><a href={`${prefix}/type/${t.slug}/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{locale === 'en' ? t.en : t.ja}</a></li>
          ))}
          <li><a href={`${prefix}/type/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s] font-bold">{ui.footer.seeAll}</a></li>
        </ul>
      </div>

      <!-- メーカー -->
      <div>
        <h3 class="font-bold text-text mb-3 text-[13px]">{ui.footer.maker}</h3>
        <ul class="space-y-2">
          <li><a href={`${prefix}/daiwa/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">DAIWA</a></li>
          <li><a href={`${prefix}/shimano/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">SHIMANO</a></li>
          <li><a href={`${prefix}/jackall/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">JACKALL</a></li>
          <li><a href={`${prefix}/megabass/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">Megabass</a></li>
          <li><a href={`${prefix}/duo/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">DUO</a></li>
          <li><a href={`${prefix}/osp/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">O.S.P</a></li>
          <li><a href={`${prefix}/evergreen/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">EVERGREEN</a></li>
          <li><a href={`${prefix}/blueblue/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">BlueBlue</a></li>
          <li><a href={`${prefix}/maker/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s] font-bold">{ui.footer.seeAll}</a></li>
        </ul>
      </div>

      <!-- 対象魚 -->
      <div>
        <h3 class="font-bold text-text mb-3 text-[13px]">{ui.footer.fish}</h3>
        <ul class="space-y-2">
          {fishLinks.map(f => (
            <li><a href={`${prefix}/fish/${f.slug}/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{locale === 'en' ? f.en : f.ja}</a></li>
          ))}
          <li><a href={`${prefix}/fish/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s] font-bold">{ui.footer.seeAll}</a></li>
        </ul>
      </div>

      <!-- サイト情報 -->
      <div>
        <h3 class="font-bold text-text mb-3 text-[13px]">CAST<span class="text-accent">/</span>LOG</h3>
        <ul class="space-y-2">
          <li><a href={`${prefix}/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.home}</a></li>
          <li><a href={`${prefix}/search/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.search}</a></li>
          <li><a href={`${prefix}/ranking/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.nav.catalog}</a></li>
          <li><a href={`${prefix}/compare/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.compare}</a></li>
          <li><a href={`${prefix}/method/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.method}</a></li>
          <li><a href={`${prefix}/season/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.season}</a></li>
          <li><a href={`${prefix}/new/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.new}</a></li>
          <li><a href={`${prefix}/guide/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.guide}</a></li>
          <li><a href={`${prefix}/article/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.article}</a></li>
          <li><a href={`${prefix}/maker/`} class="text-text-mid hover:text-text transition-colors duration-[0.15s]">{ui.footer.makerList}</a></li>
        </ul>
      </div>

    </div>

    <!-- 法定ページリンク -->
    <div class="border-t border-border pt-4 pb-4 flex flex-wrap justify-center gap-4 font-mono text-[10px] text-text-dim tracking-[1px]">
      <a href="/about/" class="hover:text-text transition-colors">運営者情報</a>
      <a href="/privacy/" class="hover:text-text transition-colors">プライバシーポリシー</a>
      <a href="/disclaimer/" class="hover:text-text transition-colors">免責事項</a>
      <a href="mailto:info@castlog.xyz" class="hover:text-text transition-colors">お問い合わせ</a>
    </div>

    <!-- アフィリエイト表記 -->
    <div class="border-t border-border pt-3 pb-3 text-center font-mono text-[10px] text-text-faint tracking-[0.5px]">
      {locale === 'en'
        ? 'This site participates in the Rakuten Affiliate Program.'
        : '当サイトは楽天アフィリエイトプログラムに参加しています。'}
    </div>

    <!-- コピーライト -->
    <div class="border-t border-border-light pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 font-mono text-[10px] text-text-dim tracking-[1px]">
      <div class="flex items-center gap-3">
        <span class="font-bold text-[14px] tracking-[2px]">CAST<span class="text-accent">/</span>LOG</span>
        <span>{ui.tagline}</span>
      </div>
      <p>&copy; 2026 CAST/LOG</p>
    </div>
  </div>
</footer>
