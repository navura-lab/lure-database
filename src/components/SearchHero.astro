---
interface Props {
  seriesCount: number;
  colorCount: number;
  lureImages?: string[];
}

const { seriesCount, colorCount, lureImages = [] } = Astro.props;
---

<section class="relative overflow-hidden bg-[#080810]" style="min-height: 540px;">
  <!-- Canvas: ルアーネットワークアニメーション -->
  <canvas id="lure-network" class="absolute inset-0 w-full h-full"></canvas>

  <!-- 下部フェード -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#080810]"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center z-10">
    <h1 class="font-mono text-[48px] sm:text-[64px] font-bold tracking-[4px] text-white mb-3 animate-fade-up drop-shadow-lg">
      CAST<span class="text-accent">/</span>LOG
    </h1>
    <p class="text-[16px] sm:text-[18px] text-white/70 tracking-[2px] mb-8 animate-fade-up drop-shadow" style="animation-delay: 100ms;">
      一投を、資産にする。
    </p>
    <div class="flex items-center justify-center gap-8 sm:gap-12 mb-10 animate-fade-up" style="animation-delay: 200ms;">
      <div class="text-center">
        <p class="font-mono text-[28px] sm:text-[36px] font-bold text-white drop-shadow-lg">{seriesCount.toLocaleString()}</p>
        <p class="font-mono text-[10px] text-white/50 tracking-[2px]">シリーズ</p>
      </div>
      <div class="w-px h-10 bg-white/15"></div>
      <div class="text-center">
        <p class="font-mono text-[28px] sm:text-[36px] font-bold text-white drop-shadow-lg">{colorCount.toLocaleString()}</p>
        <p class="font-mono text-[10px] text-white/50 tracking-[2px]">カラー</p>
      </div>
    </div>
    <form action="/search/" method="get" class="max-w-xl mx-auto animate-fade-up" style="animation-delay: 300ms;">
      <div class="relative flex items-center bg-white/10 backdrop-blur-md rounded-full border border-white/20 hover:bg-white/15 focus-within:bg-white/20 focus-within:border-accent/50 transition-all duration-200">
        <svg class="absolute left-5 w-5 h-5 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" name="q" placeholder="ルアー名・メーカー名で検索..."
               class="w-full pl-13 pr-28 py-4 text-[15px] text-white placeholder:text-white/40 rounded-full bg-transparent focus:outline-none" />
        <button type="submit" class="absolute right-2 bg-accent text-white font-mono font-bold text-[13px] px-6 py-2.5 rounded-full tracking-[1px] hover:bg-accent-dark active:scale-95 transition-all duration-200">
          検索
        </button>
      </div>
    </form>
  </div>
</section>

<script define:vars={{ lureImages }}>
  window.__LURE_IMAGES = lureImages;
</script>

<script>
  const canvas = document.getElementById('lure-network') as HTMLCanvasElement;
  if (!canvas) throw new Error('Canvas not found');
  const ctx = canvas.getContext('2d')!;
  const images: string[] = (window as any).__LURE_IMAGES || [];

  interface Node {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    img: HTMLImageElement | null;
    loaded: boolean;
    opacity: number;
    isLure: boolean;
  }

  const LURE_COUNT = Math.min(images.length, 8); // 大きいノード8個
  const DOT_COUNT = 20; // 小さい光ドット
  const CONNECTION_DIST = 250;
  const LURE_RADIUS = 36; // 大きく
  let mouseX = -1000;
  let mouseY = -1000;
  let W = 0;
  let H = 0;
  const nodes: Node[] = [];

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = rect.width;
    H = rect.height;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }

  function init() {
    resize();

    // ルアー画像ノード（大きく目立つ）
    for (let i = 0; i < LURE_COUNT; i++) {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      const node: Node = {
        x: (W * 0.1) + Math.random() * (W * 0.8),
        y: (H * 0.1) + Math.random() * (H * 0.8),
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        radius: LURE_RADIUS + Math.random() * 8,
        img: null,
        loaded: false,
        opacity: 0,
        isLure: true,
      };
      if (images[i]) {
        img.onload = () => { node.img = img; node.loaded = true; };
        img.src = images[i];
      }
      nodes.push(node);
    }

    // 光のドット（小さい）
    for (let i = 0; i < DOT_COUNT; i++) {
      nodes.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        radius: 1.5 + Math.random() * 2.5,
        img: null,
        loaded: false,
        opacity: 0.2 + Math.random() * 0.5,
        isLure: false,
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // 接続線（ルアーノード同士、ルアーとドット）
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECTION_DIST) {
          // ルアー同士の接続はより明るく太く
          const bothLure = nodes[i].isLure && nodes[j].isLure;
          const alpha = (1 - dist / CONNECTION_DIST) * (bothLure ? 0.35 : 0.12);
          const width = bothLure ? 1.5 : 0.5;

          ctx.strokeStyle = `rgba(0, 199, 138, ${alpha})`;
          ctx.lineWidth = width;
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.stroke();
        }
      }

      // マウスとの接続線
      const mdx = nodes[i].x - mouseX;
      const mdy = nodes[i].y - mouseY;
      const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
      if (mdist < CONNECTION_DIST * 1.2) {
        const alpha = (1 - mdist / (CONNECTION_DIST * 1.2)) * (nodes[i].isLure ? 0.5 : 0.2);
        ctx.strokeStyle = `rgba(0, 199, 138, ${alpha})`;
        ctx.lineWidth = nodes[i].isLure ? 1.5 : 0.5;
        ctx.beginPath();
        ctx.moveTo(nodes[i].x, nodes[i].y);
        ctx.lineTo(mouseX, mouseY);
        ctx.stroke();
      }
    }

    // ノード描画
    for (const node of nodes) {
      if (node.opacity < 1) node.opacity = Math.min(1, node.opacity + 0.015);

      if (node.isLure && node.loaded && node.img) {
        const r = node.radius;

        // 白い円背景（ルアーが見えるように）
        ctx.save();
        ctx.globalAlpha = node.opacity * 0.95;
        ctx.fillStyle = '#ffffff';
        ctx.shadowColor = 'rgba(0, 199, 138, 0.3)';
        ctx.shadowBlur = 20;
        ctx.beginPath();
        ctx.arc(node.x, node.y, r + 4, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;

        // ルアー画像
        ctx.beginPath();
        ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
        ctx.closePath();
        ctx.clip();
        ctx.drawImage(node.img, node.x - r, node.y - r, r * 2, r * 2);
        ctx.restore();

        // アクセント縁取り
        ctx.strokeStyle = `rgba(0, 199, 138, ${node.opacity * 0.6})`;
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(node.x, node.y, r + 4, 0, Math.PI * 2);
        ctx.stroke();

      } else if (!node.isLure) {
        // 光のドット
        ctx.globalAlpha = node.opacity;
        ctx.fillStyle = `rgba(0, 199, 138, 0.7)`;
        ctx.beginPath();
        ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      // 移動
      node.x += node.vx;
      node.y += node.vy;

      // ソフトバウンス
      if (node.x < -30) node.x = W + 30;
      if (node.x > W + 30) node.x = -30;
      if (node.y < -30) node.y = H + 30;
      if (node.y > H + 30) node.y = -30;
    }

    requestAnimationFrame(draw);
  }

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;
  });

  canvas.addEventListener('mouseleave', () => {
    mouseX = -1000;
    mouseY = -1000;
  });

  window.addEventListener('resize', resize);
  init();
  draw();
</script>
