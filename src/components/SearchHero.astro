---
interface Props {
  seriesCount: number;
  colorCount: number;
}

const { seriesCount, colorCount } = Astro.props;
---

<section class="bg-surface border-b border-border">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 text-center">
    <h1 class="font-mono text-[36px] font-bold tracking-[2px] text-text mb-2">
      CAST<span class="text-accent">/</span>LOG
    </h1>
    <p class="font-mono text-[13px] text-text-dim tracking-[2px] mb-4">
      Cast it. Log it. Prove it.
    </p>
    <p class="font-mono text-[11px] text-text-faint">
      {seriesCount.toLocaleString()} series · {colorCount.toLocaleString()} colors
    </p>
  </div>
</section>
