---
interface Props {
  seriesCount: number;
  colorCount: number;
}

const { seriesCount, colorCount } = Astro.props;
---

<section class="relative overflow-hidden hero-gradient-bg border-b border-border">
  <div class="absolute inset-0 opacity-[0.03]"
       style="background-image: radial-gradient(circle, #1A1A1A 1px, transparent 1px); background-size: 24px 24px;"></div>
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
    <h1 class="font-mono text-[48px] sm:text-[64px] font-bold tracking-[4px] text-text mb-3 animate-fade-up">
      CAST<span class="text-accent">/</span>LOG
    </h1>
    <p class="text-[16px] sm:text-[18px] text-text-mid tracking-[2px] mb-6 animate-fade-up" style="animation-delay: 100ms;">
      一投を、資産にする。
    </p>
    <div class="flex items-center justify-center gap-8 sm:gap-12 mb-8 animate-fade-up" style="animation-delay: 200ms;">
      <div class="text-center">
        <p class="font-mono text-[28px] sm:text-[36px] font-bold text-text">{seriesCount.toLocaleString()}</p>
        <p class="font-mono text-[10px] text-text-dim tracking-[2px]">シリーズ</p>
      </div>
      <div class="w-px h-10 bg-border"></div>
      <div class="text-center">
        <p class="font-mono text-[28px] sm:text-[36px] font-bold text-text">{colorCount.toLocaleString()}</p>
        <p class="font-mono text-[10px] text-text-dim tracking-[2px]">カラー</p>
      </div>
    </div>
    <form action="/search/" method="get" class="max-w-xl mx-auto animate-fade-up" style="animation-delay: 300ms;">
      <div class="relative flex items-center bg-white rounded-full shadow-lg border border-gray-200 hover:border-accent focus-within:border-accent focus-within:ring-2 focus-within:ring-accent/20 transition-all duration-200">
        <svg class="absolute left-5 w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" name="q" placeholder="ルアー名・メーカー名で検索..."
               class="w-full pl-13 pr-28 py-4 text-[15px] rounded-full bg-transparent focus:outline-none" />
        <button type="submit" class="absolute right-2 bg-accent text-white font-mono font-bold text-[13px] px-6 py-2.5 rounded-full tracking-[1px] hover:bg-accent-dark active:scale-95 transition-all duration-200">
          検索
        </button>
      </div>
    </form>
  </div>
</section>
