---
interface TypeItem {
  name: string;
  slug: string;
  count: number;
  image: string | null;
}

interface MakerItem {
  name: string;
  slug: string;
  count: number;
}

interface FishItem {
  name: string;
  slug: string;
  count: number;
}

interface Props {
  types: TypeItem[];
  makers: MakerItem[];
  fish: FishItem[];
  remainingTypeCount: number;
  remainingMakerCount: number;
  remainingFishCount: number;
  makerLogos: Record<string, string>;
}

const { types, makers, fish, remainingTypeCount, remainingMakerCount, remainingFishCount, makerLogos } = Astro.props;

// 魚種SVGアイコンの存在マップ（publicディレクトリに配置済み）
const FISH_SVG_AVAILABLE = new Set([
  'bass', 'black-bass', 'bluerunner', 'hiramasa', 'hirame',
  'madai', 'mebaru', 'seabass', 'trout',
]);

// SVGがない魚種のemoji fallback
const FISH_EMOJI: Record<string, string> = {
  'aji': '🐟', 'squid': '🦑', 'aori-ika': '🦑', 'octopus': '🐙',
  'yellowtail': '🐟', 'kampachi': '🐟', 'tuna': '🐟', 'rockfish': '🐡',
  'kurodai': '🐟', 'magochi': '🐟', 'tachiuo': '🐟', 'catfish': '🐱',
  'mahi-mahi': '🐟', 'salmon': '🐟', 'offshore': '🌊', 'saltwater': '🌊',
  'gt': '🐟', 'kasago': '🐡', 'sawara': '🐟', 'goby': '🐟',
  'bluerunner-all': '🐟', 'rockfish-all': '🐡', 'trout-all': '🐟',
  'squid-all': '🦑', 'chinu-kurodai': '🐟', 'hirame-magochi': '🐟',
};

// メーカー名からアバター色を生成（名前ハッシュベース）
function getAvatarColor(name: string): string {
  const colors = [
    'bg-accent-bg text-accent',
    'bg-blue-50 text-blue-600',
    'bg-orange-50 text-orange-600',
    'bg-purple-50 text-purple-600',
    'bg-rose-50 text-rose-600',
    'bg-teal-50 text-teal-600',
  ];
  let hash = 0;
  for (let i = 0; i < name.length; i++) hash = (hash * 31 + name.charCodeAt(i)) | 0;
  return colors[Math.abs(hash) % colors.length];
}
---

<div class="max-w-[960px] mx-auto">
  <!-- ピル型タブ -->
  <div class="flex gap-2 mb-5" role="tablist">
    <button
      role="tab"
      aria-selected="true"
      data-tab="type"
      class="portal-tab portal-tab--active px-5 py-2 rounded-full font-mono text-[13px] font-bold transition-all duration-200 bg-text text-bg"
    >
      タイプ
    </button>
    <button
      role="tab"
      aria-selected="false"
      data-tab="species"
      class="portal-tab px-5 py-2 rounded-full font-mono text-[13px] font-bold transition-all duration-200 bg-surface text-text-dim hover:bg-elevated"
    >
      対象魚
    </button>
    <button
      role="tab"
      aria-selected="false"
      data-tab="maker"
      class="portal-tab px-5 py-2 rounded-full font-mono text-[13px] font-bold transition-all duration-200 bg-surface text-text-dim hover:bg-elevated"
    >
      メーカー
    </button>
  </div>

  <!-- タブコンテンツ: TYPE -->
  <div data-panel="type" class="portal-panel">
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 gap-3">
      {types.map(t => (
        <a
          href={`/type/${t.slug}/`}
          class="group flex flex-col items-center text-center p-3 sm:p-4 rounded-xl border border-transparent bg-bg transition-all duration-200 hover:border-accent hover:shadow-card hover:-translate-y-1"
        >
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full overflow-hidden flex items-center justify-center mb-2.5 bg-surface group-hover:bg-accent-bg transition-colors duration-200">
            {t.image ? (
              <img src={t.image} alt={t.name} class="w-10 h-10 sm:w-11 sm:h-11 object-contain" loading="lazy" />
            ) : (
              <span class="font-mono text-[10px] text-text-dim">{t.slug}</span>
            )}
          </div>
          <span class="text-[13px] sm:text-[14px] font-bold text-text leading-tight">{t.name}</span>
          <span class="font-mono text-[11px] text-text-faint mt-0.5">{t.count.toLocaleString()}</span>
        </a>
      ))}
      <a
        href="/type/"
        class="group flex flex-col items-center justify-center text-center p-3 sm:p-4 rounded-xl border border-transparent bg-bg transition-all duration-200 hover:border-accent hover:shadow-card hover:-translate-y-1"
      >
        <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full flex items-center justify-center mb-2.5 bg-surface group-hover:bg-accent-bg transition-colors duration-200">
          <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </div>
        <span class="text-[13px] sm:text-[14px] font-bold text-text-dim">もっと見る</span>
        <span class="font-mono text-[11px] text-text-faint mt-0.5">+{remainingTypeCount}</span>
      </a>
    </div>
  </div>

  <!-- タブコンテンツ: SPECIES -->
  <div data-panel="species" class="portal-panel hidden">
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 gap-3">
      {fish.map(f => {
        const hasSvg = FISH_SVG_AVAILABLE.has(f.slug);
        const emoji = FISH_EMOJI[f.slug] || '🐟';
        return (
          <a
            href={`/fish/${f.slug}/`}
            class="group flex flex-col items-center text-center p-3 sm:p-4 rounded-xl border border-transparent bg-bg transition-all duration-200 hover:border-accent hover:shadow-card hover:-translate-y-1"
          >
            <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full overflow-hidden flex items-center justify-center mb-2.5 bg-surface group-hover:bg-accent-bg transition-colors duration-200">
              {hasSvg ? (
                <img src={`/icons/fish/${f.slug}.svg`} alt={f.name} class="w-8 h-8 sm:w-10 sm:h-10 object-contain" loading="lazy" />
              ) : (
                <span class="text-2xl sm:text-3xl leading-none">{emoji}</span>
              )}
            </div>
            <span class="text-[13px] sm:text-[14px] font-bold text-text leading-tight">{f.name}</span>
            <span class="font-mono text-[11px] text-text-faint mt-0.5">{f.count.toLocaleString()}</span>
          </a>
        );
      })}
      <a
        href="/fish/"
        class="group flex flex-col items-center justify-center text-center p-3 sm:p-4 rounded-xl border border-transparent bg-bg transition-all duration-200 hover:border-accent hover:shadow-card hover:-translate-y-1"
      >
        <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full flex items-center justify-center mb-2.5 bg-surface group-hover:bg-accent-bg transition-colors duration-200">
          <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </div>
        <span class="text-[13px] sm:text-[14px] font-bold text-text-dim">もっと見る</span>
        <span class="font-mono text-[11px] text-text-faint mt-0.5">+{remainingFishCount}</span>
      </a>
    </div>
  </div>

  <!-- タブコンテンツ: MAKER -->
  <div data-panel="maker" class="portal-panel hidden">
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 gap-3">
      {makers.map(m => {
        const hasLogo = !!makerLogos[m.slug];
        const avatarColor = getAvatarColor(m.name);
        // 略称: 英語メーカーは大文字のみ抽出 or 先頭3文字、日本語は先頭2文字
        const abbrev = /^[a-zA-Z0-9]/.test(m.name)
          ? m.name.replace(/[^A-Z]/g, '').slice(0, 3) || m.name.slice(0, 3).toUpperCase()
          : m.name.slice(0, 2);
        return (
          <a
            href={`/${m.slug}/`}
            class="group flex flex-col items-center text-center p-3 sm:p-4 rounded-xl border border-transparent bg-bg transition-all duration-200 hover:border-accent hover:shadow-card hover:-translate-y-1"
          >
            <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full overflow-hidden flex items-center justify-center mb-2.5 bg-surface group-hover:bg-accent-bg transition-colors duration-200">
              {hasLogo ? (
                <img src={makerLogos[m.slug]} alt={m.name} class="w-10 h-10 sm:w-11 sm:h-11 object-contain" loading="lazy" />
              ) : (
                <span class={`w-full h-full rounded-full flex items-center justify-center font-bold text-[11px] sm:text-[13px] ${avatarColor}`}>
                  {abbrev}
                </span>
              )}
            </div>
            <span class="text-[13px] sm:text-[14px] font-bold text-text leading-tight line-clamp-1">{m.name}</span>
            <span class="font-mono text-[11px] text-text-faint mt-0.5">{m.count.toLocaleString()}</span>
          </a>
        );
      })}
      <a
        href="/maker/"
        class="group flex flex-col items-center justify-center text-center p-3 sm:p-4 rounded-xl border border-transparent bg-bg transition-all duration-200 hover:border-accent hover:shadow-card hover:-translate-y-1"
      >
        <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full flex items-center justify-center mb-2.5 bg-surface group-hover:bg-accent-bg transition-colors duration-200">
          <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </div>
        <span class="text-[13px] sm:text-[14px] font-bold text-text-dim">もっと見る</span>
        <span class="font-mono text-[11px] text-text-faint mt-0.5">+{remainingMakerCount}</span>
      </a>
    </div>
  </div>

  <!-- 検索バー行 -->
  <div class="mt-5 flex gap-2">
    <form action="/search/" method="get" class="flex gap-2 w-full">
      <div class="relative flex-1">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          name="q"
          placeholder="フリーワードで検索..."
          class="w-full pl-10 pr-4 py-3 border border-border rounded-xl text-[14px] bg-bg focus:border-accent focus:outline-none transition-colors duration-200"
        />
      </div>
      <button
        type="submit"
        class="bg-accent text-white font-mono font-bold text-[13px] px-6 py-3 rounded-xl tracking-[1px] hover:bg-accent-dark transition-colors duration-200"
      >
        検索
      </button>
    </form>
  </div>
</div>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.portal-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.portal-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      // タブの切り替え（ピル型）
      tabs.forEach(t => {
        const isActive = t.dataset.tab === target;
        t.classList.toggle('portal-tab--active', isActive);
        // アクティブ: 黒背景 + 白テキスト
        t.classList.toggle('bg-text', isActive);
        t.classList.toggle('text-bg', isActive);
        // 非アクティブ: surface背景 + dimテキスト
        t.classList.toggle('bg-surface', !isActive);
        t.classList.toggle('text-text-dim', !isActive);
        t.setAttribute('aria-selected', String(isActive));
      });

      // パネルの切り替え
      panels.forEach(p => {
        p.classList.toggle('hidden', p.dataset.panel !== target);
      });
    });
  });
</script>
