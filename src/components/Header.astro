---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/[0.94] backdrop-blur-xl border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <span class="font-mono text-[20px] font-bold tracking-[2px]">CAST<span class="text-accent">/</span>LOG</span>
      </a>
      <nav class="flex items-center gap-3 sm:gap-5 font-mono text-[11px] tracking-[1.5px] uppercase">
        <a
          href="/maker/"
          class:list={[
            'transition-colors duration-[0.15s]',
            currentPath.startsWith('/maker') ? 'text-text font-bold' : 'text-text-dim hover:text-text'
          ]}
        >
          MAKER
        </a>
        <a
          href="/type/"
          class:list={[
            'transition-colors duration-[0.15s]',
            currentPath.startsWith('/type') ? 'text-text font-bold' : 'text-text-dim hover:text-text'
          ]}
        >
          TYPE
        </a>
        <a
          href="/fish/"
          class:list={[
            'transition-colors duration-[0.15s]',
            currentPath.startsWith('/fish') ? 'text-text font-bold' : 'text-text-dim hover:text-text'
          ]}
        >
          SPECIES
        </a>
        <a
          href="/ranking/"
          class:list={[
            'transition-colors duration-[0.15s]',
            currentPath.startsWith('/ranking') ? 'text-text font-bold' : 'text-text-dim hover:text-text'
          ]}
        >
          RANKING
        </a>
        <a
          href="/search/"
          class:list={[
            'transition-colors duration-[0.15s]',
            currentPath.startsWith('/search') ? 'text-text font-bold' : 'text-text-dim hover:text-text'
          ]}
        >
          SEARCH
        </a>
      </nav>
    </div>
  </div>
</header>
