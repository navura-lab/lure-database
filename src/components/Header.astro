---
import { getUI } from '../i18n/lib/t';
import { getBasePrefix, getJaPath, getEnPath } from '../i18n/lib/locale';
import type { Locale } from '../i18n/lib/t';

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? 'ja';
const ui = getUI(locale);
const prefix = getBasePrefix(locale);
const currentPath = Astro.url.pathname;

// 言語切替リンク
const altLangHref = locale === 'ja' ? getEnPath(currentPath) : getJaPath(currentPath);
const altLangLabel = locale === 'ja' ? 'EN' : 'JA';

const navLinks = [
  { href: `${prefix}/maker/`, label: ui.nav.maker, prefix: `${prefix}/maker` },
  { href: `${prefix}/type/`, label: ui.nav.type, prefix: `${prefix}/type` },
  { href: `${prefix}/fish/`, label: ui.nav.fish, prefix: `${prefix}/fish` },
  { href: `${prefix}/ranking/`, label: ui.nav.catalog, prefix: `${prefix}/ranking` },
  { href: `${prefix}/method/`, label: ui.nav.method, prefix: `${prefix}/method` },
  { href: `${prefix}/season/`, label: ui.nav.season, prefix: `${prefix}/season` },
  { href: `${prefix}/guide/`, label: ui.nav.guide, prefix: `${prefix}/guide` },
  { href: `${prefix}/article/`, label: ui.nav.article, prefix: `${prefix}/article` },
  { href: `${prefix}/search/`, label: ui.nav.search, prefix: `${prefix}/search` },
];
---

<header class="sticky top-0 z-50 bg-white/[0.94] backdrop-blur-xl border-b border-border" data-pagefind-ignore>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href={`${prefix}/`} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <span class="font-mono text-[20px] font-bold tracking-[2px]">CAST<span class="text-accent">/</span>LOG</span>
      </a>

      <!-- デスクトップナビ -->
      <nav class="hidden sm:flex items-center gap-5 font-mono text-[11px] tracking-[1px]">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'transition-colors duration-[0.15s]',
              currentPath.startsWith(link.prefix) ? 'text-text font-bold' : 'text-text-dim hover:text-text'
            ]}
          >
            {link.label}
          </a>
        ))}
        <!-- お気に入り -->
        <a href="/search/?favorites=1" class="relative text-text-dim hover:text-text transition-colors duration-200" aria-label="お気に入り">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          <span id="fav-count" class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center hidden">0</span>
        </a>
        <!-- 言語切替 -->
        <a
          href={altLangHref}
          class="text-text-dim hover:text-text transition-colors duration-[0.15s] border-l border-border pl-4"
          aria-label={ui.aria.languageSwitch}
        >
          {altLangLabel}
        </a>
      </nav>

      <!-- モバイルハンバーガーボタン -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden flex items-center justify-center w-10 h-10 -mr-2"
        aria-label={ui.aria.openMenu}
        aria-expanded="false"
      >
        <!-- ハンバーガーアイコン -->
        <svg id="menu-icon-open" class="w-5 h-5 text-text" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- 閉じるアイコン -->
        <svg id="menu-icon-close" class="w-5 h-5 text-text hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div id="mobile-menu" class="sm:hidden hidden border-t border-border bg-white">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'font-mono text-[13px] tracking-[1px] px-3 py-2.5 rounded-lg transition-colors duration-[0.15s]',
            currentPath.startsWith(link.prefix)
              ? 'text-accent font-bold bg-accent-bg'
              : 'text-text-mid hover:text-text hover:bg-surface'
          ]}
        >
          {link.label}
        </a>
      ))}
      <!-- モバイルお気に入り -->
      <a href="/search/?favorites=1" class="block py-2 font-mono text-[13px] tracking-[1px] text-text-dim hover:text-text transition-colors">
        ♥ お気に入り
      </a>
      <!-- モバイル言語切替 -->
      <a
        href={altLangHref}
        class="font-mono text-[13px] tracking-[1px] px-3 py-2.5 rounded-lg text-text-mid hover:text-text hover:bg-surface border-t border-border mt-1 pt-3"
        aria-label={ui.aria.languageSwitch}
      >
        🌐 {altLangLabel === 'EN' ? 'English' : '日本語'}
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    // aria-labelはlocaleに依存するためdata属性で管理
    const openLabel = btn.dataset.labelOpen || 'Open menu';
    const closeLabel = btn.dataset.labelClose || 'Close menu';
    btn.setAttribute('aria-label', isOpen ? openLabel : closeLabel);
  });
</script>
