---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 text-gray-900 hover:text-primary transition-colors">
        <span class="text-xl font-bold tracking-tight">ルアーDB</span>
      </a>
      <nav class="flex items-center gap-4 sm:gap-6 text-sm">
        <a
          href="/"
          class:list={[
            'transition-colors',
            currentPath === '/' ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'
          ]}
        >
          検索
        </a>
        <a
          href="/type/"
          class:list={[
            'transition-colors',
            currentPath.startsWith('/type') ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'
          ]}
        >
          タイプ
        </a>
        <a
          href="/fish/"
          class:list={[
            'transition-colors',
            currentPath.startsWith('/fish') ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'
          ]}
        >
          対象魚
        </a>
      </nav>
    </div>
  </div>
</header>
