---
import Badge from './Badge.astro';
import Placeholder from './Placeholder.astro';
import type { LureSeries } from '../lib/types';
import { getUI, formatPriceRange } from '../i18n/lib/t';
import { getBasePrefix } from '../i18n/lib/locale';
import type { Locale } from '../i18n/lib/t';

interface Props {
  series: LureSeries;
  isNew: boolean;
  priority?: boolean;
  rank?: number; // ランキングページでの順位（1始まり）
  locale?: Locale;
}

const { series, isNew, priority = false, rank, locale = 'ja' } = Astro.props;
const ui = getUI(locale);
const prefix = getBasePrefix(locale);

const hasLimited = (series.colors || []).some(c => c.is_limited);
const hasPrice = series.price_range.max > 0;
const priceDisplay = hasPrice
  ? formatPriceRange(series.price_range.min, series.price_range.max, locale)
  : null;

const filterData = JSON.stringify({
  name: series.name,
  manufacturer: series.manufacturer,
  manufacturer_slug: series.manufacturer_slug,
  type: series.type,
  target_fish: series.target_fish,
});
---

<a
  href={`${prefix}/${series.manufacturer_slug}/${series.slug}/`}
  class="group block h-full"
  data-series={filterData}
>
  <div class="bg-bg rounded-2xl border border-border-light overflow-hidden shadow-card hover-lift hover-glow transition-all duration-200 group-hover:scale-[1.01] h-full flex flex-col">
    <div class="aspect-[4/3] relative overflow-hidden bg-gradient-to-br from-surface to-bg">
      {series.representative_image ? (
        <img
          src={series.representative_image}
          alt={`${series.manufacturer} ${series.name} ${series.type}`}
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : undefined}
          width="500"
          height="375"
          class="w-full h-full object-scale-down p-3 transition-transform duration-500 ease-out group-hover:scale-105"
        />
      ) : (
        <Placeholder type={series.type} />
      )}
      {rank && rank <= 3 && (
        <div class="absolute top-2 left-2">
          <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold shadow-md ${
            rank === 1 ? 'bg-gradient-to-br from-yellow-400 to-amber-500 text-white' :
            rank === 2 ? 'bg-gradient-to-br from-gray-300 to-gray-400 text-white' :
            'bg-gradient-to-br from-orange-300 to-orange-400 text-white'
          }`}>{rank}</span>
        </div>
      )}
      <div class="absolute top-2 right-2 flex flex-col gap-1">
        {isNew && <Badge label={ui.lureCard.new} variant="new" />}
        {hasLimited && <Badge label={ui.lureCard.limited} variant="limited" />}
      </div>
      <button
        class="heart-btn absolute bottom-3 right-3 w-9 h-9 rounded-full
               bg-white/80 backdrop-blur-sm border border-white/50
               flex items-center justify-center
               opacity-0 group-hover:opacity-100 sm:opacity-0 sm:group-hover:opacity-100
               transition-opacity duration-200
               hover:bg-white hover:scale-110 active:scale-95"
        data-lure-slug={`${series.manufacturer_slug}/${series.slug}`}
        aria-label="お気に入り"
        onclick="event.preventDefault(); event.stopPropagation(); toggleFavorite(this);"
      >
        <svg class="w-5 h-5 text-text-dim heart-icon" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </button>
    </div>

    <div class="p-4 flex-1 flex flex-col">
      <p class="text-xs text-text-mid tracking-wider uppercase mb-1 line-clamp-1">
        {series.manufacturer}
      </p>
      <h3 class="text-base font-bold text-text mb-1.5 group-hover:text-accent transition-colors line-clamp-2 min-h-[2.75rem]">
        {series.name}
      </h3>
      <div class="flex items-center gap-1.5 text-xs text-text-mid mb-3">
        <Badge label={series.type} variant="type" />
        <span>{series.color_count} {ui.lureCard.colors}</span>
      </div>
      <div class="mt-auto">
        {priceDisplay && (
          <p class="text-sm font-bold text-text">
            {priceDisplay}
          </p>
        )}
      </div>
    </div>
  </div>
</a>
