---
interface Props {
  label: string;
  href: string;
  count: number;
  variant?: 'type' | 'maker' | 'fish' | 'more';
  imageSrc?: string;
}

const { label, href, count, variant = 'type', imageSrc } = Astro.props;

const bgColors: Record<string, string> = {
  type: 'bg-accent-bg hover:bg-accent-bg border-accent-bg',
  maker: 'bg-surface hover:bg-elevated border-border-light',
  fish: 'bg-accent-bg hover:bg-accent-bg border-accent-bg',
  more: 'bg-surface hover:bg-elevated border-border',
};

const iconColors: Record<string, string> = {
  type: 'bg-accent-bg',
  maker: 'bg-elevated',
  fish: 'bg-accent-bg',
  more: 'bg-elevated',
};

const textColors: Record<string, string> = {
  type: 'text-accent',
  maker: 'text-text',
  fish: 'text-accent',
  more: 'text-text-dim',
};

// 商品画像（type）は角丸四角、SVG/ロゴ（fish/maker）は丸
const isProductImage = imageSrc && variant === 'type';
---

<a
  href={href}
  class:list={[
    "flex flex-col items-center justify-center p-1.5 sm:p-3 rounded-xl border transition-all duration-200 hover:shadow-sm",
    bgColors[variant],
  ]}
>
  <div
    class:list={[
      "flex items-center justify-center mb-1 sm:mb-2 overflow-hidden",
      isProductImage
        ? "w-10 h-10 sm:w-14 sm:h-14 rounded-lg"
        : "w-9 h-9 sm:w-12 sm:h-12 rounded-full",
      iconColors[variant],
    ]}
  >
    {variant === 'more' ? (
      <svg class="w-4 h-4 sm:w-5 sm:h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h.01M12 12h.01M19 12h.01" />
      </svg>
    ) : imageSrc ? (
      <img
        src={imageSrc}
        alt={label}
        class:list={[
          "object-contain",
          isProductImage ? "w-8 h-8 sm:w-11 sm:h-11" : "w-5 h-5 sm:w-7 sm:h-7",
        ]}
        loading="lazy"
      />
    ) : (
      <div class:list={["w-5 h-5 sm:w-7 sm:h-7 rounded-full opacity-40", iconColors[variant]]}></div>
    )}
  </div>
  <span class:list={["text-[10px] sm:text-sm font-bold text-center leading-tight line-clamp-2", textColors[variant]]}>
    {variant === 'more' ? 'その他' : label}
  </span>
  <span class="text-[9px] sm:text-xs text-text-dim mt-0.5">
    {count.toLocaleString()}
  </span>
</a>
