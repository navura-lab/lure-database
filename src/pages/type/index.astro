---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { getTypeSlug } from '../../lib/category-slugs';

const lures = await fetchAllLures();
const allSeries = groupLuresBySeries(lures ?? []);

// タイプ別に集計
const typeStats = new Map<string, { count: number; colors: number; image: string | null; topMakers: { name: string; count: number }[] }>();
for (const s of allSeries) {
  if (!s.type) continue;
  const existing = typeStats.get(s.type);
  if (existing) {
    existing.count++;
    existing.colors += s.color_count;
    if (!existing.image && s.representative_image) existing.image = s.representative_image;
  } else {
    typeStats.set(s.type, { count: 1, colors: s.color_count, image: s.representative_image, topMakers: [] });
  }
}

// 各タイプの上位メーカーを算出
for (const [typeName, stats] of typeStats) {
  const makerCount = new Map<string, number>();
  for (const s of allSeries) {
    if (s.type === typeName) {
      makerCount.set(s.manufacturer, (makerCount.get(s.manufacturer) || 0) + 1);
    }
  }
  stats.topMakers = [...makerCount.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 3)
    .map(([name, count]) => ({ name, count }));
}

const typeList = [...typeStats.entries()]
  .map(([name, stats]) => ({ name, slug: getTypeSlug(name), ...stats }));

const byCount = [...typeList].sort((a, b) => b.count - a.count);
const byName = [...typeList].sort((a, b) => a.name.localeCompare(b.name, 'ja'));

const totalSeries = typeList.reduce((sum, t) => sum + t.count, 0);
const totalColors = typeList.reduce((sum, t) => sum + t.colors, 0);

const topTypeNames = byCount.slice(0, 5).map(t => t.name).join('・');
const pageDescription = `ルアーを${typeList.length}タイプに分類。${topTypeNames}等、全${totalSeries}シリーズ・${totalColors.toLocaleString()}カラーを掲載。タイプ別にルアーを検索・比較。`;

const pageTitle = `ルアータイプ一覧${typeList.length}種 - ${topTypeNames}等 - CAST/LOG`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.castlog.xyz/' },
    { '@type': 'ListItem', position: 2, name: 'ルアータイプ', item: 'https://www.castlog.xyz/type/' },
  ],
};

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ルアータイプ一覧',
  url: 'https://www.castlog.xyz/type/',
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: typeList.length,
    itemListElement: byCount.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.castlog.xyz/type/${t.slug}/`,
      name: t.name,
    })),
  },
};

const jsonLd = [breadcrumbLd, collectionLd] as unknown as Record<string, unknown>;

const introText = `ルアーを${typeList.length}のカテゴリに分類して一覧表示。${topTypeNames}など、タイプごとの特徴やシリーズ数を比較できる。バス釣り・ソルトルアー・トラウトなど、釣りのスタイルに合ったルアータイプを見つけよう。`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/type/" jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">ルアータイプ</span>
    </nav>

    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">ルアータイプ一覧</h1>
      <p class="text-sm text-text-mid mt-1 font-mono">
        {typeList.length} TYPES / {totalSeries} SERIES
      </p>
      <p class="text-sm text-gray-600 leading-relaxed mt-3 max-w-3xl">
        {introText}
      </p>
    </div>

    <!-- ソート切替 + 検索 -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 mb-6">
      <div class="flex gap-2">
        <button
          id="sort-count"
          class="px-3 py-1.5 text-xs font-mono rounded border border-accent bg-accent text-white transition-colors"
          data-active="true"
        >
          シリーズ数順
        </button>
        <button
          id="sort-name"
          class="px-3 py-1.5 text-xs font-mono rounded border border-border text-text-mid hover:border-accent hover:text-accent transition-colors"
          data-active="false"
        >
          50音順
        </button>
      </div>
      <div class="relative flex-1 max-w-xs">
        <input
          id="type-search"
          type="text"
          placeholder="タイプ名を検索..."
          class="w-full pl-8 pr-3 py-1.5 text-sm border border-border rounded focus:outline-none focus:border-accent transition-colors"
        />
        <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-text-dim" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>

    <!-- タイプ一覧 -->
    <div id="type-list" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {byCount.map(t => (
        <a
          href={`/type/${t.slug}/`}
          class="type-card group block bg-white rounded-lg border border-gray-100 overflow-hidden transition-all duration-150 hover:border-accent hover:scale-[1.01]"
          data-name={t.name.toLowerCase()}
          data-count={t.count}
        >
          <div class="p-3 sm:p-4">
            <h2 class="text-sm sm:text-base font-bold text-gray-900 group-hover:text-accent transition-colors mb-1.5 leading-tight">
              {t.name}
            </h2>
            <div class="flex items-center gap-2 text-xs text-text-mid font-mono mb-2">
              <span>{t.count} series</span>
              <span class="text-text-faint">|</span>
              <span>{t.colors} colors</span>
            </div>
            {t.topMakers.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {t.topMakers.map(m => (
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-mono text-text-mid bg-gray-50 border border-gray-100">
                    {m.name}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- 検索結果なし -->
    <div id="no-results" class="hidden text-center py-12 text-text-dim">
      <p class="text-lg">該当するタイプが見つかりません</p>
    </div>

  </div>

  <script define:vars={{ byCountOrder: byCount.map(t => t.name), byNameOrder: byName.map(t => t.name) }}>
    document.addEventListener('DOMContentLoaded', () => {
      const sortCountBtn = document.getElementById('sort-count');
      const sortNameBtn = document.getElementById('sort-name');
      const searchInput = document.getElementById('type-search');
      const typeListEl = document.getElementById('type-list');
      const noResults = document.getElementById('no-results');

      function setActiveSort(activeBtn, inactiveBtn) {
        activeBtn.classList.add('bg-accent', 'text-white', 'border-accent');
        activeBtn.classList.remove('text-text-mid', 'border-border');
        activeBtn.dataset.active = 'true';
        inactiveBtn.classList.remove('bg-accent', 'text-white', 'border-accent');
        inactiveBtn.classList.add('text-text-mid', 'border-border');
        inactiveBtn.dataset.active = 'false';
      }

      function reorder(order) {
        const cards = [...document.querySelectorAll('.type-card')];
        const cardMap = new Map();
        cards.forEach(c => cardMap.set(c.dataset.name, c));

        order.forEach(name => {
          const card = cardMap.get(name.toLowerCase());
          if (card) typeListEl.appendChild(card);
        });
        applySearch();
      }

      sortCountBtn.addEventListener('click', () => {
        if (sortCountBtn.dataset.active === 'true') return;
        setActiveSort(sortCountBtn, sortNameBtn);
        reorder(byCountOrder);
      });

      sortNameBtn.addEventListener('click', () => {
        if (sortNameBtn.dataset.active === 'true') return;
        setActiveSort(sortNameBtn, sortCountBtn);
        reorder(byNameOrder);
      });

      let searchTimeout;
      searchInput.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(applySearch, 150);
      });

      function applySearch() {
        const query = searchInput.value.toLowerCase().trim();
        const cards = document.querySelectorAll('.type-card');
        let visibleCount = 0;

        cards.forEach(card => {
          const name = card.dataset.name || '';
          const match = !query || name.includes(query);
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });

        noResults.style.display = visibleCount === 0 ? '' : 'none';
      }
    });
  </script>
</BaseLayout>
