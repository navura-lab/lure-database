---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { getTypeSlug } from '../../lib/category-slugs';

const lures = await fetchAllLures();
const allSeries = groupLuresBySeries(lures ?? []);

// タイプ別に集計
const typeStats = new Map<string, { count: number; colors: number; image: string | null }>();
for (const s of allSeries) {
  if (!s.type) continue;
  const existing = typeStats.get(s.type);
  if (existing) {
    existing.count++;
    existing.colors += s.color_count;
    if (!existing.image && s.representative_image) existing.image = s.representative_image;
  } else {
    typeStats.set(s.type, { count: 1, colors: s.color_count, image: s.representative_image });
  }
}

const typeList = [...typeStats.entries()]
  .map(([name, stats]) => ({ name, slug: getTypeSlug(name), ...stats }))
  .sort((a, b) => b.count - a.count);

const totalSeries = typeList.reduce((sum, t) => sum + t.count, 0);
const totalColors = typeList.reduce((sum, t) => sum + t.colors, 0);

const topTypeNames = typeList.slice(0, 5).map(t => t.name).join('・');
const pageDescription = `ルアーを${typeList.length}タイプに分類。${topTypeNames}等、全${totalSeries}シリーズ・${totalColors.toLocaleString()}カラーを掲載。タイプ別にルアーを検索・比較。`;

const pageTitle = `ルアータイプ一覧${typeList.length}種 - ${topTypeNames}等 - ルアーDB`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.lure-db.com/' },
    { '@type': 'ListItem', position: 2, name: 'ルアータイプ', item: 'https://www.lure-db.com/type/' },
  ],
};

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ルアータイプ一覧',
  url: 'https://www.lure-db.com/type/',
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: typeList.length,
    itemListElement: typeList.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.lure-db.com/type/${t.slug}/`,
      name: t.name,
    })),
  },
};

const jsonLd = [breadcrumbLd, collectionLd] as unknown as Record<string, unknown>;

const introText = `ルアーを${typeList.length}のカテゴリに分類して一覧表示。${topTypeNames}など、タイプごとの特徴やシリーズ数を比較できる。バス釣り・ソルトルアー・トラウトなど、釣りのスタイルに合ったルアータイプを見つけよう。`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/type/" jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-secondary mb-8">
      <a href="/" class="hover:text-primary transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">ルアータイプ</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">ルアータイプ一覧</h1>
      <p class="text-sm text-text-secondary mt-1">
        {typeList.length}タイプ・{totalSeries}シリーズ
      </p>
      <p class="text-sm text-gray-600 leading-relaxed mt-3 max-w-3xl">
        {introText}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {typeList.map(t => (
        <a href={`/type/${t.slug}/`} class="group block bg-white rounded-xl border border-gray-100 overflow-hidden shadow-card transition-all duration-200 hover:shadow-card-hover hover:scale-[1.01]">
          <div class="p-5">
            <h2 class="text-base font-bold text-gray-900 group-hover:text-primary transition-colors mb-2">
              {t.name}
            </h2>
            <div class="flex items-center gap-3 text-xs text-text-secondary">
              <span>{t.count}シリーズ</span>
              <span>{t.colors}カラー</span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
