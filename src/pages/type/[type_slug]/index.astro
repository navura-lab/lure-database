---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LureCard from '../../../components/LureCard.astro';
import { fetchAllLures } from '../../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../../lib/group-lures';
import { TYPE_SLUG_MAP, TYPE_NAME_MAP, getFishSlug } from '../../../lib/category-slugs';
import { typeDescriptions } from '../../../data/type-descriptions';
import { guideArticles } from '../../../data/guides';
import { contentArticles } from '../../../data/articles/_index';
import type { LureSeries } from '../../../lib/types';

export async function getStaticPaths() {
  const lures = await fetchAllLures();
  const allSeries = groupLuresBySeries(lures ?? []);

  // タイプ別にグルーピング
  const typeMap = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    if (!s.type) continue;
    const existing = typeMap.get(s.type) || [];
    existing.push(s);
    typeMap.set(s.type, existing);
  }

  // 各タイプの対象魚プロファイルを計算（関連タイプ算出用）
  const typeProfiles = new Map<string, { fish: Set<string>; count: number }>();
  for (const [name, seriesList] of typeMap) {
    const fish = new Set<string>();
    for (const s of seriesList) {
      for (const f of s.target_fish) fish.add(f);
    }
    typeProfiles.set(name, { fish, count: seriesList.length });
  }

  return [...typeMap.entries()].map(([typeName, series]) => {
    const slug = TYPE_SLUG_MAP[typeName] ?? encodeURIComponent(typeName);

    // 関連タイプ: 対象魚の重複度でスコアリング
    const profile = typeProfiles.get(typeName)!;
    const scored: { name: string; slug: string; count: number; score: number }[] = [];
    for (const [otherName, otherProfile] of typeProfiles) {
      if (otherName === typeName) continue;
      let score = 0;
      for (const f of profile.fish) { if (otherProfile.fish.has(f)) score++; }
      if (score > 0) {
        scored.push({
          name: otherName,
          slug: TYPE_SLUG_MAP[otherName] ?? encodeURIComponent(otherName),
          count: otherProfile.count,
          score,
        });
      }
    }
    scored.sort((a, b) => b.score - a.score || b.count - a.count);
    const relatedTypes = scored.slice(0, 8).map(({ name, slug, count }) => ({ name, slug, count }));

    return {
      params: { type_slug: slug },
      props: { typeName, series, relatedTypes },
    };
  });
}

const { typeName, series, relatedTypes } = Astro.props as {
  typeName: string;
  series: LureSeries[];
  relatedTypes: { name: string; slug: string; count: number }[];
};

const typeSlug = Astro.params.type_slug as string;
const editorialText = typeDescriptions[typeSlug] ?? '';

// ─── 集計 ───

const totalColors = series.reduce((sum, s) => sum + s.color_count, 0);

// メーカー別シリーズ数
const makerCounts = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const existing = makerCounts.get(s.manufacturer_slug);
  if (existing) {
    existing.count++;
  } else {
    makerCounts.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
  }
}
const makerBreakdown = [...makerCounts.values()].sort((a, b) => b.count - a.count);

// 対象魚集計
const fishCounts = new Map<string, number>();
for (const s of series) {
  for (const fish of s.target_fish) {
    fishCounts.set(fish, (fishCounts.get(fish) || 0) + 1);
  }
}
const allTargetFish = [...fishCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([fish]) => fish)
  .slice(0, 15);

// 価格帯
const prices = series
  .flatMap(s => [s.price_range.min, s.price_range.max])
  .filter(p => p > 0);
const priceRange = prices.length > 0
  ? { min: Math.min(...prices), max: Math.max(...prices) }
  : null;

// 重量帯
const weights = series
  .flatMap(s => [s.weight_range.min, s.weight_range.max])
  .filter((w): w is number => w != null && w > 0);
const weightRange = weights.length > 0
  ? { min: Math.min(...weights), max: Math.max(...weights) }
  : null;

// 全長帯
const lengths = series
  .flatMap(s => [s.length_range.min, s.length_range.max])
  .filter((l): l is number => l != null && l > 0);
const lengthRange = lengths.length > 0
  ? { min: Math.min(...lengths), max: Math.max(...lengths) }
  : null;

// ─── SEO ───

const topMakers = makerBreakdown.slice(0, 3).map(m => m.name).join('・');
const topFish = allTargetFish.slice(0, 3).join('・');
const priceText = priceRange ? `価格¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}` : '';

const pageDescription = [
  `${typeName}のルアー${series.length}シリーズ・${totalColors}カラーを掲載。`,
  topMakers ? `${topMakers}等${makerBreakdown.length}メーカーが展開。` : '',
  topFish ? `${topFish}向け。` : '',
  priceText ? `${priceText}。` : '',
].filter(Boolean).join('');

// 概要テキスト
const summaryParts: string[] = [];
summaryParts.push(`${typeName}は${makerBreakdown.length}メーカーから${series.length}シリーズ・${totalColors}カラーが登録されている`);
if (topMakers) {
  summaryParts.push(`${topMakers}など人気メーカーがラインナップ`);
}
if (allTargetFish.length > 0) {
  const fishNames = allTargetFish.slice(0, 5).join('・');
  summaryParts.push(`主なターゲットは${fishNames}`);
}
if (priceRange) {
  summaryParts.push(`価格帯は¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}`);
}
const summaryText = summaryParts.join('。') + '。';

// スペック
const specItems: { label: string; value: string }[] = [];
specItems.push({ label: 'シリーズ数', value: `${series.length}` });
specItems.push({ label: 'カラー数', value: `${totalColors}色` });
if (priceRange) {
  specItems.push({ label: '価格帯', value: `¥${priceRange.min.toLocaleString()} 〜 ¥${priceRange.max.toLocaleString()}` });
}
if (weightRange) {
  specItems.push({ label: '重さ', value: `${weightRange.min}g 〜 ${weightRange.max}g` });
}
if (lengthRange) {
  specItems.push({ label: '全長', value: `${lengthRange.min}mm 〜 ${lengthRange.max}mm` });
}

// FAQ JSON-LD
const faqItems: { q: string; a: string }[] = [];

if (allTargetFish.length > 0) {
  const fishNames = allTargetFish.slice(0, 6).join('、');
  faqItems.push({
    q: `${typeName}で狙える魚種は？`,
    a: `${typeName}で狙える対象魚は${fishNames}など${allTargetFish.length > 6 ? allTargetFish.length + '種以上' : ''}。${series.length}シリーズから最適なルアーを選べる。`,
  });
}

if (priceRange) {
  faqItems.push({
    q: `${typeName}の価格帯は？`,
    a: `${typeName}の価格帯は¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}。${series.length}シリーズ・${totalColors}カラーが登録されている。`,
  });
}

if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 5).map(m => m.name).join('、');
  faqItems.push({
    q: `${typeName}の人気メーカーは？`,
    a: `${typeName}を展開するメーカーは${makerBreakdown.length}社。${makerNames}がシリーズ数上位に入る。`,
  });
}

if (weightRange) {
  faqItems.push({
    q: `${typeName}の重さの目安は？`,
    a: `登録されている${typeName}の重量範囲は${weightRange.min}g〜${weightRange.max}g。ターゲットや使用するタックルに合わせて選ぼう。`,
  });
}

const faqLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
} : null;

// JSON-LD
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${typeName}のルアー一覧`,
  url: `https://www.castlog.xyz/type/${typeSlug}/`,
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: series.length,
    itemListElement: series.slice(0, 50).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.castlog.xyz/${s.manufacturer_slug}/${s.slug}/`,
      name: `${s.manufacturer} ${s.name}`,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.castlog.xyz/' },
    { '@type': 'ListItem', position: 2, name: 'ルアータイプ', item: 'https://www.castlog.xyz/type/' },
    { '@type': 'ListItem', position: 3, name: typeName, item: `https://www.castlog.xyz/type/${typeSlug}/` },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])] as unknown as Record<string, unknown>;

// 関連ガイド記事
const relatedGuides = guideArticles.filter(g => g.targetTypes.includes(typeName));
---

<BaseLayout title={`${typeName}のルアー${series.length}シリーズ一覧${topMakers ? ` | ${topMakers}等` : ''} - CAST/LOG`} description={pageDescription} canonicalPath={`/type/${typeSlug}/`} jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href="/type/" class="hover:text-accent transition-colors">ルアータイプ</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{typeName}</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{typeName}</h1>
      <p class="text-sm text-text-mid mt-1">
        {series.length}シリーズ・{totalColors}カラー
      </p>
    </div>

    <!-- 概要セクション -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">

      <p class="text-sm text-gray-700 leading-relaxed mb-4">
        {summaryText}
      </p>

      {editorialText && (
        <p class="text-sm text-gray-600 leading-relaxed mb-5 border-l-2 border-accent pl-4">
          {editorialText}
        </p>
      )}

      <!-- スペックサマリー -->
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-5">
        {specItems.map(item => (
          <div>
            <p class="text-xs text-text-dim">{item.label}</p>
            <p class="text-sm font-semibold text-gray-900">{item.value}</p>
          </div>
        ))}
      </div>

      <!-- メーカー一覧 -->
      {makerBreakdown.length > 0 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">取り扱いメーカー</h2>
          <div class="flex flex-wrap gap-2">
            {makerBreakdown.map(m => (
              <a href={`/${m.slug}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent-bg transition-colors">
                {m.name}
                <span class="text-accent">{m.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- 対象魚タグ -->
      {allTargetFish.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">対象魚</h2>
          <div class="flex flex-wrap gap-1.5">
            {allTargetFish.map(fish => (
              <a href={`/fish/${getFishSlug(fish)}/`} class="px-2.5 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
                {fish}
              </a>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- シリーズ見出し -->
    <h2 class="text-lg font-bold text-gray-900 mb-4">全{series.length}シリーズ</h2>

    <!-- 商品グリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {series.map((s, i) => (
        <LureCard series={s} isNew={false} priority={i < 4} />
      ))}
    </div>

    <!-- 関連ガイド記事 -->
    {relatedGuides.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">{typeName}の選び方ガイド</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedGuides.map(guide => (
            <a href={`/guide/${guide.slug}/`} class="group flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
              <div>
                <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors">{guide.title.split('【')[0]}</p>
                <p class="text-xs text-text-dim mt-0.5">{guide.targetFish.join('・')}</p>
              </div>
              <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連記事（タイプマッチ） -->
    {(() => {
      const typeArticles = contentArticles.filter(a => a.targetTypes.includes(typeName)).slice(0, 6);
      return typeArticles.length > 0 ? (
        <section class="mt-12 pt-8 border-t border-gray-100">
          <h2 class="text-lg font-bold text-gray-900 mb-4">関連記事</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {typeArticles.map(article => (
              <a href={`/article/${article.slug}/`} class="group flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
                <div>
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors">{article.h1}</p>
                  <p class="text-xs text-text-dim mt-0.5">{article.targetFish.join('・')}</p>
                </div>
                <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            ))}
          </div>
        </section>
      ) : null;
    })()}

    <!-- 関連ルアータイプ -->
    {relatedTypes.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連ルアータイプ</h2>
        <p class="text-sm text-text-mid mb-4">
          {typeName}と同じ対象魚を狙えるルアータイプ
        </p>
        <div class="flex flex-wrap gap-2">
          {relatedTypes.map(t => (
            <a href={`/type/${t.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {t.name}
              <span class="text-xs text-gray-400">{t.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
