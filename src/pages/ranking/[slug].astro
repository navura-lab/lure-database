---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LureCard from '../../components/LureCard.astro';
import { getTypeSlug, getFishSlug } from '../../lib/category-slugs';
import { rankingDescriptions } from '../../data/ranking-descriptions';
import { guideArticles } from '../../data/guides';
import { getRankingPaths } from '../../lib/paths/ranking-paths';
import type { RankingPathProps } from '../../lib/paths/ranking-paths';
import type { LureSeries } from '../../lib/types';

export async function getStaticPaths() {
  return getRankingPaths();
}

const { fishName, typeName, rankedSeries, related, isCurated } = Astro.props as RankingPathProps;

const slug = Astro.params.slug as string;
const editorialText = rankingDescriptions[slug] ?? '';

// ─── 集計 ───

const totalColors = rankedSeries.reduce((sum, s) => sum + s.color_count, 0);

// メーカー別
const makerCounts = new Map<string, { name: string; slug: string; count: number }>();
for (const s of rankedSeries) {
  const existing = makerCounts.get(s.manufacturer_slug);
  if (existing) {
    existing.count++;
  } else {
    makerCounts.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
  }
}
const makerBreakdown = [...makerCounts.values()].sort((a, b) => b.count - a.count);

// 価格帯
const prices = rankedSeries
  .flatMap(s => [s.price_range.min, s.price_range.max])
  .filter(p => p > 0);
const priceRange = prices.length > 0
  ? { min: Math.min(...prices), max: Math.max(...prices) }
  : null;

// 重量帯
const weights = rankedSeries
  .flatMap(s => [s.weight_range.min, s.weight_range.max])
  .filter((w): w is number => w != null && w > 0);
const weightRange = weights.length > 0
  ? { min: Math.min(...weights), max: Math.max(...weights) }
  : null;

// ─── SEO ───

const topMakers = makerBreakdown.slice(0, 3).map(m => m.name).join('・');
const priceText = priceRange ? `¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}` : '';

// KP分析: 「[魚種] [タイプ] おすすめ」(210/月)、「[タイプ] ランキング」(140-210/月) が主要クエリ
const currentYear = new Date().getFullYear();
const pageTitle = `${fishName} ${typeName} おすすめランキング${rankedSeries.length}選【${currentYear}年】 | CAST/LOG`;
const pageDescription = [
  `全${totalColors}カラー・${rankedSeries.length}シリーズを徹底比較。`,
  `${fishName}向け${typeName}のおすすめと選び方を解説。`,
  topMakers ? `${topMakers}等${makerBreakdown.length}メーカーから厳選。` : '',
  priceText ? `価格帯${priceText}。` : '',
  'スペック・カラー展開・価格を一覧で比較して最適な1本が見つかる。',
].filter(Boolean).join('');

// 概要テキスト
const summaryParts: string[] = [];
summaryParts.push(`${fishName}向けの${typeName}は${makerBreakdown.length}メーカーから${rankedSeries.length}シリーズが登録されている`);
if (topMakers) {
  summaryParts.push(`${topMakers}がラインナップ上位`);
}
if (priceRange) {
  summaryParts.push(`価格帯は${priceText}`);
}
if (isCurated) {
  summaryParts.push('複数の釣り情報サイト・口コミ・販売実績をもとに、実績のあるルアーを上位に掲載している');
} else {
  summaryParts.push('カラー展開・価格帯・重量展開・モデル数・魚種対応の5指標を総合評価して掲載している');
}
const summaryText = summaryParts.join('。') + '。';

// スペック
const specItems: { label: string; value: string }[] = [];
specItems.push({ label: 'シリーズ数', value: `${rankedSeries.length}` });
specItems.push({ label: 'カラー数', value: `${totalColors}色` });
specItems.push({ label: 'メーカー数', value: `${makerBreakdown.length}` });
if (priceRange) {
  specItems.push({ label: '価格帯', value: priceText });
}
if (weightRange) {
  specItems.push({ label: '重さ', value: `${weightRange.min}g 〜 ${weightRange.max}g` });
}

// ─── 選び方セクション ───

// ガイド記事から該当タイプの選び方セクションを抽出
const matchingGuides = guideArticles.filter(g =>
  g.targetFish.includes(fishName) || g.targetTypes.includes(typeName)
);
const selectionTips: { heading: string; body: string; guideSlug: string }[] = [];
for (const guide of matchingGuides) {
  for (const section of guide.sections) {
    // セクション見出しにタイプ名 or 「選び方」を含むものを抽出
    if (section.heading.includes(typeName) || (section.heading.includes('選び方') && section.heading.includes(fishName))) {
      selectionTips.push({ heading: section.heading, body: section.body, guideSlug: guide.slug });
    }
  }
}
// 最大2セクションまで表示
const displayTips = selectionTips.slice(0, 2);

// データ駆動の選び方ポイント（ガイドがなくても表示）
const dataPoints: string[] = [];
if (weightRange) {
  const lightCount = rankedSeries.filter(s => s.weight_range.min != null && s.weight_range.min <= (weightRange.min + (weightRange.max - weightRange.min) / 3)).length;
  const heavyCount = rankedSeries.filter(s => s.weight_range.max != null && s.weight_range.max >= (weightRange.min + (weightRange.max - weightRange.min) * 2 / 3)).length;
  dataPoints.push(`重量は${weightRange.min}g〜${weightRange.max}gまで展開。軽量モデル（${lightCount}シリーズ）は操作性重視、重量モデル（${heavyCount}シリーズ）は飛距離重視で選ぶとよい`);
}
if (priceRange && priceRange.max - priceRange.min > 500) {
  const midPrice = Math.round((priceRange.min + priceRange.max) / 2);
  const budgetCount = rankedSeries.filter(s => s.price_range.max > 0 && s.price_range.max <= midPrice).length;
  dataPoints.push(`価格帯は${priceText}。${budgetCount}シリーズが¥${midPrice.toLocaleString()}以下で入手可能`);
}
if (rankedSeries[0] && rankedSeries[0].color_count >= 10) {
  dataPoints.push(`カラー展開が多いシリーズほどフィールドや条件に合わせた使い分けがしやすい。${rankedSeries[0].manufacturer}の${rankedSeries[0].name}は${rankedSeries[0].color_count}色展開で選択肢が豊富`);
}

// FAQ JSON-LD
const faqItems: { q: string; a: string }[] = [];

faqItems.push({
  q: `${fishName}向け${typeName}にはどんなルアーがある？`,
  a: `${fishName}向け${typeName}は${rankedSeries.length}シリーズが登録されている。${rankedSeries[0] ? `${rankedSeries[0].manufacturer}の${rankedSeries[0].name}などが総合評価上位。` : ''}`,
});

if (priceRange) {
  faqItems.push({
    q: `${fishName}向け${typeName}の価格帯は？`,
    a: `${fishName}向け${typeName}の価格帯は${priceText}。${rankedSeries.length}シリーズ・${totalColors}カラーから予算に合ったルアーを選べる。`,
  });
}

if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 5).map(m => `${m.name}（${m.count}シリーズ）`).join('、');
  faqItems.push({
    q: `${fishName}向け${typeName}を展開するメーカーは？`,
    a: `${fishName}向け${typeName}を展開するメーカーは${makerBreakdown.length}社。${makerNames}がシリーズ数上位。`,
  });
}

// 選び方FAQ
if (displayTips.length > 0) {
  const tipSummary = displayTips[0].body.length > 150 ? displayTips[0].body.slice(0, 150) + '…' : displayTips[0].body;
  faqItems.push({
    q: `${fishName}向け${typeName}の選び方は？`,
    a: tipSummary,
  });
} else if (dataPoints.length > 0) {
  faqItems.push({
    q: `${fishName}向け${typeName}の選び方は？`,
    a: dataPoints[0] + '。',
  });
}

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const fishSlug = getFishSlug(fishName);
const typeSlug = getTypeSlug(typeName);

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${fishName}向け${typeName}カタログ`,
  url: `https://www.castlog.xyz/ranking/${slug}/`,
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: rankedSeries.length,
    itemListElement: rankedSeries.slice(0, 50).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.castlog.xyz/${s.manufacturer_slug}/${s.slug}/`,
      name: `${s.manufacturer} ${s.name}`,
      ...(s.representative_image ? { image: s.representative_image } : {}),
      description: `${s.type}・全${s.color_count}色${s.price_range.max > 0 ? `・¥${s.price_range.min.toLocaleString()}〜` : ''}`,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.castlog.xyz/' },
    { '@type': 'ListItem', position: 2, name: 'カタログ', item: 'https://www.castlog.xyz/ranking/' },
    { '@type': 'ListItem', position: 3, name: `${fishName}×${typeName}`, item: `https://www.castlog.xyz/ranking/${slug}/` },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, faqLd] as unknown as Record<string, unknown>;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath={`/ranking/${slug}/`} jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href="/ranking/" class="hover:text-accent transition-colors">カタログ</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{fishName}×{typeName}</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-6">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-1">CATALOG</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
        {fishName}向け{typeName}{rankedSeries.length}選
      </h1>
      <p class="text-sm text-text-mid mt-1">
        {rankedSeries.length}シリーズ・{totalColors}カラー
      </p>
    </div>

    <!-- 概要セクション -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">

      <p class="text-sm text-gray-700 leading-relaxed mb-4">
        {summaryText}
      </p>

      {editorialText && (
        <p class="text-sm text-gray-600 leading-relaxed mb-5 border-l-2 border-accent pl-4">
          {editorialText}
        </p>
      )}

      <!-- スペックサマリー -->
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-5">
        {specItems.map(item => (
          <div>
            <p class="text-xs text-text-dim">{item.label}</p>
            <p class="text-sm font-semibold text-gray-900">{item.value}</p>
          </div>
        ))}
      </div>

      <!-- メーカー一覧 -->
      {makerBreakdown.length > 0 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">取り扱いメーカー</h2>
          <div class="flex flex-wrap gap-2">
            {makerBreakdown.map(m => (
              <a href={`/${m.slug}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent-bg transition-colors">
                {m.name}
                <span class="text-accent">{m.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- カテゴリリンク -->
      <div class="flex flex-wrap gap-2">
        <a href={`/compare/${slug}/`} class="px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent/10 transition-colors">
          上位モデルを比較 →
        </a>
        <a href={`/fish/${fishSlug}/`} class="px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
          {fishName}のルアー一覧
        </a>
        <a href={`/type/${typeSlug}/`} class="px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
          {typeName}のルアー一覧
        </a>
      </div>

    </div>

    <!-- 選び方セクション -->
    {(displayTips.length > 0 || dataPoints.length > 0) && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-gray-900 mb-4">{fishName}向け{typeName}の選び方</h2>

        {displayTips.map(tip => (
          <div class="bg-gray-50 rounded-lg p-4 sm:p-5 mb-3">
            <h3 class="text-sm font-semibold text-gray-900 mb-2">{tip.heading}</h3>
            <p class="text-sm text-gray-700 leading-relaxed">{tip.body}</p>
            <a href={`/guide/${tip.guideSlug}/`} class="inline-block mt-2 text-xs text-accent hover:underline">
              ガイド記事で詳しく読む →
            </a>
          </div>
        ))}

        {dataPoints.length > 0 && (
          <div class="bg-white rounded-lg border border-gray-100 p-4 sm:p-5">
            <h3 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-3">データから見る選び方のポイント</h3>
            <ul class="space-y-2">
              {dataPoints.map(point => (
                <li class="text-sm text-gray-700 leading-relaxed flex gap-2">
                  <span class="text-accent shrink-0 mt-0.5">▸</span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- 登録ルアー一覧 -->
    <h2 class="text-lg font-bold text-gray-900 mb-4">登録ルアー {rankedSeries.length}シリーズ</h2>

    <!-- 商品グリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {rankedSeries.map((s, i) => (
        <div class="relative">
          <LureCard series={s} isNew={false} priority={i < 4} rank={i + 1} />
        </div>
      ))}
    </div>

    <!-- 関連ガイド記事 -->
    {(() => {
      const guides = guideArticles.filter(g =>
        g.targetFish.includes(fishName) || g.targetTypes.includes(typeName)
      );
      return guides.length > 0 ? (
        <section class="mt-12 pt-8 border-t border-gray-100">
          <h2 class="text-lg font-bold text-gray-900 mb-4">関連ガイド記事</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {guides.map(guide => (
              <a href={`/guide/${guide.slug}/`} class="group flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
                <div>
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors">{guide.title.split('【')[0]}</p>
                  <p class="text-xs text-text-dim mt-0.5">{guide.targetFish.join('・')}</p>
                </div>
                <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            ))}
          </div>
        </section>
      ) : null;
    })()}

    <!-- 掲載順について -->
    <section class="mt-12 pt-8 border-t border-gray-100">
      <h2 class="text-lg font-bold text-gray-900 mb-3">掲載順について</h2>
      <div class="bg-gray-50 rounded-lg p-4 sm:p-5">
        {isCurated ? (
          <>
            <p class="text-sm text-gray-700 leading-relaxed mb-3">
              本カタログの上位掲載は、複数の釣り情報サイト・販売実績・ユーザー口コミを横断的に調査し、実績のあるルアーを優先的に掲載しています。
            </p>
            <ul class="space-y-1.5 text-sm text-gray-700">
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>調査対象</strong>: TSURI HACK、マイベスト、sakidori、タックルノート、Amazon売上ランキング、Yahoo!ショッピング等の複数ソース</span></li>
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>評価基準</strong>: 複数ソースで繰り返し名前が挙がるルアーほど「実績あり」と判断し上位に配置</span></li>
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>上位以降</strong>: 手動調査リスト以降のシリーズは、スペックデータ（カラー展開・価格帯・重量展開・モデル数・対応魚種）の複合スコアで順位を決定</span></li>
            </ul>
          </>
        ) : (
          <>
            <p class="text-sm text-gray-700 leading-relaxed mb-3">
              本カタログはCAST/LOGデータベースに登録されたスペックデータをもとに、以下の5指標を同カテゴリ内で正規化し、重み付けした複合スコアで算出しています。
            </p>
            <ul class="space-y-1.5 text-sm text-gray-700">
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>カラー展開数（35%）</strong>: カラーバリエーションが多いシリーズほど、メーカーが注力している売れ筋モデルと判断</span></li>
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>価格帯の幅（20%）</strong>: エントリーからハイエンドまで幅広い価格設定があるほどラインナップが充実</span></li>
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>重量展開の幅（20%）</strong>: 軽量から重量級まで幅広いウェイト展開があるほど多様なフィールドに対応</span></li>
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>モデル数（15%）</strong>: ユニークな重量バリエーション数。サイズ展開が豊富なほどシチュエーションに合わせやすい</span></li>
              <li class="flex gap-2"><span class="text-accent shrink-0">▸</span><span><strong>対応魚種数（10%）</strong>: 複数の魚種に対応するほど汎用性が高い</span></li>
            </ul>
          </>
        )}
        <p class="text-xs text-text-dim mt-3">
          ※ 広告・アフィリエイトによる順位操作は一切行っていません。
        </p>
      </div>
    </section>

    <!-- 関連ランキング -->
    {related.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連カテゴリ</h2>
        <p class="text-sm text-text-mid mb-4">
          {fishName}・{typeName}に関連するカテゴリ
        </p>
        <div class="flex flex-wrap gap-2">
          {related.map(r => (
            <a href={`/ranking/${r.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {r.fishName}×{r.typeName}
              <span class="text-xs text-gray-400">{r.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
