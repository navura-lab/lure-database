---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LureCard from '../../components/LureCard.astro';
import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../../lib/category-slugs';
import { guideArticles } from '../../data/guides';
import type { LureSeries } from '../../lib/types';

export async function getStaticPaths() {
  const lures = await fetchAllLures();
  const allSeries = groupLuresBySeries(lures ?? []);

  return guideArticles.map(guide => {
    // 対象魚 + タイプでフィルタリング
    const matchingSeries = allSeries
      .filter(s => {
        const fishMatch = guide.targetFish.length === 0 ||
          s.target_fish.some(f => guide.targetFish.includes(f));
        const typeMatch = guide.targetTypes.length === 0 ||
          guide.targetTypes.includes(s.type);
        return fishMatch && typeMatch;
      })
      .map(s => ({ ...s, score: s.color_count }))
      .sort((a, b) => b.color_count - a.color_count);

    // タイプ別にグルーピング（上位5件ずつ）
    const byType = new Map<string, (LureSeries & { score: number })[]>();
    for (const s of matchingSeries) {
      if (!s.type) continue;
      if (!guide.targetTypes.includes(s.type)) continue;
      const arr = byType.get(s.type) || [];
      if (arr.length < 5) arr.push(s);
      byType.set(s.type, arr);
    }

    // 全体の上位10件（記事冒頭用）
    const topPicks = matchingSeries.slice(0, 10);

    // メーカー集計
    const makerSet = new Set(matchingSeries.map(s => s.manufacturer));

    return {
      params: { slug: guide.slug },
      props: { guide, topPicks, byType: Object.fromEntries(byType), makerCount: makerSet.size, totalCount: matchingSeries.length },
    };
  });
}

const { guide, topPicks, byType, makerCount, totalCount } = Astro.props as {
  guide: typeof guideArticles[0];
  topPicks: (LureSeries & { score: number })[];
  byType: Record<string, (LureSeries & { score: number })[]>;
  makerCount: number;
  totalCount: number;
};

// JSON-LD: Article
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishedAt,
  dateModified: guide.updatedAt,
  author: {
    '@type': 'Organization',
    name: 'CAST/LOG',
    url: 'https://www.lure-db.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'CAST/LOG',
    url: 'https://www.lure-db.com',
    logo: { '@type': 'ImageObject', url: 'https://www.lure-db.com/favicon.svg' },
  },
  mainEntityOfPage: `https://www.lure-db.com/guide/${guide.slug}/`,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.lure-db.com/' },
    { '@type': 'ListItem', position: 2, name: 'ガイド', item: 'https://www.lure-db.com/guide/' },
    { '@type': 'ListItem', position: 3, name: guide.title, item: `https://www.lure-db.com/guide/${guide.slug}/` },
  ],
};

const jsonLd = [articleLd, breadcrumbLd] as unknown as Record<string, unknown>;

// 関連ランキングリンク
const rankingLinks = guide.targetFish.flatMap(fish =>
  guide.targetTypes.map(type => ({
    label: `${fish}×${type}`,
    href: `/ranking/${getFishSlug(fish)}-${getTypeSlug(type)}/`,
  }))
).slice(0, 8);
---

<BaseLayout title={guide.title + ' - CAST/LOG'} description={guide.description} canonicalPath={`/guide/${guide.slug}/`} jsonLd={jsonLd}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href="/guide/" class="hover:text-accent transition-colors">ガイド</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{guide.title.split('【')[0]}</span>
    </nav>

    <!-- 記事ヘッダー -->
    <header class="mb-8">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-2">/GUIDE</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
        {guide.title}
      </h1>
      <div class="flex items-center gap-4 text-xs text-text-dim font-mono">
        <time datetime={guide.updatedAt}>更新: {guide.updatedAt}</time>
        <span>{totalCount}シリーズ対象</span>
        <span>{makerCount}メーカー</span>
      </div>
    </header>

    <!-- リード文 -->
    {guide.lead && (
      <div class="bg-surface rounded-xl border border-border p-5 sm:p-6 mb-8">
        <p class="text-sm text-gray-700 leading-relaxed">
          {guide.lead}
        </p>
      </div>
    )}

    <!-- 目次 -->
    <nav class="bg-white rounded-xl border border-gray-100 p-5 mb-10">
      <h2 class="text-sm font-bold text-gray-900 mb-3">目次</h2>
      <ol class="space-y-1.5 text-sm text-text-mid">
        {guide.sections.map((s, i) => (
          <li>
            <a href={`#section-${i}`} class="hover:text-accent transition-colors">
              {i + 1}. {s.heading}
            </a>
          </li>
        ))}
        <li>
          <a href="#top-picks" class="hover:text-accent transition-colors">
            {guide.sections.length + 1}. 注目ルアー10選
          </a>
        </li>
      </ol>
    </nav>

    <!-- セクション -->
    {guide.sections.map((section, i) => {
      const typeKey = guide.targetTypes[i];
      const typeLures = typeKey ? (byType[typeKey] || []) : [];
      // セクションに対応するランキングページへのリンクを生成
      const sectionRankingLinks = typeKey ? guide.targetFish.map(fish => ({
        label: `${fish}×${typeKey}のおすすめ一覧`,
        href: `/ranking/${getFishSlug(fish)}-${getTypeSlug(typeKey)}/`,
      })) : [];

      return (
        <section id={`section-${i}`} class="mb-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4">{section.heading}</h2>
          <p class="text-sm text-gray-700 leading-relaxed mb-6">
            {section.body}
          </p>

          {/* セクションに対応するタイプのルアーがあれば表示 */}
          {typeLures.length > 0 && (
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-4">
              {typeLures.map(s => (
                <LureCard series={s} isNew={false} />
              ))}
            </div>
          )}

          {/* 該当ランキングへの導線 */}
          {sectionRankingLinks.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3">
              {sectionRankingLinks.map(link => (
                <a href={link.href} class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-accent bg-accent-bg rounded-full hover:bg-accent/10 transition-colors">
                  {link.label}
                  <span class="text-sm">→</span>
                </a>
              ))}
            </div>
          )}
        </section>
      );
    })}

    <!-- 注目ルアー10選 -->
    <section id="top-picks" class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">注目ルアー10選</h2>
      <p class="text-sm text-gray-600 mb-6">
        データベース登録ルアーからカラー展開数順に10シリーズを掲載。
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {topPicks.map((s, i) => (
          <div class="relative">
            <LureCard series={s} isNew={false} />
          </div>
        ))}
      </div>
    </section>

    <!-- 関連ランキング -->
    {rankingLinks.length > 0 && (
      <section class="mb-10 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連カテゴリ</h2>
        <div class="flex flex-wrap gap-2">
          {rankingLinks.map(link => (
            <a href={link.href} class="inline-flex items-center px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- SNSシェア -->
    <div class="flex items-center gap-3 pt-6 border-t border-gray-100">
      <span class="text-xs text-text-dim font-mono">SHARE:</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(guide.title)}&url=${encodeURIComponent(`https://www.lure-db.com/guide/${guide.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        X(Twitter)
      </a>
      <a
        href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://www.lure-db.com/guide/${guide.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        LINE
      </a>
    </div>

  </article>
</BaseLayout>
