---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LureCard from '../../components/LureCard.astro';
import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { computeRankingScores } from '../../lib/ranking-score';
import { getTypeSlug, getFishSlug } from '../../lib/category-slugs';
import { seasonalGuides } from '../../data/seasonal-guides';
import { contentArticles } from '../../data/articles/_index';
import type { LureSeries } from '../../lib/types';
import type { SeasonalGuide } from '../../data/seasonal-guides';

// ─── 静的パス生成 ───

export async function getStaticPaths() {
  const lures = await fetchAllLures();
  const allSeries = groupLuresBySeries(lures ?? []);

  return seasonalGuides.map(guide => {
    // 対象魚でフィルタ → recommendedTypes でグルーピング
    const matchingSeries = allSeries.filter(s => {
      if (!s.type) return false;
      const typeMatch = guide.recommendedTypes.includes(s.type);
      const fishMatch = s.target_fish.some(f => f === guide.fish);
      return typeMatch && fishMatch;
    });

    // スコアでソート
    const scoreMap = computeRankingScores(matchingSeries);
    const sorted = matchingSeries.sort((a, b) => {
      const sa = scoreMap.get(`${a.manufacturer_slug}/${a.slug}`)?.total ?? 0;
      const sb = scoreMap.get(`${b.manufacturer_slug}/${b.slug}`)?.total ?? 0;
      return sb - sa;
    });

    // タイプ別にグルーピング
    const byType = new Map<string, LureSeries[]>();
    for (const s of sorted) {
      const existing = byType.get(s.type) || [];
      existing.push(s);
      byType.set(s.type, existing);
    }

    const typeGroups = guide.recommendedTypes
      .filter(t => byType.has(t))
      .map(t => ({
        typeName: t,
        typeSlug: getTypeSlug(t),
        series: byType.get(t)!,
      }));

    return {
      params: { slug: guide.slug },
      props: { guide, typeGroups, totalCount: sorted.length },
    };
  });
}

// ─── Props ───

const { guide, typeGroups, totalCount } = Astro.props as {
  guide: SeasonalGuide;
  typeGroups: { typeName: string; typeSlug: string; series: LureSeries[] }[];
  totalCount: number;
};

const slug = Astro.params.slug as string;

// ─── 関連記事 ───

const relatedArticles = contentArticles.filter(a =>
  a.targetFish.includes(guide.fish) ||
  a.targetTypes.some(t => guide.recommendedTypes.includes(t))
).slice(0, 6);

// ─── 関連ランキングリンク ───

const relatedRankings: { slug: string; label: string }[] = [];
for (const type of guide.recommendedTypes) {
  const rSlug = `${getFishSlug(guide.fish)}-${getTypeSlug(type)}`;
  relatedRankings.push({ slug: rSlug, label: `${guide.fish}×${type}` });
}

// ─── 同じ魚種の他シーズン ───

const otherSeasons = seasonalGuides.filter(g =>
  g.fish === guide.fish && g.slug !== guide.slug
);

// ─── SEO ───

const currentYear = new Date().getFullYear();
const pageTitle = `${guide.name}【${currentYear}年】おすすめ${totalCount}選 | CAST/LOG`;
const pageDescription = guide.description;

// FAQ JSON-LD
const faqEntries = guide.faq.map(f => ({
  '@type': 'Question' as const,
  name: f.question,
  acceptedAnswer: { '@type': 'Answer' as const, text: f.answer },
}));

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries,
};

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: guide.name,
  url: `https://castlog.xyz/season/${slug}/`,
  description: pageDescription,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://castlog.xyz/' },
    { '@type': 'ListItem', position: 2, name: '季節で選ぶ', item: 'https://castlog.xyz/season/' },
    { '@type': 'ListItem', position: 3, name: guide.name, item: `https://castlog.xyz/season/${slug}/` },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, faqLd] as unknown as Record<string, unknown>;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath={`/season/${slug}/`} jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href="/season/" class="hover:text-accent transition-colors">季節で選ぶ</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{guide.name}</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-6">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-1">{guide.season}（{guide.months.join('・')}月）</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
        {guide.name} おすすめ{totalCount}選
      </h1>
      <p class="text-sm text-text-mid mt-1">
        {guide.fish}向け・{guide.recommendedTypes.join('・')}
      </p>
    </div>

    <!-- 概要セクション -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">
      <p class="text-sm text-gray-700 leading-relaxed mb-4">
        {guide.description}
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
        <div>
          <p class="text-xs text-text-dim">シーズン</p>
          <p class="text-sm font-semibold text-gray-900">{guide.months.map(m => `${m}月`).join('・')}</p>
        </div>
        <div>
          <p class="text-xs text-text-dim">対象魚</p>
          <p class="text-sm font-semibold text-gray-900">{guide.fish}</p>
        </div>
        <div>
          <p class="text-xs text-text-dim">おすすめルアー</p>
          <p class="text-sm font-semibold text-gray-900">{guide.recommendedTypes.slice(0, 3).join('・')}</p>
        </div>
        <div>
          <p class="text-xs text-text-dim">登録シリーズ</p>
          <p class="text-sm font-semibold text-gray-900">{totalCount}シリーズ</p>
        </div>
      </div>

      <!-- タグリンク -->
      <div class="flex flex-wrap gap-2">
        <a href={`/fish/${getFishSlug(guide.fish)}/`} class="px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
          {guide.fish}のルアー一覧
        </a>
        {guide.recommendedTypes.map(type => (
          <a href={`/type/${getTypeSlug(type)}/`} class="px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
            {type}のルアー一覧
          </a>
        ))}
      </div>
    </div>

    <!-- パターン解説 -->
    <section class="mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">{guide.season}のパターン</h2>
      <div class="bg-white rounded-lg border border-gray-100 p-4 sm:p-5">
        <ul class="space-y-3">
          {guide.patterns.map(pattern => (
            <li class="text-sm text-gray-700 leading-relaxed flex gap-2">
              <span class="text-accent shrink-0 mt-0.5">▸</span>
              <span>{pattern}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- おすすめルアー（タイプ別セクション） -->
    {typeGroups.map(group => (
      <section class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-lg font-bold text-gray-900">{group.typeName}</h2>
          <a href={`/type/${group.typeSlug}/`} class="text-xs text-text-mid hover:text-accent transition-colors">
            全一覧 →
          </a>
          <span class="text-xs text-text-dim">{group.series.length}シリーズ</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
          {group.series.slice(0, 8).map((s, i) => (
            <LureCard series={s} isNew={false} priority={i < 2} rank={i + 1} />
          ))}
        </div>
        {group.series.length > 8 && (
          <p class="mt-3 text-sm text-text-mid">
            他 {group.series.length - 8}シリーズ →
            <a href={`/type/${group.typeSlug}/`} class="text-accent hover:underline">一覧を見る</a>
          </p>
        )}
      </section>
    ))}

    <!-- コツ -->
    <section class="mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">{guide.season}の{guide.fish}釣りのコツ</h2>
      <div class="bg-white rounded-lg border border-gray-100 p-4 sm:p-5">
        <ul class="space-y-2">
          {guide.tips.map(tip => (
            <li class="text-sm text-gray-700 leading-relaxed flex gap-2">
              <span class="text-accent shrink-0 mt-0.5">▸</span>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FAQ アコーディオン -->
    <section class="mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">よくある質問</h2>
      <div class="space-y-3">
        {guide.faq.map(item => (
          <details class="bg-white rounded-lg border border-gray-100 overflow-hidden group">
            <summary class="px-4 py-3 text-sm font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition-colors flex items-center justify-between">
              <span>{item.question}</span>
              <span class="text-accent text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-700 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- 他のシーズン -->
    {otherSeasons.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-bold text-gray-900 mb-4">{guide.fish}の他のシーズン</h2>
        <div class="flex flex-wrap gap-2">
          {otherSeasons.map(other => (
            <a href={`/season/${other.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {other.name}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連ランキング -->
    {relatedRankings.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連カタログ</h2>
        <div class="flex flex-wrap gap-2">
          {relatedRankings.map(r => (
            <a href={`/ranking/${r.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {r.label}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連記事 -->
    {relatedArticles.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連記事</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedArticles.map(article => (
            <a href={`/article/${article.slug}/`} class="group flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
              <div>
                <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors">{article.h1}</p>
                <p class="text-xs text-text-dim mt-0.5">{article.targetFish.join('・')}</p>
              </div>
              <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
