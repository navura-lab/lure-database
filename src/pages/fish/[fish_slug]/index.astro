---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LureCard from '../../../components/LureCard.astro';
import { fetchAllLures } from '../../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../../lib/group-lures';
import { FISH_SLUG_MAP, FISH_NAME_MAP, getTypeSlug } from '../../../lib/category-slugs';
import { fishDescriptions } from '../../../data/fish-descriptions';
import type { LureSeries } from '../../../lib/types';

export async function getStaticPaths() {
  const lures = await fetchAllLures();
  const allSeries = groupLuresBySeries(lures ?? []);

  // 対象魚別にグルーピング
  const fishMap = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    for (const fish of s.target_fish) {
      const existing = fishMap.get(fish) || [];
      existing.push(s);
      fishMap.set(fish, existing);
    }
  }

  // 各対象魚のルアータイプ・メーカープロファイル（関連魚種算出用）
  const fishProfiles = new Map<string, { types: Set<string>; makers: Set<string>; count: number }>();
  for (const [name, seriesList] of fishMap) {
    const types = new Set<string>();
    const makers = new Set<string>();
    for (const s of seriesList) {
      if (s.type) types.add(s.type);
      makers.add(s.manufacturer_slug);
    }
    fishProfiles.set(name, { types, makers, count: seriesList.length });
  }

  return [...fishMap.entries()].map(([fishName, series]) => {
    const slug = FISH_SLUG_MAP[fishName] ?? encodeURIComponent(fishName);

    // 関連魚種: ルアータイプ・メーカーの重複度でスコアリング
    const profile = fishProfiles.get(fishName)!;
    const scored: { name: string; slug: string; count: number; score: number }[] = [];
    for (const [otherName, otherProfile] of fishProfiles) {
      if (otherName === fishName) continue;
      let score = 0;
      for (const t of profile.types) { if (otherProfile.types.has(t)) score += 2; }
      for (const m of profile.makers) { if (otherProfile.makers.has(m)) score += 1; }
      if (score > 0) {
        scored.push({
          name: otherName,
          slug: FISH_SLUG_MAP[otherName] ?? encodeURIComponent(otherName),
          count: otherProfile.count,
          score,
        });
      }
    }
    scored.sort((a, b) => b.score - a.score || b.count - a.count);
    const relatedFish = scored.slice(0, 8).map(({ name, slug, count }) => ({ name, slug, count }));

    return {
      params: { fish_slug: slug },
      props: { fishName, series, relatedFish },
    };
  });
}

const { fishName, series, relatedFish } = Astro.props as {
  fishName: string;
  series: LureSeries[];
  relatedFish: { name: string; slug: string; count: number }[];
};

const fishSlug = Astro.params.fish_slug as string;
const editorialText = fishDescriptions[fishSlug] ?? '';

// ─── 集計 ───

const totalColors = series.reduce((sum, s) => sum + s.color_count, 0);

// メーカー別
const makerCounts = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const existing = makerCounts.get(s.manufacturer_slug);
  if (existing) {
    existing.count++;
  } else {
    makerCounts.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
  }
}
const makerBreakdown = [...makerCounts.values()].sort((a, b) => b.count - a.count);

// タイプ別
const typeCounts = new Map<string, number>();
for (const s of series) {
  if (s.type) typeCounts.set(s.type, (typeCounts.get(s.type) || 0) + 1);
}
const typeBreakdown = [...typeCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([type, count]) => ({ type, count }));

// 価格帯
const prices = series
  .flatMap(s => [s.price_range.min, s.price_range.max])
  .filter(p => p > 0);
const priceRange = prices.length > 0
  ? { min: Math.min(...prices), max: Math.max(...prices) }
  : null;

// 重量帯
const weights = series
  .flatMap(s => [s.weight_range.min, s.weight_range.max])
  .filter((w): w is number => w != null && w > 0);
const weightRange = weights.length > 0
  ? { min: Math.min(...weights), max: Math.max(...weights) }
  : null;

// 全長帯
const lengths = series
  .flatMap(s => [s.length_range.min, s.length_range.max])
  .filter((l): l is number => l != null && l > 0);
const lengthRange = lengths.length > 0
  ? { min: Math.min(...lengths), max: Math.max(...lengths) }
  : null;

// ─── SEO ───

const topMakers = makerBreakdown.slice(0, 3).map(m => m.name).join('・');
const topTypes = typeBreakdown.slice(0, 3).map(t => t.type).join('、');
const priceText = priceRange ? `価格¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}` : '';

const pageDescription = [
  `${fishName}向けルアー${series.length}シリーズ・${totalColors}カラーを掲載。`,
  topTypes ? `${topTypes}等のタイプを収録。` : '',
  topMakers ? `${topMakers}等が展開。` : '',
  priceText ? `${priceText}。` : '',
].filter(Boolean).join('');

const summaryParts: string[] = [];
summaryParts.push(`${fishName}をターゲットとするルアーは${series.length}シリーズ・${totalColors}カラーが登録されている`);
if (typeBreakdown.length > 0) {
  const typeNames = typeBreakdown.slice(0, 5).map(t => t.type).join('、');
  summaryParts.push(`${typeNames}など${typeBreakdown.length > 5 ? `${typeBreakdown.length}種類` : ''}のルアータイプで狙える`);
}
if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 4).map(m => m.name).join('・');
  summaryParts.push(`${makerNames}など${makerBreakdown.length}メーカーからラインナップ`);
}
if (priceRange) {
  summaryParts.push(`価格帯は¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}`);
}
const summaryText = summaryParts.join('。') + '。';

// スペック
const specItems: { label: string; value: string }[] = [];
specItems.push({ label: 'シリーズ数', value: `${series.length}` });
specItems.push({ label: 'カラー数', value: `${totalColors}色` });
specItems.push({ label: 'メーカー数', value: `${makerBreakdown.length}` });
if (priceRange) {
  specItems.push({ label: '価格帯', value: `¥${priceRange.min.toLocaleString()} 〜 ¥${priceRange.max.toLocaleString()}` });
}
if (weightRange) {
  specItems.push({ label: '重さ', value: `${weightRange.min}g 〜 ${weightRange.max}g` });
}

// FAQ JSON-LD
const faqItems: { q: string; a: string }[] = [];

if (typeBreakdown.length > 0) {
  const typeNames = typeBreakdown.slice(0, 6).map(t => `${t.type}（${t.count}シリーズ）`).join('、');
  faqItems.push({
    q: `${fishName}向けルアーにはどんなタイプがある？`,
    a: `${fishName}向けルアーは${typeBreakdown.length}タイプが登録されており、${typeNames}などがある。`,
  });
}

if (priceRange) {
  faqItems.push({
    q: `${fishName}向けルアーの価格帯は？`,
    a: `${fishName}向けルアーの価格帯は¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}。${series.length}シリーズ・${totalColors}カラーから予算に合ったルアーを選べる。`,
  });
}

if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 5).map(m => m.name).join('、');
  faqItems.push({
    q: `${fishName}向けルアーの人気メーカーは？`,
    a: `${fishName}向けルアーを展開するメーカーは${makerBreakdown.length}社。${makerNames}などがシリーズ数上位に入る。`,
  });
}

const faqLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
} : null;

// JSON-LD
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${fishName}向けルアー一覧`,
  url: `https://www.lure-db.com/fish/${fishSlug}/`,
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: series.length,
    itemListElement: series.slice(0, 50).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.lure-db.com/${s.manufacturer_slug}/${s.slug}/`,
      name: `${s.manufacturer} ${s.name}`,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.lure-db.com/' },
    { '@type': 'ListItem', position: 2, name: '対象魚', item: 'https://www.lure-db.com/fish/' },
    { '@type': 'ListItem', position: 3, name: fishName, item: `https://www.lure-db.com/fish/${fishSlug}/` },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])] as unknown as Record<string, unknown>;
---

<BaseLayout title={`${fishName}向けルアー${series.length}シリーズ一覧${topTypes ? ` | ${topTypes}等` : ''} - CAST/LOG`} description={pageDescription} canonicalPath={`/fish/${fishSlug}/`} jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href="/fish/" class="hover:text-accent transition-colors">対象魚</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{fishName}</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{fishName}向けルアー</h1>
      <p class="text-sm text-text-mid mt-1">
        {series.length}シリーズ・{totalColors}カラー
      </p>
    </div>

    <!-- 概要セクション -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">

      <p class="text-sm text-gray-700 leading-relaxed mb-4">
        {summaryText}
      </p>

      {editorialText && (
        <p class="text-sm text-gray-600 leading-relaxed mb-5 border-l-2 border-emerald-200 pl-4">
          {editorialText}
        </p>
      )}

      <!-- スペックサマリー -->
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-5">
        {specItems.map(item => (
          <div>
            <p class="text-xs text-text-dim">{item.label}</p>
            <p class="text-sm font-semibold text-gray-900">{item.value}</p>
          </div>
        ))}
      </div>

      <!-- ルアータイプ -->
      {typeBreakdown.length > 0 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">ルアータイプ</h2>
          <div class="flex flex-wrap gap-2">
            {typeBreakdown.map(t => (
              <a href={`/type/${getTypeSlug(t.type)}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent-bg transition-colors">
                {t.type}
                <span class="text-accent">{t.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- メーカー一覧 -->
      {makerBreakdown.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">取り扱いメーカー</h2>
          <div class="flex flex-wrap gap-2">
            {makerBreakdown.map(m => (
              <a href={`/${m.slug}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs font-medium border border-gray-100 hover:bg-gray-100 transition-colors">
                {m.name}
                <span class="text-gray-400">{m.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- シリーズ見出し -->
    <h2 class="text-lg font-bold text-gray-900 mb-4">全{series.length}シリーズ</h2>

    <!-- 商品グリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {series.map((s, i) => (
        <LureCard series={s} isNew={false} priority={i < 4} />
      ))}
    </div>

    <!-- 関連対象魚 -->
    {relatedFish.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連する対象魚</h2>
        <p class="text-sm text-text-mid mb-4">
          {fishName}と同じルアータイプ・メーカーで狙える魚種
        </p>
        <div class="flex flex-wrap gap-2">
          {relatedFish.map(f => (
            <a href={`/fish/${f.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {f.name}
              <span class="text-xs text-gray-400">{f.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
