---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchHero from '../components/SearchHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CategoryTile from '../components/CategoryTile.astro';
import LureCard from '../components/LureCard.astro';
import { fetchAllLures } from '../lib/fetch-all-lures';
import { groupLuresBySeries } from '../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../lib/category-slugs';

const lures = await fetchAllLures();
const series = groupLuresBySeries(lures ?? []);
const totalColors = lures?.length ?? 0;

// ─── ルアータイプ集計（上位9件）───
const typeMap = new Map<string, number>();
for (const s of series) {
  if (s.type) typeMap.set(s.type, (typeMap.get(s.type) || 0) + 1);
}
const topTypes = [...typeMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 9)
  .map(([name, count]) => ({ name, slug: getTypeSlug(name), count }));
const remainingTypeCount = typeMap.size - topTypes.length;

// ─── メーカー集計（上位9件）───
const mfrMap = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const e = mfrMap.get(s.manufacturer_slug);
  if (e) e.count++;
  else mfrMap.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
}
const topMakers = [...mfrMap.values()]
  .sort((a, b) => b.count - a.count)
  .slice(0, 9);
const remainingMakerCount = mfrMap.size - topMakers.length;

// ─── 対象魚集計（上位9件）───
const fishMap = new Map<string, number>();
for (const s of series) {
  for (const f of s.target_fish) fishMap.set(f, (fishMap.get(f) || 0) + 1);
}
const topFish = [...fishMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 9)
  .map(([name, count]) => ({ name, slug: getFishSlug(name), count }));
const remainingFishCount = fishMap.size - topFish.length;

// ─── 新着ルアー（直近30日、最大10件）───
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const newThreshold = thirtyDaysAgo.toISOString();
const newArrivals = series
  .filter(s => s.created_at > newThreshold)
  .slice(0, 10);

// ─── JSON-LD: WebSite schema ───
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ルアーDB',
  url: 'https://www.lure-db.com',
  description: '釣り人のためのルアーデータベース。国内主要メーカーのルアーを網羅的に掲載。',
  inLanguage: 'ja',
};
---

<BaseLayout
  title="ルアーDB - ルアーデータベース"
  description={`国内主要メーカーのルアーを網羅的に掲載。${series.length}シリーズ・${totalColors.toLocaleString()}カラー登録。`}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <!-- 検索ヒーロー -->
  <SearchHero seriesCount={series.length} colorCount={totalColors} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-8 sm:space-y-10">

    <!-- ルアータイプから探す -->
    <section>
      <SectionHeading title="ルアータイプから探す" href="/type/" />
      <div class="grid grid-cols-5 lg:grid-cols-10 gap-1.5 sm:gap-3">
        {topTypes.map(t => (
          <CategoryTile label={t.name} href={`/type/${t.slug}/`} count={t.count} variant="type" />
        ))}
        <CategoryTile label="その他" href="/type/" count={remainingTypeCount} variant="more" />
      </div>
    </section>

    <!-- メーカーから探す -->
    <section>
      <SectionHeading title="メーカーから探す" href="/maker/" />
      <div class="grid grid-cols-5 lg:grid-cols-10 gap-1.5 sm:gap-3">
        {topMakers.map(m => (
          <CategoryTile label={m.name} href={`/${m.slug}/`} count={m.count} variant="maker" />
        ))}
        <CategoryTile label="その他" href="/maker/" count={remainingMakerCount} variant="more" />
      </div>
    </section>

    <!-- 対象魚から探す -->
    <section>
      <SectionHeading title="対象魚から探す" href="/fish/" />
      <div class="grid grid-cols-5 lg:grid-cols-10 gap-1.5 sm:gap-3">
        {topFish.map(f => (
          <CategoryTile label={f.name} href={`/fish/${f.slug}/`} count={f.count} variant="fish" />
        ))}
        <CategoryTile label="その他" href="/fish/" count={remainingFishCount} variant="more" />
      </div>
    </section>

    <!-- 新着ルアー -->
    {newArrivals.length > 0 && (
      <section>
        <SectionHeading title="新着ルアー" href="/search/" />
        <div class="flex gap-4 overflow-x-auto pb-4 -mx-4 px-4 snap-x snap-mandatory scrollbar-hide">
          {newArrivals.map((s, i) => (
            <div class="snap-start shrink-0 w-56 sm:w-64">
              <LureCard series={s} isNew={true} priority={i < 4} />
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
