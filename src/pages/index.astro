---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchHero from '../components/SearchHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PortalSearch from '../components/PortalSearch.astro';
import LureCard from '../components/LureCard.astro';
import { fetchAllLures } from '../lib/fetch-all-lures';
import { groupLuresBySeries } from '../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../lib/category-slugs';
import makerLogos from '../data/maker-logos.json';
import { guideArticles } from '../data/guides';

const lures = await fetchAllLures();
const series = groupLuresBySeries(lures ?? []);
const totalColors = lures?.length ?? 0;

// ─── ルアータイプ集計（上位9件）───
const typeMap = new Map<string, { count: number; image: string | null }>();
for (const s of series) {
  if (!s.type) continue;
  const existing = typeMap.get(s.type);
  if (existing) {
    existing.count++;
    if (!existing.image && s.representative_image) existing.image = s.representative_image;
  } else {
    typeMap.set(s.type, { count: 1, image: s.representative_image });
  }
}
const topTypes = [...typeMap.entries()]
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 9)
  .map(([name, { count, image }]) => ({ name, slug: getTypeSlug(name), count, image }));
const remainingTypeCount = typeMap.size - topTypes.length;

// ─── メーカー集計（上位9件）───
const mfrMap = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const e = mfrMap.get(s.manufacturer_slug);
  if (e) e.count++;
  else mfrMap.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
}
const topMakers = [...mfrMap.values()]
  .sort((a, b) => b.count - a.count)
  .slice(0, 9);
const remainingMakerCount = mfrMap.size - topMakers.length;

// ─── 対象魚集計（上位9件）───
const fishMap = new Map<string, number>();
for (const s of series) {
  for (const f of s.target_fish) fishMap.set(f, (fishMap.get(f) || 0) + 1);
}
const topFish = [...fishMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 9)
  .map(([name, count]) => ({ name, slug: getFishSlug(name), count }));
const remainingFishCount = fishMap.size - topFish.length;

// ─── ランキング集計（上位8件）───
const crossMap = new Map<string, { fishName: string; typeName: string; count: number }>();
for (const s of series) {
  if (!s.type) continue;
  for (const fish of s.target_fish) {
    const fishSlug = getFishSlug(fish);
    const typeSlug = getTypeSlug(s.type);
    const key = `${fishSlug}-${typeSlug}`;
    const existing = crossMap.get(key);
    if (existing) {
      existing.count++;
    } else {
      crossMap.set(key, { fishName: fish, typeName: s.type, count: 1 });
    }
  }
}
const topRankings = [...crossMap.entries()]
  .filter(([_, v]) => v.count >= 3)
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 8)
  .map(([slug, v]) => ({ slug, fishName: v.fishName, typeName: v.typeName, count: v.count }));

// ─── 新着ルアー（直近30日、最大10件）───
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const newThreshold = thirtyDaysAgo.toISOString();
const newArrivals = series
  .filter(s => s.created_at > newThreshold)
  .slice(0, 10);

// ─── API token（ランダムセクション用）───
const apiToken = import.meta.env.LDB_API_TOKEN || '';

// ─── JSON-LD: WebSite schema ───
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CAST/LOG',
  url: 'https://www.lure-db.com',
  description: '釣り人のためのルアーデータベース。国内主要メーカーのルアーを網羅的に掲載。',
  inLanguage: 'ja',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://www.lure-db.com/search/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title={`CAST/LOG - ${series.length}シリーズ・${totalColors.toLocaleString()}カラーのルアーデータベース`}
  description={`国内${mfrMap.size}メーカーのルアーを網羅的に掲載。${series.length}シリーズ・${totalColors.toLocaleString()}カラー登録。ミノー、クランク、ワームなどタイプ別、メーカー別、対象魚別に検索可能。`}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <!-- ブランドヒーロー -->
  <SearchHero seriesCount={series.length} colorCount={totalColors} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12">

    <!-- ポータル検索 -->
    <section>
      <PortalSearch
        types={topTypes}
        makers={topMakers}
        fish={topFish}
        remainingTypeCount={remainingTypeCount}
        remainingMakerCount={remainingMakerCount}
        remainingFishCount={remainingFishCount}
        makerLogos={makerLogos as Record<string, string>}
      />
    </section>

    <!-- 新着ルアー -->
    {newArrivals.length > 0 && (
      <section>
        <SectionHeading title="新着ルアー" href="/search/" slashLabel="NEW ARRIVALS" />
        <div class="flex gap-4 overflow-x-auto pb-4 -mx-4 px-4 snap-x snap-mandatory scrollbar-hide">
          {newArrivals.map((s, i) => (
            <div class="snap-start shrink-0 w-56 sm:w-64">
              <LureCard series={s} isNew={true} priority={i < 4} />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ランキング -->
    {topRankings.length > 0 && (
      <section>
        <SectionHeading title="おすすめランキング" href="/ranking/" slashLabel="RANKING" />
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {topRankings.map(r => (
            <a
              href={`/ranking/${r.slug}/`}
              class="flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-border-light hover:border-accent hover:shadow-sm transition-all duration-[0.15s] group"
            >
              <div>
                <p class="text-[13px] font-bold text-text group-hover:text-accent transition-colors duration-[0.15s]">
                  {r.fishName}×{r.typeName}
                </p>
                <p class="font-mono text-[11px] text-text-dim mt-0.5">
                  {r.count}シリーズ
                </p>
              </div>
              <span class="font-mono text-[11px] font-bold text-accent">{r.count}</span>
            </a>
          ))}
        </div>
        <div class="mt-3 text-right">
          <a href="/ranking/" class="font-mono text-[11px] text-text-dim hover:text-accent tracking-[1px] transition-colors duration-[0.15s]">
            全{crossMap.size}カテゴリを見る →
          </a>
        </div>
      </section>
    )}

    <!-- ガイド記事 -->
    {guideArticles.length > 0 && (
      <section>
        <SectionHeading title="ガイド記事" href="/guide/" slashLabel="GUIDE" />
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {guideArticles.map(guide => (
            <a href={`/guide/${guide.slug}/`} class="group block bg-white rounded-lg border border-border-light p-4 hover:border-accent hover:shadow-sm transition-all duration-[0.15s]">
              <h3 class="text-[14px] font-bold text-text group-hover:text-accent transition-colors duration-[0.15s] mb-2 line-clamp-2">
                {guide.title}
              </h3>
              <p class="text-[12px] text-text-mid leading-relaxed line-clamp-2 mb-2">
                {guide.description}
              </p>
              <div class="flex items-center gap-2 font-mono text-[10px] text-text-dim">
                <time datetime={guide.updatedAt}>{guide.updatedAt}</time>
                <span>{guide.targetFish.join('・')}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ルアーを発見する -->
    <section>
      <div class="flex items-end justify-between mb-4">
        <div>
          <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">/DISCOVER</p>
          <h2 class="text-[18px] font-bold text-text">ランダムで探す</h2>
        </div>
        <button
          id="shuffle-btn"
          class="inline-flex items-center gap-2 font-mono text-[11px] font-bold text-text-dim tracking-[1px] px-4 py-2 border border-border rounded transition-all duration-[0.15s] hover:border-accent hover:text-text"
        >
          <svg class="w-4 h-4" id="shuffle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          シャッフル
        </button>
      </div>
      <div id="random-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        <!-- Client-side rendered -->
      </div>
      <div id="random-spinner" class="py-8 text-center">
        <div class="inline-block h-5 w-5 animate-spin rounded-full border-2 border-accent border-t-transparent"></div>
      </div>
    </section>

  </div>

  <script define:vars={{ apiToken }}>
    window.__LDB_T = apiToken;
  </script>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const TOKEN = (window as any).__LDB_T || '';
  const grid = document.getElementById('random-grid')!;
  const spinner = document.getElementById('random-spinner')!;
  const shuffleBtn = document.getElementById('shuffle-btn')!;
  const shuffleIcon = document.getElementById('shuffle-icon')!;

  interface CardData {
    slug: string;
    name: string;
    manufacturer: string;
    manufacturer_slug: string;
    type: string;
    representative_image: string | null;
    color_count: number;
    price_min: number;
    price_max: number;
    is_new: boolean;
    has_limited: boolean;
  }

  function esc(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function cardHtml(d: CardData): string {
    const hasPrice = d.price_max > 0;
    const price = hasPrice
      ? d.price_min === d.price_max
        ? `¥${d.price_min.toLocaleString()}`
        : `¥${d.price_min.toLocaleString()} - ¥${d.price_max.toLocaleString()}`
      : '';

    const img = d.representative_image
      ? `<img src="${esc(d.representative_image)}" alt="${esc(d.manufacturer)} ${esc(d.name)} ${esc(d.type)}" loading="lazy" width="500" height="375" class="w-full h-full object-scale-down p-3">`
      : `<div class="placeholder-lure-bg w-full h-full flex items-center justify-center"><span class="font-mono text-[9px] text-text-dim">${esc(d.type)}</span></div>`;

    const badges = [
      d.is_new ? `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border bg-amber-50 text-amber-700 border-amber-200">新着</span>` : '',
      d.has_limited ? `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border bg-purple-50 text-purple-700 border-purple-200">限定</span>` : '',
    ].filter(Boolean).join('');

    return `<a href="/${esc(d.manufacturer_slug)}/${esc(d.slug)}/" class="group block">
      <div class="bg-white rounded-lg border border-border-light overflow-hidden shadow-card transition-all duration-[0.15s] group-hover:shadow-card-hover group-hover:scale-[1.01] group-hover:border-accent">
        <div class="aspect-[4/3] relative overflow-hidden bg-white">
          ${img}
          <div class="absolute top-2 right-2 flex flex-col gap-1">${badges}</div>
        </div>
        <div class="p-4">
          <p class="font-mono text-[10px] text-text-dim tracking-wider uppercase mb-1">${esc(d.manufacturer)}</p>
          <h3 class="text-[14px] font-bold text-text mb-1.5 group-hover:text-accent transition-colors duration-[0.15s]">${esc(d.name)}</h3>
          <div class="flex items-center gap-1.5 text-[11px] text-text-dim mb-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-[11px] font-medium border bg-accent-bg text-accent border-accent">${esc(d.type)}</span>
            <span class="font-mono">${d.color_count}カラー</span>
          </div>
          ${price ? `<p class="font-mono text-[13px] font-bold text-text">${price}</p>` : ''}
        </div>
      </div>
    </a>`;
  }

  async function loadRandom() {
    spinner.classList.remove('hidden');
    shuffleIcon.classList.add('animate-spin');

    try {
      const res = await fetch('/api/catalog?sort=random&limit=8&page=0', {
        headers: { 'X-LDB-Token': TOKEN, 'Accept': 'application/json' },
      });
      if (!res.ok) throw new Error('API error');
      const data = await res.json();

      grid.innerHTML = '';
      const fragment = document.createDocumentFragment();
      const div = document.createElement('div');
      for (const item of data.items as CardData[]) {
        div.innerHTML = cardHtml(item);
        const el = div.firstElementChild;
        if (el) fragment.appendChild(el);
      }
      grid.appendChild(fragment);
    } catch {
      grid.innerHTML = '<p class="font-mono text-[13px] text-text-dim col-span-full text-center py-4">読み込みに失敗しました</p>';
    } finally {
      spinner.classList.add('hidden');
      shuffleIcon.classList.remove('animate-spin');
    }
  }

  shuffleBtn.addEventListener('click', loadRandom);

  // 初回ロード
  loadRandom();
</script>
