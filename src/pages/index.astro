---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchHero from '../components/SearchHero.astro';
import LureCard from '../components/LureCard.astro';
import { fetchAllLures } from '../lib/fetch-all-lures';
import { groupLuresBySeries } from '../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../lib/category-slugs';
import makerLogos from '../data/maker-logos.json';
import { editorialReviews } from '../data/seo/editorials/_index';
import type { LureSeries } from '../lib/types';

const lures = await fetchAllLures();
const series = groupLuresBySeries(lures ?? []);
const totalColors = lures?.length ?? 0;

// ─── メーカー集計 ───
const mfrMap = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const e = mfrMap.get(s.manufacturer_slug);
  if (e) e.count++;
  else mfrMap.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
}
const topMakers = [...mfrMap.values()].sort((a, b) => b.count - a.count).slice(0, 8);

// ─── 対象魚集計（上位8件）───
const fishMap = new Map<string, number>();
for (const s of series) {
  for (const f of s.target_fish) fishMap.set(f, (fishMap.get(f) || 0) + 1);
}
const topFish = [...fishMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([name, count]) => ({ name, slug: getFishSlug(name), count }));

// ─── タイプ集計（上位8件）───
const typeMap = new Map<string, { count: number }>();
for (const s of series) {
  if (!s.type) continue;
  const e = typeMap.get(s.type);
  if (e) e.count++;
  else typeMap.set(s.type, { count: 1 });
}
const topTypes = [...typeMap.entries()]
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 8)
  .map(([name, { count }]) => ({ name, slug: getTypeSlug(name), count }));

// ─── ランキング上位（フィードプロンプト用）───
const crossMap = new Map<string, { fishName: string; typeName: string; count: number }>();
for (const s of series) {
  if (!s.type) continue;
  for (const fish of s.target_fish) {
    const key = `${getFishSlug(fish)}-${getTypeSlug(s.type)}`;
    const e = crossMap.get(key);
    if (e) e.count++;
    else crossMap.set(key, { fishName: fish, typeName: s.type, count: 1 });
  }
}

// ─── ピックアップ（ビルド時シャッフル）───
const withImage = series.filter(s => s.representative_image);
for (let i = withImage.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [withImage[i], withImage[j]] = [withImage[j], withImage[i]];
}

// フィーチャー: エディトリアルありのルアーからランダム1件
const editorialSlugs = Object.keys(editorialReviews);
const featureCandidates = withImage.filter(s => editorialSlugs.includes(s.slug));
const feature = featureCandidates[0] || withImage[0];
const featureEditorial = editorialReviews[feature?.slug];

// サブピック: 4件
const subPicks = withImage.filter(s => s.slug !== feature?.slug).slice(0, 4);

// ─── エディトリアルフィード（6件）───
const editorialFeed = editorialSlugs
  .map(slug => {
    const s = series.find(s => s.slug === slug);
    const ed = editorialReviews[slug];
    return s && s.representative_image && ed ? { series: s, catchcopy: ed.catchcopy } : null;
  })
  .filter((r): r is NonNullable<typeof r> => r !== null);
// シャッフル
for (let i = editorialFeed.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [editorialFeed[i], editorialFeed[j]] = [editorialFeed[j], editorialFeed[i]];
}
const feedReviews = editorialFeed.slice(0, 6);

// ─── 新着ルアー ───
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const newThreshold = thirtyDaysAgo.toISOString();
const newArrivals = series.filter(s => s.created_at > newThreshold && s.representative_image).slice(0, 12);

// ─── ランダム発見（8件）───
const randomPicks = withImage.filter(s => s.slug !== feature?.slug && !subPicks.find(p => p.slug === s.slug)).slice(0, 8);

// ─── JSON-LD ───
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CAST/LOG',
  url: 'https://www.castlog.xyz',
  description: `日本最大級のルアーデータベース。${series.length}シリーズ・${totalColors.toLocaleString()}カラーを網羅。`,
  inLanguage: 'ja',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://www.castlog.xyz/search/?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title={`CAST/LOG — 日本最大級のルアーデータベース｜${series.length}シリーズ・${totalColors.toLocaleString()}カラー`}
  description={`日本最大級のルアーデータベース CAST/LOG。${mfrMap.size}メーカー・${series.length}シリーズ・${totalColors.toLocaleString()}カラーを網羅。データで選ぶ。感覚で釣る。`}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <!-- ═══ 1. ヒーロー ═══ -->
  <SearchHero seriesCount={series.length} colorCount={totalColors} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ═══ 2. ピックアップ（発見 + 好奇心）═══ -->
    <section class="py-12 animate-fade-up">
      <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">PICK UP</p>
      <h2 class="text-[18px] font-bold text-text mb-6">今日のピックアップ</h2>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 lg:auto-rows-[1fr]">
        {/* フィーチャー（大きい） */}
        {feature && (
          <a href={`/${feature.manufacturer_slug}/${feature.slug}/`} class="lg:col-span-3 lg:row-span-2 group block h-full">
            <div class="relative h-full min-h-[300px] rounded-2xl overflow-hidden bg-surface">
              <img
                src={feature.representative_image!}
                alt={`${feature.manufacturer} ${feature.name}`}
                class="w-full h-full object-contain p-6 transition-transform duration-500 group-hover:scale-105"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-5">
                {featureEditorial && (
                  <p class="text-white/90 text-[14px] leading-relaxed mb-2 line-clamp-2">{featureEditorial.catchcopy}</p>
                )}
                <p class="text-white/60 text-xs uppercase tracking-wider">{feature.manufacturer}</p>
                <p class="text-white text-lg font-bold">{feature.name}</p>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-accent text-xs font-mono">{feature.type}</span>
                  <span class="text-white/40">|</span>
                  <span class="text-white/60 text-xs font-mono">{feature.color_count}カラー</span>
                  {featureEditorial && <span class="text-xs bg-accent/20 text-accent px-2 py-0.5 rounded-full">📝 レビューあり</span>}
                </div>
              </div>
            </div>
          </a>
        )}

        {/* サブピック（小さい 2x2） */}
        <div class="lg:col-span-2 lg:row-span-2 grid grid-cols-2 gap-4">
          {subPicks.map(s => (
            <a href={`/${s.manufacturer_slug}/${s.slug}/`} class="group block h-full">
              <div class="relative h-full min-h-[140px] rounded-xl overflow-hidden bg-surface">
                <img
                  src={s.representative_image!}
                  alt={`${s.manufacturer} ${s.name}`}
                  class="w-full h-full object-contain p-3 transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-3">
                  <p class="text-white/60 text-[10px] uppercase tracking-wider">{s.manufacturer}</p>
                  <p class="text-white text-[13px] font-bold line-clamp-1">{s.name}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ フィードプロンプト: 対象魚 ═══ -->
    <div class="py-4">
      <p class="font-mono text-[10px] text-text-dim tracking-[2px] uppercase mb-3">🐟 どんな釣りをする？</p>
      <div class="flex flex-wrap gap-2">
        {topFish.map(f => (
          <a
            href={`/fish/${f.slug}/`}
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-surface rounded-full text-[13px] font-bold text-text hover:bg-accent-bg hover:text-accent transition-all duration-200"
          >
            {f.name}
            <span class="font-mono text-[10px] text-text-faint">{f.count.toLocaleString()}</span>
          </a>
        ))}
        <a href="/fish/" class="inline-flex items-center px-4 py-2 bg-surface rounded-full text-[13px] text-text-dim hover:text-accent transition-colors">
          もっと見る →
        </a>
      </div>
    </div>

    <!-- ═══ 3. エディトリアルフィード（マガジン風）═══ -->
    <section class="py-12 animate-fade-up">
      <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">EDITORIAL REVIEW</p>
      <div class="flex items-end justify-between mb-6">
        <h2 class="text-[18px] font-bold text-text">CAST/LOGレビュー</h2>
        <a href="/article/" class="font-mono text-[11px] text-text-dim hover:text-accent tracking-[1px] transition-colors">
          全{editorialSlugs.length}件 →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {feedReviews.map(r => (
          <a href={`/${r.series.manufacturer_slug}/${r.series.slug}/`} class="group block">
            <div class="relative aspect-[4/3] rounded-xl overflow-hidden bg-surface mb-3">
              <img
                src={r.series.representative_image!}
                alt={`${r.series.manufacturer} ${r.series.name}`}
                class="w-full h-full object-contain p-4 transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute top-3 left-3">
                <span class="text-[10px] bg-accent text-white px-2 py-1 rounded-full font-bold">📝 REVIEW</span>
              </div>
            </div>
            <p class="text-[14px] text-text-mid leading-relaxed line-clamp-2 mb-1.5">
              「{r.catchcopy}」
            </p>
            <p class="text-xs text-text-dim uppercase tracking-wider">{r.series.manufacturer}</p>
            <p class="text-[15px] font-bold text-text group-hover:text-accent transition-colors">{r.series.name}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══ フィードプロンプト: タイプ ═══ -->
    <div class="py-4">
      <p class="font-mono text-[10px] text-text-dim tracking-[2px] uppercase mb-3">🎣 ルアーのタイプで探す</p>
      <div class="flex flex-wrap gap-2">
        {topTypes.map(t => (
          <a
            href={`/type/${t.slug}/`}
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-surface rounded-full text-[13px] font-bold text-text hover:bg-accent-bg hover:text-accent transition-all duration-200"
          >
            <img src={`/icons/type/${t.slug}.svg`} alt="" class="w-4 h-4 opacity-60" />
            {t.name}
            <span class="font-mono text-[10px] text-text-faint">{t.count.toLocaleString()}</span>
          </a>
        ))}
        <a href="/type/" class="inline-flex items-center px-4 py-2 bg-surface rounded-full text-[13px] text-text-dim hover:text-accent transition-colors">
          もっと見る →
        </a>
      </div>
    </div>

    <!-- ═══ 4. 新着ルアー（横スクロール）═══ -->
    {newArrivals.length > 0 && (
      <section class="py-12 animate-fade-up">
        <div class="flex items-end justify-between mb-6">
          <div>
            <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">NEW ARRIVALS</p>
            <h2 class="text-[18px] font-bold text-text">新着ルアー</h2>
          </div>
          <a href="/new/" class="font-mono text-[11px] text-text-dim hover:text-accent tracking-[1px] transition-colors">
            すべて見る →
          </a>
        </div>
        <div class="relative">
          <div class="absolute right-0 top-0 bottom-4 w-12 bg-gradient-to-l from-bg to-transparent z-10 pointer-events-none"></div>
          <div class="flex gap-4 overflow-x-auto pb-4 -mx-4 px-4 snap-x snap-mandatory scrollbar-hide">
            {newArrivals.map((s, i) => (
              <div class="snap-start shrink-0 w-48 sm:w-56">
                <LureCard series={s} isNew={true} priority={i < 4} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ フィードプロンプト: メーカー ═══ -->
    <div class="py-4">
      <p class="font-mono text-[10px] text-text-dim tracking-[2px] uppercase mb-3">🏭 メーカーで探す</p>
      <div class="flex flex-wrap gap-2">
        {topMakers.map(m => (
          <a
            href={`/${m.slug}/`}
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-surface rounded-full text-[13px] font-bold text-text hover:bg-accent-bg hover:text-accent transition-all duration-200"
          >
            {m.name}
            <span class="font-mono text-[10px] text-text-faint">{m.count.toLocaleString()}</span>
          </a>
        ))}
        <a href="/maker/" class="inline-flex items-center px-4 py-2 bg-surface rounded-full text-[13px] text-text-dim hover:text-accent transition-colors">
          全{mfrMap.size}社 →
        </a>
      </div>
    </div>

    <!-- ═══ 5. ランダム発見 ═══ -->
    <section class="py-12 animate-fade-up">
      <div class="bg-[#0a0a0a] rounded-2xl p-6 sm:p-8 -mx-4 sm:mx-0">
        <div class="flex items-end justify-between mb-6">
          <div>
            <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">DISCOVER</p>
            <h2 class="text-[18px] font-bold text-white">ランダムで発見する</h2>
          </div>
          <a href="/search/" class="font-mono text-[11px] text-gray-400 hover:text-accent tracking-[1px] transition-colors">
            もっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {randomPicks.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ 6. データインサイト ═══ -->
    <section class="py-12 animate-fade-up">
      <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">DATA INSIGHT</p>
      <h2 class="text-[18px] font-bold text-text mb-6">{series.length.toLocaleString()}シリーズの分析から</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/type/" class="group bg-surface rounded-xl p-6 hover:bg-accent-bg transition-colors duration-200">
          <p class="font-mono text-[32px] font-bold text-accent mb-1">19.2%</p>
          <p class="text-[13px] font-bold text-text group-hover:text-accent transition-colors">ワームが最多タイプ</p>
          <p class="text-[11px] text-text-dim mt-1">タイプ別シェア分析 →</p>
        </a>
        <a href="/ranking/" class="group bg-surface rounded-xl p-6 hover:bg-accent-bg transition-colors duration-200">
          <p class="font-mono text-[32px] font-bold text-accent mb-1">¥1,741</p>
          <p class="text-[13px] font-bold text-text group-hover:text-accent transition-colors">ルアー平均価格</p>
          <p class="text-[11px] text-text-dim mt-1">価格帯分析 →</p>
        </a>
        <a href="/maker/" class="group bg-surface rounded-xl p-6 hover:bg-accent-bg transition-colors duration-200">
          <p class="font-mono text-[32px] font-bold text-accent mb-1">{mfrMap.size}</p>
          <p class="text-[13px] font-bold text-text group-hover:text-accent transition-colors">登録メーカー数</p>
          <p class="text-[11px] text-text-dim mt-1">メーカー比較 →</p>
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
