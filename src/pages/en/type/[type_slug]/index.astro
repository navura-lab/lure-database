---
/**
 * 英語版ルアータイプ詳細ページ — /en/type/[type_slug]/
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import LureCard from '../../../../components/LureCard.astro';
import { fetchAllLures } from '../../../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../../../lib/group-lures';
import { TYPE_SLUG_MAP, TYPE_NAME_MAP, getFishSlug } from '../../../../lib/category-slugs';
import { LURE_TYPE_EN, FISH_NAME_EN } from '../../../../i18n/dictionaries/fishing-terms';
import type { LureSeries } from '../../../../lib/types';

const locale = 'en' as const;

export async function getStaticPaths() {
  const lures = await fetchAllLures();
  const allSeries = groupLuresBySeries(lures ?? []);

  const typeMap = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    if (!s.type) continue;
    const existing = typeMap.get(s.type) || [];
    existing.push(s);
    typeMap.set(s.type, existing);
  }

  const typeProfiles = new Map<string, { fish: Set<string>; count: number }>();
  for (const [name, seriesList] of typeMap) {
    const fish = new Set<string>();
    for (const s of seriesList) {
      for (const f of s.target_fish) fish.add(f);
    }
    typeProfiles.set(name, { fish, count: seriesList.length });
  }

  return [...typeMap.entries()].map(([typeName, series]) => {
    const slug = TYPE_SLUG_MAP[typeName] ?? encodeURIComponent(typeName);

    const profile = typeProfiles.get(typeName)!;
    const scored: { name: string; slug: string; count: number; score: number }[] = [];
    for (const [otherName, otherProfile] of typeProfiles) {
      if (otherName === typeName) continue;
      let score = 0;
      for (const f of profile.fish) { if (otherProfile.fish.has(f)) score++; }
      if (score > 0) {
        scored.push({
          name: otherName,
          slug: TYPE_SLUG_MAP[otherName] ?? encodeURIComponent(otherName),
          count: otherProfile.count,
          score,
        });
      }
    }
    scored.sort((a, b) => b.score - a.score || b.count - a.count);
    const relatedTypes = scored.slice(0, 8).map(({ name, slug, count }) => ({ name, slug, count }));

    return {
      params: { type_slug: slug },
      props: { typeName, series, relatedTypes },
    };
  });
}

const { typeName, series, relatedTypes } = Astro.props as {
  typeName: string;
  series: LureSeries[];
  relatedTypes: { name: string; slug: string; count: number }[];
};

const typeSlug = Astro.params.type_slug as string;
const typeNameEn = LURE_TYPE_EN[typeName] ?? typeName;

// ─── 集計 ───

const totalColors = series.reduce((sum, s) => sum + s.color_count, 0);

const makerCounts = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const existing = makerCounts.get(s.manufacturer_slug);
  if (existing) existing.count++;
  else makerCounts.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
}
const makerBreakdown = [...makerCounts.values()].sort((a, b) => b.count - a.count);

const fishCounts = new Map<string, number>();
for (const s of series) {
  for (const fish of s.target_fish) fishCounts.set(fish, (fishCounts.get(fish) || 0) + 1);
}
const allTargetFish = [...fishCounts.entries()].sort((a, b) => b[1] - a[1]).map(([fish]) => fish).slice(0, 15);

const prices = series.flatMap(s => [s.price_range.min, s.price_range.max]).filter(p => p > 0);
const priceRange = prices.length > 0 ? { min: Math.min(...prices), max: Math.max(...prices) } : null;

const weights = series.flatMap(s => [s.weight_range.min, s.weight_range.max]).filter((w): w is number => w != null && w > 0);
const weightRange = weights.length > 0 ? { min: Math.min(...weights), max: Math.max(...weights) } : null;

const lengths = series.flatMap(s => [s.length_range.min, s.length_range.max]).filter((l): l is number => l != null && l > 0);
const lengthRange = lengths.length > 0 ? { min: Math.min(...lengths), max: Math.max(...lengths) } : null;

// ─── SEO ───

const topMakers = makerBreakdown.slice(0, 3).map(m => m.name).join(', ');
const topFishEn = allTargetFish.slice(0, 3).map(f => FISH_NAME_EN[f] ?? f).join(', ');
const yen = String.fromCharCode(165);
const priceUsd = priceRange ? `$${Math.round(priceRange.min / 150)}–$${Math.round(priceRange.max / 150)}` : '';

const pageDescription = [
  `${typeNameEn} lures: ${series.length} series, ${totalColors} colors.`,
  topMakers ? ` From ${topMakers} and ${makerBreakdown.length} other brands.` : '',
  topFishEn ? ` Targeting ${topFishEn}.` : '',
  priceUsd ? ` ${priceUsd}.` : '',
].join('');

const summaryParts: string[] = [];
summaryParts.push(`${typeNameEn} lures are available from ${makerBreakdown.length} brands with ${series.length} series and ${totalColors} colors`);
if (topMakers) summaryParts.push(`Top brands include ${topMakers}`);
if (allTargetFish.length > 0) {
  const fishNames = allTargetFish.slice(0, 5).map(f => FISH_NAME_EN[f] ?? f).join(', ');
  summaryParts.push(`Main targets: ${fishNames}`);
}
if (priceRange) {
  summaryParts.push(`Price range: ${yen}${priceRange.min.toLocaleString()}–${yen}${priceRange.max.toLocaleString()} (${priceUsd})`);
}
const summaryText = summaryParts.join('. ') + '.';

const specItems: { label: string; value: string }[] = [];
specItems.push({ label: 'Series', value: `${series.length}` });
specItems.push({ label: 'Colors', value: `${totalColors}` });
if (priceRange) specItems.push({ label: 'Price', value: `${yen}${priceRange.min.toLocaleString()} – ${yen}${priceRange.max.toLocaleString()}` });
if (weightRange) specItems.push({ label: 'Weight', value: `${weightRange.min}g – ${weightRange.max}g` });
if (lengthRange) specItems.push({ label: 'Length', value: `${lengthRange.min}mm – ${lengthRange.max}mm` });

// FAQ
const faqItems: { q: string; a: string }[] = [];
if (allTargetFish.length > 0) {
  const fishNames = allTargetFish.slice(0, 6).map(f => FISH_NAME_EN[f] ?? f).join(', ');
  faqItems.push({
    q: `What fish can you catch with ${typeNameEn} lures?`,
    a: `${typeNameEn} lures target ${fishNames}${allTargetFish.length > 6 ? ` and ${allTargetFish.length - 6} more species` : ''}. Choose from ${series.length} series to find the best match.`,
  });
}
if (priceRange) {
  faqItems.push({
    q: `What is the price range for ${typeNameEn} lures?`,
    a: `${typeNameEn} lures range from ${yen}${priceRange.min.toLocaleString()} to ${yen}${priceRange.max.toLocaleString()} (approx. ${priceUsd}). ${series.length} series with ${totalColors} colors are available.`,
  });
}
if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 5).map(m => m.name).join(', ');
  faqItems.push({
    q: `Which brands make the best ${typeNameEn} lures?`,
    a: `${makerBreakdown.length} brands produce ${typeNameEn} lures. Top brands by series count: ${makerNames}.`,
  });
}
if (weightRange) {
  faqItems.push({
    q: `What weight range do ${typeNameEn} lures come in?`,
    a: `${typeNameEn} lures range from ${weightRange.min}g to ${weightRange.max}g. Choose based on your target species and tackle setup.`,
  });
}

const faqLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
} : null;

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${typeNameEn} Lures`,
  url: `https://www.castlog.xyz/en/type/${typeSlug}/`,
  description: pageDescription,
  inLanguage: 'en',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: series.length,
    itemListElement: series.slice(0, 50).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.castlog.xyz/en/${s.manufacturer_slug}/${s.slug}/`,
      name: `${s.manufacturer} ${s.name}`,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.castlog.xyz/en/' },
    { '@type': 'ListItem', position: 2, name: 'Lure Types', item: 'https://www.castlog.xyz/en/type/' },
    { '@type': 'ListItem', position: 3, name: typeNameEn, item: `https://www.castlog.xyz/en/type/${typeSlug}/` },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])] as unknown as Record<string, unknown>;
---

<BaseLayout title={`${typeNameEn} Lures — ${series.length} Series${topMakers ? ` | ${topMakers}` : ''} | CAST/LOG`} description={pageDescription} canonicalPath={`/en/type/${typeSlug}/`} jsonLd={jsonLd} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-mid mb-8">
      <a href="/en/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/en/type/" class="hover:text-accent transition-colors">Lure Types</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{typeNameEn}</span>
    </nav>

    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{typeNameEn}</h1>
      <p class="text-sm text-text-mid mt-1">
        {series.length} series · {totalColors} colors
      </p>
    </div>

    <!-- Summary -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">
      <p class="text-sm text-gray-700 leading-relaxed mb-4">{summaryText}</p>

      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-5">
        {specItems.map(item => (
          <div>
            <p class="text-xs text-text-dim">{item.label}</p>
            <p class="text-sm font-semibold text-gray-900">{item.value}</p>
          </div>
        ))}
      </div>

      {makerBreakdown.length > 0 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">Brands</h2>
          <div class="flex flex-wrap gap-2">
            {makerBreakdown.map(m => (
              <a href={`/en/${m.slug}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent-bg transition-colors">
                {m.name}
                <span class="text-accent">{m.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {allTargetFish.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">Target Fish</h2>
          <div class="flex flex-wrap gap-1.5">
            {allTargetFish.map(fish => (
              <a href={`/en/fish/${getFishSlug(fish)}/`} class="px-2.5 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
                {FISH_NAME_EN[fish] ?? fish}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <h2 class="text-lg font-bold text-gray-900 mb-4">All {series.length} Series</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {series.map((s, i) => (
        <LureCard series={s} isNew={false} priority={i < 4} locale={locale} />
      ))}
    </div>

    <!-- FAQ -->
    {faqItems.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">FAQ</h2>
        <div class="space-y-3">
          {faqItems.map(item => (
            <details class="bg-white rounded-lg border border-gray-100 overflow-hidden group">
              <summary class="px-4 py-3 text-sm font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition-colors flex items-center justify-between">
                <span>{item.q}</span>
                <span class="text-accent text-xs group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-gray-700 leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Related Lure Types -->
    {relatedTypes.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Related Lure Types</h2>
        <p class="text-sm text-text-mid mb-4">
          Lure types that target similar fish species as {typeNameEn}
        </p>
        <div class="flex flex-wrap gap-2">
          {relatedTypes.map(t => (
            <a href={`/en/type/${t.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {LURE_TYPE_EN[t.name] ?? t.name}
              <span class="text-xs text-gray-400">{t.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
