---
/**
 * 英語版対象魚詳細ページ — /en/fish/[fish_slug]/
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import LureCard from '../../../../components/LureCard.astro';
import { fetchAllLures } from '../../../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../../../lib/group-lures';
import { FISH_SLUG_MAP, FISH_NAME_MAP, getTypeSlug } from '../../../../lib/category-slugs';
import { FISH_NAME_EN, LURE_TYPE_EN } from '../../../../i18n/dictionaries/fishing-terms';
import type { LureSeries } from '../../../../lib/types';

const locale = 'en' as const;

export async function getStaticPaths() {
  const lures = await fetchAllLures();
  const allSeries = groupLuresBySeries(lures ?? []);

  const fishMap = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    for (const fish of s.target_fish) {
      const existing = fishMap.get(fish) || [];
      existing.push(s);
      fishMap.set(fish, existing);
    }
  }

  const fishProfiles = new Map<string, { types: Set<string>; makers: Set<string>; count: number }>();
  for (const [name, seriesList] of fishMap) {
    const types = new Set<string>();
    const makers = new Set<string>();
    for (const s of seriesList) {
      if (s.type) types.add(s.type);
      makers.add(s.manufacturer_slug);
    }
    fishProfiles.set(name, { types, makers, count: seriesList.length });
  }

  return [...fishMap.entries()].map(([fishName, series]) => {
    const slug = FISH_SLUG_MAP[fishName] ?? encodeURIComponent(fishName);

    const profile = fishProfiles.get(fishName)!;
    const scored: { name: string; slug: string; count: number; score: number }[] = [];
    for (const [otherName, otherProfile] of fishProfiles) {
      if (otherName === fishName) continue;
      let score = 0;
      for (const t of profile.types) { if (otherProfile.types.has(t)) score += 2; }
      for (const m of profile.makers) { if (otherProfile.makers.has(m)) score += 1; }
      if (score > 0) {
        scored.push({
          name: otherName,
          slug: FISH_SLUG_MAP[otherName] ?? encodeURIComponent(otherName),
          count: otherProfile.count,
          score,
        });
      }
    }
    scored.sort((a, b) => b.score - a.score || b.count - a.count);
    const relatedFish = scored.slice(0, 8).map(({ name, slug, count }) => ({ name, slug, count }));

    return {
      params: { fish_slug: slug },
      props: { fishName, series, relatedFish },
    };
  });
}

const { fishName, series, relatedFish } = Astro.props as {
  fishName: string;
  series: LureSeries[];
  relatedFish: { name: string; slug: string; count: number }[];
};

const fishSlug = Astro.params.fish_slug as string;
const fishNameEn = FISH_NAME_EN[fishName] ?? fishName;

// ─── 集計 ───

const totalColors = series.reduce((sum, s) => sum + s.color_count, 0);

const makerCounts = new Map<string, { name: string; slug: string; count: number }>();
for (const s of series) {
  const existing = makerCounts.get(s.manufacturer_slug);
  if (existing) existing.count++;
  else makerCounts.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
}
const makerBreakdown = [...makerCounts.values()].sort((a, b) => b.count - a.count);

const typeCounts = new Map<string, number>();
for (const s of series) {
  if (s.type) typeCounts.set(s.type, (typeCounts.get(s.type) || 0) + 1);
}
const typeBreakdown = [...typeCounts.entries()].sort((a, b) => b[1] - a[1]).map(([type, count]) => ({ type, count }));

const prices = series.flatMap(s => [s.price_range.min, s.price_range.max]).filter(p => p > 0);
const priceRange = prices.length > 0 ? { min: Math.min(...prices), max: Math.max(...prices) } : null;

const weights = series.flatMap(s => [s.weight_range.min, s.weight_range.max]).filter((w): w is number => w != null && w > 0);
const weightRange = weights.length > 0 ? { min: Math.min(...weights), max: Math.max(...weights) } : null;

// ─── SEO ───

const topMakers = makerBreakdown.slice(0, 3).map(m => m.name).join(', ');
const topTypesEn = typeBreakdown.slice(0, 3).map(t => LURE_TYPE_EN[t.type] ?? t.type).join(', ');
const yen = String.fromCharCode(165);
const priceUsd = priceRange ? `$${Math.round(priceRange.min / 150)}–$${Math.round(priceRange.max / 150)}` : '';

const pageDescription = [
  `${fishNameEn} lures: ${series.length} series, ${totalColors} colors.`,
  topTypesEn ? ` Types: ${topTypesEn}.` : '',
  topMakers ? ` From ${topMakers}.` : '',
  priceUsd ? ` ${priceUsd}.` : '',
].join('');

const summaryParts: string[] = [];
summaryParts.push(`${series.length} series and ${totalColors} colors are available for ${fishNameEn}`);
if (typeBreakdown.length > 0) {
  const typeNames = typeBreakdown.slice(0, 5).map(t => LURE_TYPE_EN[t.type] ?? t.type).join(', ');
  summaryParts.push(`Available in ${typeBreakdown.length > 5 ? `${typeBreakdown.length}` : ''} lure types including ${typeNames}`);
}
if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 4).map(m => m.name).join(', ');
  summaryParts.push(`From ${makerBreakdown.length} brands including ${makerNames}`);
}
if (priceRange) {
  summaryParts.push(`Price range: ${yen}${priceRange.min.toLocaleString()}–${yen}${priceRange.max.toLocaleString()} (${priceUsd})`);
}
const summaryText = summaryParts.join('. ') + '.';

const specItems: { label: string; value: string }[] = [];
specItems.push({ label: 'Series', value: `${series.length}` });
specItems.push({ label: 'Colors', value: `${totalColors}` });
specItems.push({ label: 'Brands', value: `${makerBreakdown.length}` });
if (priceRange) specItems.push({ label: 'Price', value: `${yen}${priceRange.min.toLocaleString()} – ${yen}${priceRange.max.toLocaleString()}` });
if (weightRange) specItems.push({ label: 'Weight', value: `${weightRange.min}g – ${weightRange.max}g` });

// FAQ
const faqItems: { q: string; a: string }[] = [];
if (typeBreakdown.length > 0) {
  const typeNames = typeBreakdown.slice(0, 6).map(t => `${LURE_TYPE_EN[t.type] ?? t.type} (${t.count} series)`).join(', ');
  faqItems.push({
    q: `What types of lures work for ${fishNameEn}?`,
    a: `${typeBreakdown.length} lure types are available for ${fishNameEn}, including ${typeNames}.`,
  });
}
if (priceRange) {
  faqItems.push({
    q: `What is the price range for ${fishNameEn} lures?`,
    a: `${fishNameEn} lures range from ${yen}${priceRange.min.toLocaleString()} to ${yen}${priceRange.max.toLocaleString()} (approx. ${priceUsd}). Choose from ${series.length} series and ${totalColors} colors.`,
  });
}
if (makerBreakdown.length > 0) {
  const makerNames = makerBreakdown.slice(0, 5).map(m => m.name).join(', ');
  faqItems.push({
    q: `Which brands make the best ${fishNameEn} lures?`,
    a: `${makerBreakdown.length} brands produce ${fishNameEn} lures. Top brands by series count: ${makerNames}.`,
  });
}

const faqLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
} : null;

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${fishNameEn} Lures`,
  url: `https://www.castlog.xyz/en/fish/${fishSlug}/`,
  description: pageDescription,
  inLanguage: 'en',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: series.length,
    itemListElement: series.slice(0, 50).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.castlog.xyz/en/${s.manufacturer_slug}/${s.slug}/`,
      name: `${s.manufacturer} ${s.name}`,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.castlog.xyz/en/' },
    { '@type': 'ListItem', position: 2, name: 'Target Fish', item: 'https://www.castlog.xyz/en/fish/' },
    { '@type': 'ListItem', position: 3, name: fishNameEn, item: `https://www.castlog.xyz/en/fish/${fishSlug}/` },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])] as unknown as Record<string, unknown>;
---

<BaseLayout title={`${fishNameEn} Lures — ${series.length} Series${topTypesEn ? ` | ${topTypesEn}` : ''} | CAST/LOG`} description={pageDescription} canonicalPath={`/en/fish/${fishSlug}/`} jsonLd={jsonLd} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-mid mb-8">
      <a href="/en/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/en/fish/" class="hover:text-accent transition-colors">Target Fish</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{fishNameEn}</span>
    </nav>

    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Lures for {fishNameEn}</h1>
      <p class="text-sm text-text-mid mt-1">
        {series.length} series · {totalColors} colors
      </p>
    </div>

    <!-- Summary -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">
      <p class="text-sm text-gray-700 leading-relaxed mb-4">{summaryText}</p>

      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-5">
        {specItems.map(item => (
          <div>
            <p class="text-xs text-text-dim">{item.label}</p>
            <p class="text-sm font-semibold text-gray-900">{item.value}</p>
          </div>
        ))}
      </div>

      {typeBreakdown.length > 0 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">Lure Types</h2>
          <div class="flex flex-wrap gap-2">
            {typeBreakdown.map(t => (
              <a href={`/en/type/${getTypeSlug(t.type)}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent-bg transition-colors">
                {LURE_TYPE_EN[t.type] ?? t.type}
                <span class="text-accent">{t.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {makerBreakdown.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">Brands</h2>
          <div class="flex flex-wrap gap-2">
            {makerBreakdown.map(m => (
              <a href={`/en/${m.slug}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs font-medium border border-gray-100 hover:bg-gray-100 transition-colors">
                {m.name}
                <span class="text-gray-400">{m.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <h2 class="text-lg font-bold text-gray-900 mb-4">All {series.length} Series</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {series.map((s, i) => (
        <LureCard series={s} isNew={false} priority={i < 4} locale={locale} />
      ))}
    </div>

    <!-- FAQ -->
    {faqItems.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">FAQ</h2>
        <div class="space-y-3">
          {faqItems.map(item => (
            <details class="bg-white rounded-lg border border-gray-100 overflow-hidden group">
              <summary class="px-4 py-3 text-sm font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition-colors flex items-center justify-between">
                <span>{item.q}</span>
                <span class="text-accent text-xs group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-gray-700 leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Related Target Fish -->
    {relatedFish.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Related Target Fish</h2>
        <p class="text-sm text-text-mid mb-4">
          Fish species that share lure types and brands with {fishNameEn}
        </p>
        <div class="flex flex-wrap gap-2">
          {relatedFish.map(f => (
            <a href={`/en/fish/${f.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {FISH_NAME_EN[f.name] ?? f.name}
              <span class="text-xs text-gray-400">{f.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
