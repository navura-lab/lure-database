---
/**
 * 英語版 比較インデックスページ — /en/compare/
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { fetchAllLures } from '../../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../../../lib/category-slugs';
import { LURE_TYPE_EN, FISH_NAME_EN } from '../../../i18n/dictionaries/fishing-terms';

const locale = 'en' as const;
const MIN_SERIES = 3;
const lures = await fetchAllLures();
const allSeries = groupLuresBySeries(lures ?? []);

const crossMap = new Map<string, { fishName: string; typeName: string; count: number }>();
for (const s of allSeries) {
  if (!s.type) continue;
  for (const fish of s.target_fish) {
    const fishSlug = getFishSlug(fish);
    const typeSlug = getTypeSlug(s.type);
    const key = `${fishSlug}-${typeSlug}`;
    const existing = crossMap.get(key);
    if (existing) existing.count++;
    else crossMap.set(key, { fishName: fish, typeName: s.type, count: 1 });
  }
}

const categories = [...crossMap.entries()]
  .filter(([_, v]) => v.count >= MIN_SERIES)
  .sort((a, b) => b[1].count - a[1].count);

const fishGroups = new Map<string, { slug: string; fishName: string; typeName: string; count: number }[]>();
for (const [slug, { fishName, typeName, count }] of categories) {
  const arr = fishGroups.get(fishName) || [];
  arr.push({ slug, fishName, typeName, count });
  fishGroups.set(fishName, arr);
}
const sortedFishGroups = [...fishGroups.entries()]
  .sort((a, b) => b[1].reduce((s, c) => s + c.count, 0) - a[1].reduce((s, c) => s + c.count, 0));

const pageTitle = `JDM Lure Comparison - ${categories.length} Categories | CAST/LOG`;
const pageDescription = `Compare ${categories.length} categories of JDM lures by specs, color lineups, and pricing. Side-by-side comparison covering ${sortedFishGroups.slice(0, 3).map(([name]) => FISH_NAME_EN[name] ?? name).join(', ')} and more.`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.castlog.xyz/en/' },
    { '@type': 'ListItem', position: 2, name: 'Compare', item: 'https://www.castlog.xyz/en/compare/' },
  ],
};
const jsonLd = [breadcrumbLd] as unknown as Record<string, unknown>;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/en/compare/" jsonLd={jsonLd} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-mid mb-8">
      <a href="/en/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">Compare</span>
    </nav>

    <div class="mb-6">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-1">COMPARE</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
        JDM Lure Comparison
      </h1>
      <p class="text-sm text-text-mid mt-1">
        {categories.length} categories compared by specs, colors, and pricing
      </p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">
      <p class="text-sm text-gray-700 leading-relaxed">
        Compare top-rated JDM lures by target fish and lure type. View spec, color lineup, and price comparisons side by side to find the best match for your fishing conditions.
      </p>
    </div>

    {sortedFishGroups.map(([fishName, items]) => {
      const fishEn = FISH_NAME_EN[fishName] ?? fishName;
      return (
        <section class="mb-8">
          <h2 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
            {fishEn}
            <span class="text-xs font-normal text-text-dim bg-gray-100 px-2 py-0.5 rounded-full">
              {items.length} categories
            </span>
          </h2>
          <div class="flex flex-wrap gap-2">
            {items.sort((a, b) => b.count - a.count).map(item => (
              <a
                href={`/en/compare/${item.slug}/`}
                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors"
              >
                {LURE_TYPE_EN[item.typeName] ?? item.typeName}
                <span class="text-xs text-gray-400">{item.count}</span>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mt-12 pt-8 border-t border-gray-100">
      <p class="text-sm text-text-mid mb-3">Browse all series in catalog format:</p>
      <a href="/en/ranking/" class="px-4 py-2 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent-hover transition-colors">
        View Catalog (Ranking) &rarr;
      </a>
    </section>

  </div>
</BaseLayout>
