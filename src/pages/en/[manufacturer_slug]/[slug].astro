---
/**
 * English Lure Detail Page — /en/[manufacturer_slug]/[slug]/
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Badge from '../../../components/Badge.astro';
import Placeholder from '../../../components/Placeholder.astro';
import LureCard from '../../../components/LureCard.astro';

import { getTypeSlug, getFishSlug } from '../../../lib/category-slugs';
import { youtubeVideos } from '../../../data/youtube-videos';
import type { LureSeries } from '../../../lib/types';
import { getLurePaths } from '../../../lib/paths/lure-paths';
import type { LurePathProps } from '../../../lib/paths/lure-paths';
import { LURE_TYPE_EN, FISH_NAME_EN, COLOR_CATEGORY_EN, ACTION_TYPE_EN } from '../../../i18n/dictionaries/fishing-terms';
import { generateAutoDescriptionEn } from '../../../i18n/generators/auto-description.en';
import { getFieldCompatibilityEn } from '../../../i18n/generators/field-compatibility.en';
import { generateWeightStrategyEn } from '../../../i18n/generators/weight-strategy.en';
import { localizeSimilarSeries } from '../../../i18n/generators/similar-series.en';
import { editorialReviews } from '../../../data/seo/editorials/_index';

const locale = 'en' as const;

export async function getStaticPaths() {
  return getLurePaths('en');
}

const {
  series, relatedByType, relatedByMaker, relatedByFish, canonicalPathOverride,
  categoryRank, categoryTotal, categoryFish, colorBreakdown, relatedContentArticles,
  categoryComparisonPeers, specComparison, pricePosition,
  fieldCompat, weightStrategy, similarSeries,
} = Astro.props as LurePathProps;

// 英語版生成データで上書き
const fieldCompatEn = getFieldCompatibilityEn(series.type);
const weightStrategyEn = generateWeightStrategyEn(series);
const similarSeriesEn = localizeSimilarSeries(similarSeries, series);

const typeEn = LURE_TYPE_EN[series.type] ?? series.type;
const fishEn = categoryFish ? (FISH_NAME_EN[categoryFish] ?? categoryFish) : '';

const hasLimited = (series.colors || []).some(c => c.is_limited);

// 楽天アフィリエイトリンク
const RAKUTEN_AFF_ID = '521589db.1417b362.521589dc.750250b8';
const rakutenSearchUrl = `https://hb.afl.rakuten.co.jp/ichiba/${RAKUTEN_AFF_ID}/?pc=${encodeURIComponent(`https://search.rakuten.co.jp/search/mall/${series.manufacturer} ${series.name}/`)}`;

// エディトリアルレビュー（SEO Pipeline生成コンテンツ）
const editorial = editorialReviews[series.slug] || null;
const hasPrice = series.price_range.max > 0;

// 価格表示（USD換算付き）
const yen = String.fromCharCode(165);
const priceDisplay = hasPrice
  ? series.price_range.min === series.price_range.max
    ? `${yen}${series.price_range.min.toLocaleString()} (~$${Math.round(series.price_range.min / 150)})`
    : `${yen}${series.price_range.min.toLocaleString()} - ${yen}${series.price_range.max.toLocaleString()} (~$${Math.round(series.price_range.min / 150)}-$${Math.round(series.price_range.max / 150)})`
  : null;

const weightDisplay = (() => {
  if (!series.weight_range.min) return null;
  if (series.weight_range.min === series.weight_range.max) return `${series.weight_range.min}g`;
  return `${series.weight_range.min} - ${series.weight_range.max}g`;
})();

const lengthDisplay = (() => {
  if (!series.length_range.min) return null;
  if (series.length_range.min === series.length_range.max) return `${series.length_range.min}mm`;
  return `${series.length_range.min} - ${series.length_range.max}mm`;
})();

function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
  return match ? match[1] : null;
}

const youtubeId = series.official_video_url ? getYouTubeId(series.official_video_url) : null;
const embedUrl = youtubeId ? `https://www.youtube.com/embed/${youtubeId}` : null;

const videoKey = `${series.manufacturer_slug}/${series.slug}`;
const relatedVideos = (youtubeVideos[videoKey] || [])
  .filter(v => v.videoId !== youtubeId)
  .slice(0, 3);

// --- SEO ---
const pageTitle = `${series.name} by ${series.manufacturer} - ${typeEn} | ${series.color_count} Colors | CAST/LOG`;

const specs = [
  typeEn,
  weightDisplay ? `${weightDisplay}` : null,
  lengthDisplay ? `${lengthDisplay}` : null,
  `${series.color_count} colors`,
].filter(Boolean).join(' | ');

const autoDescription = generateAutoDescriptionEn(series);
const effectiveDescription = autoDescription;

const rankLabel = categoryRank > 0 && categoryRank <= 10 && fishEn
  ? `Ranked #${categoryRank} of ${categoryTotal} ${typeEn.toLowerCase()} for ${fishEn}. `
  : '';

function truncateDescription(raw: string, maxLen: number = 155): string {
  if (raw.length <= maxLen) return raw;
  const cut = raw.lastIndexOf('. ', maxLen - 1);
  if (cut > 80) return raw.slice(0, cut + 1);
  return raw.slice(0, maxLen - 1) + '...';
}

const rawDescription = `${series.name} by ${series.manufacturer} - ${typeEn} with ${series.color_count} colors. ${rankLabel}${effectiveDescription}`;
const pageDescription = truncateDescription(rawDescription);

// Spec summary
const specParts: string[] = [];
specParts.push(`${typeEn} by ${series.manufacturer}`);
if (weightDisplay) specParts.push(`weighing ${weightDisplay}`);
if (lengthDisplay) specParts.push(`${lengthDisplay} long`);
if (series.diving_depth) specParts.push(`diving depth ${series.diving_depth}`);
if (series.action_type) specParts.push(`${ACTION_TYPE_EN[series.action_type] ?? series.action_type} action`);
if (hasPrice) specParts.push(`priced at ${priceDisplay}`);
const targetFishEn = (series.target_fish || []).slice(0, 5).map(f => FISH_NAME_EN[f] ?? f);
const specsSummary = `The ${series.name} is a ${specParts.join(', ')}. Available in ${series.color_count} colors${targetFishEn.length > 0 ? `, designed for ${targetFishEn.join(', ')}` : ''}.`;

// --- JSON-LD ---
const productImages: string[] = [];
if (series.representative_image) productImages.push(series.representative_image);
for (const color of series.colors) {
  if (color.images && color.images.length > 0) productImages.push(color.images[0]);
  if (productImages.length >= 9) break;
}
const uniqueImages = [...new Set(productImages)];

const offersLd = hasPrice
  ? series.price_range.min === series.price_range.max
    ? { '@type': 'Offer', priceCurrency: 'JPY', price: series.price_range.min, availability: 'https://schema.org/InStock', url: `https://www.castlog.xyz/en/${series.manufacturer_slug}/${series.slug}/` }
    : { '@type': 'AggregateOffer', priceCurrency: 'JPY', lowPrice: series.price_range.min, highPrice: series.price_range.max, offerCount: series.color_count, availability: 'https://schema.org/InStock' }
  : undefined;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org', '@type': 'Product',
  name: `${series.manufacturer} ${series.name}`,
  description: effectiveDescription,
  brand: { '@type': 'Brand', name: series.manufacturer },
  category: typeEn,
  sku: `${series.manufacturer_slug}-${series.slug}`,
  url: `https://www.castlog.xyz/en/${series.manufacturer_slug}/${series.slug}/`,
  ...(uniqueImages.length > 0 ? { image: uniqueImages } : {}),
  ...(offersLd ? { offers: offersLd } : {}),
  additionalProperty: [
    ...(series.weight_range.min ? [{ '@type': 'PropertyValue', name: 'Weight', value: weightDisplay }] : []),
    ...(series.length_range.min ? [{ '@type': 'PropertyValue', name: 'Length', value: lengthDisplay }] : []),
    ...(series.diving_depth ? [{ '@type': 'PropertyValue', name: 'Diving Depth', value: series.diving_depth }] : []),
    ...(series.action_type ? [{ '@type': 'PropertyValue', name: 'Action', value: ACTION_TYPE_EN[series.action_type] ?? series.action_type }] : []),
    ...(series.target_fish.length > 0 ? [{ '@type': 'PropertyValue', name: 'Target Fish', value: targetFishEn.join(', ') }] : []),
    ...(series.color_count > 0 ? [{ '@type': 'PropertyValue', name: 'Color Count', value: `${series.color_count}` }] : []),
  ],
};

const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.castlog.xyz/en/' },
    { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://www.castlog.xyz/en/maker/' },
    { '@type': 'ListItem', position: 3, name: series.manufacturer, item: `https://www.castlog.xyz/en/${series.manufacturer_slug}/` },
    { '@type': 'ListItem', position: 4, name: series.name, item: `https://www.castlog.xyz/en/${series.manufacturer_slug}/${series.slug}/` },
  ],
};

// FAQ
const faqEntries: { '@type': string; name: string; acceptedAnswer: { '@type': string; text: string } }[] = [];

if (series.type) {
  const rankInfo = categoryRank > 0 && fishEn
    ? ` In the CAST/LOG database, there are ${categoryTotal} ${typeEn.toLowerCase()} series for ${fishEn}, and the ${series.name} ranks #${categoryRank} by color variety.`
    : '';
  const parts = [
    `The ${series.name} is a ${typeEn.toLowerCase()} made by ${series.manufacturer}.`,
    weightDisplay ? ` Weight: ${weightDisplay}.` : '',
    lengthDisplay ? ` Length: ${lengthDisplay}.` : '',
    series.diving_depth ? ` Diving depth: ${series.diving_depth}.` : '',
    series.action_type ? ` Action: ${ACTION_TYPE_EN[series.action_type] ?? series.action_type}.` : '',
    ` Available in ${series.color_count} colors.`,
    rankInfo,
  ].filter(Boolean).join('');
  faqEntries.push({ '@type': 'Question', name: `What are the specs of the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: parts } });
}

if (hasPrice) {
  faqEntries.push({ '@type': 'Question', name: `How much does the ${series.name} cost?`, acceptedAnswer: { '@type': 'Answer', text: `The ${series.name} is priced at ${priceDisplay} (tax included).` } });
}

if ((series.target_fish || []).length > 0) {
  const fishList = targetFishEn.join(', ');
  faqEntries.push({ '@type': 'Question', name: `What fish can you catch with the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: `The ${series.name} is designed as a ${typeEn.toLowerCase()} targeting ${fishList}.${ (series.target_fish || []).length >= 3 ? ` It has the most proven track record for ${targetFishEn[0]}.` : ''}` } });
}

if (series.color_count > 0) {
  const sampleColors = (series.colors || []).slice(0, 5).map(c => c.color_name).join(', ');
  const topCat = colorBreakdown.length > 0 && colorBreakdown[0].id !== 'other'
    ? ` The most prominent color category is ${COLOR_CATEGORY_EN[colorBreakdown[0].label] ?? colorBreakdown[0].label} with ${colorBreakdown[0].count} colors (${colorBreakdown[0].pct}%).`
    : '';
  faqEntries.push({ '@type': 'Question', name: `What colors are available for the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: `The ${series.name} comes in ${series.color_count} colors including ${sampleColors}.${topCat}` } });
}

faqEntries.push({ '@type': 'Question', name: `What are the features of the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: effectiveDescription } });

if (fieldCompatEn.length > 0) {
  const bestFields = fieldCompatEn.filter(f => f.rating === '◎').map(f => f.field);
  const goodFields = fieldCompatEn.filter(f => f.rating === '○').map(f => f.field);
  const fieldAnswer = bestFields.length > 0
    ? `The ${series.name} (${typeEn}) is best suited for ${bestFields.join(', ')}.${goodFields.length > 0 ? ` Also effective in ${goodFields.join(', ')}.` : ''}`
    : `The ${series.name} (${typeEn}) can be used in ${goodFields.join(', ')}.`;
  faqEntries.push({ '@type': 'Question', name: `What fishing environments suit the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: fieldAnswer } });
}

if (weightStrategyEn.length >= 2) {
  const wsText = weightStrategyEn.map(w => `${w.label} for ${w.situation.toLowerCase()}`).join('; ');
  faqEntries.push({ '@type': 'Question', name: `How do I choose the right weight for the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: `The ${series.name} covers ${weightStrategyEn.length} weight categories: ${wsText}. Choose based on water depth and current conditions.` } });
}

if (series.target_fish.length > 0) {
  const seasonMap: Record<string, string> = {
    'シーバス': 'Year-round (peak during spring post-spawn and fall gizzard shad patterns)',
    'ヒラメ': 'Fall through spring (Oct-Apr, with late fall to early winter being prime)',
    'マゴチ': 'Summer through fall (Jun-Oct, when water temperature is high)',
    '青物': 'Summer through fall (Jul-Nov, timing depends on migration)',
    'ブラックバス': 'Year-round (peak during spring pre-spawn period)',
    'メバル': 'Winter through spring (Dec-May, mainly night fishing)',
    'アジ': 'Year-round (summer through fall for best numbers)',
    'イカ': 'Spring (Mar-Jun for large spawning adults) and fall (Sep-Nov for new hatchlings)',
    'マダイ': 'Year-round (spring spawning run and fall aggressive feeding are peak)',
    'ヒラマサ': 'Summer through fall (Jun-Nov, water temp above 20C)',
    'タチウオ': 'Summer through winter (Jul-Dec, evening to night is best)',
    'チヌ': 'Year-round (spring through fall has highest activity)',
    'ロックフィッシュ': 'Year-round (fall through winter is prime, tolerates cold water)',
  };
  const fish = series.target_fish[0];
  const season = seasonMap[fish];
  if (season) {
    faqEntries.push({ '@type': 'Question', name: `When is the best season to use the ${series.name}?`, acceptedAnswer: { '@type': 'Answer', text: `The primary target of the ${series.name}, ${FISH_NAME_EN[fish] ?? fish}, can be targeted: ${season}. Conditions vary by region and water temperature.` } });
  }
}

const faqLd = faqEntries.length > 0 ? { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqEntries } : null;

const videoLdItems: Record<string, unknown>[] = [];
if (youtubeId) {
  videoLdItems.push({ '@context': 'https://schema.org', '@type': 'VideoObject', name: `${series.manufacturer} ${series.name} Official Video`, description: `Official video for the ${series.name} ${typeEn.toLowerCase()} by ${series.manufacturer}.`, thumbnailUrl: `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`, embedUrl: `https://www.youtube.com/embed/${youtubeId}`, uploadDate: series.created_at });
}

// Color selection guide (English)
const COLOR_ADVICE_EN: Record<string, string> = {
  natural: 'The go-to choice for clear water and daytime fishing. Match to local baitfish for best results',
  chart: 'Excels in low-light, dawn/dusk, and murky water. High visibility helps anglers track the lure',
  glow: 'Proven performer for night fishing and deep water. UV-reactive glow appeals even in daytime depths',
  red: 'Classic dawn bite color. Red/gold combos are proven producers in stained water',
  gold: 'Strong appeal through flash in murky water and dawn/dusk conditions. A natural flash pattern',
  silver: 'The standard for sunny, clear water conditions. Flash effect searches wide areas effectively',
  pink: 'Excellent visibility in overcast or stained water. Proven for flatfish and trout species',
  orange: 'Effective at dusk and in murky conditions. Subtler appeal than red-based colors',
  blue: 'Proven in clear open-water environments. Popular for bluewater species on offshore trips',
  green: 'Camouflage effect in weedy areas. Effective in high-pressure fishing spots',
  purple: 'The secret weapon for tough conditions. Can trigger fish that ignore other colors',
};
const colorGuideLines: string[] = [];
const topColors = colorBreakdown.filter(c => c.id !== 'other').slice(0, 3);
for (const cat of topColors) {
  const advice = COLOR_ADVICE_EN[cat.id];
  if (advice) {
    const catEn = COLOR_CATEGORY_EN[cat.label] ?? cat.label;
    colorGuideLines.push(`${catEn} (${cat.count} colors): ${advice}`);
  }
}

const combinedJsonLd = [jsonLd, breadcrumbLd, ...(faqLd ? [faqLd] : []), ...videoLdItems] as unknown as Record<string, unknown>;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPathOverride ? `/en${canonicalPathOverride}` : `/en/${series.manufacturer_slug}/${series.slug}/`}
  ogImage={`https://www.castlog.xyz/og/${series.manufacturer_slug}/${series.slug}/`}
  ogType="product"
  jsonLd={combinedJsonLd}
  locale={locale}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-pagefind-body>

    <!-- Breadcrumb -->
    <nav class="text-sm text-text-mid mb-8" data-pagefind-ignore>
      <a href="/en/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`/en/${series.manufacturer_slug}/`} class="hover:text-accent transition-colors">{series.manufacturer}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{series.name}</span>
    </nav>

    <!-- Pagefind metadata (for build-time indexing) -->
    <span data-pagefind-meta="title" class="sr-only">{series.manufacturer} {series.name}</span>
    {series.representative_image && (
      <span data-pagefind-meta={`image:${series.representative_image}`} class="sr-only"></span>
    )}

    <!-- Editorial Review (top position) -->
    {editorial && (
      <section class="mb-10">
        <div class="bg-gradient-to-br from-surface to-bg rounded-2xl border border-border-light p-6 sm:p-8">
          {/* First view: representative image + catchcopy */}
          <div class="flex flex-col sm:flex-row gap-6 mb-8">
            {series.representative_image && (
              <div class="sm:w-2/5 shrink-0">
                <div class="aspect-[4/3] rounded-xl overflow-hidden bg-white border border-border-light">
                  <img
                    src={series.representative_image}
                    alt={`${series.manufacturer} ${series.name}`}
                    class="w-full h-full object-scale-down p-4"
                    loading="eager"
                  />
                </div>
              </div>
            )}
            <div class="flex-1">
              <p class="text-lg sm:text-xl font-bold text-text leading-snug mb-4">
                {editorial.catchcopy}
              </p>
              <p class="text-[15px] text-text-mid leading-[1.9] whitespace-pre-line">
                {editorial.overview.split('\n\n')[0]}
              </p>
            </div>
          </div>
          {editorial.overview.split('\n\n').length > 1 && (
            <div class="text-[15px] text-text-mid leading-[1.9] whitespace-pre-line mb-8">
              {editorial.overview.split('\n\n').slice(1).join('\n\n')}
            </div>
          )}
          <div class="space-y-6 mb-8">
            {editorial.strengths.map((s, i) => (
              <div>
                <h3 class="text-base font-bold text-text mb-2 flex items-center gap-2">
                  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-accent text-white text-xs font-bold">{i + 1}</span>
                  {s.title}
                </h3>
                <p class="text-[14px] text-text-mid leading-[1.85] whitespace-pre-line">{s.body}</p>
              </div>
            ))}
          </div>
          <div class="mb-8">
            <h3 class="text-base font-bold text-text mb-4">How to Use</h3>
            <div class="space-y-4">
              {editorial.usage.map(u => (
                <div class="bg-bg rounded-xl border border-border-light p-4">
                  <p class="text-sm font-bold text-accent mb-1.5">{u.scene}</p>
                  <p class="text-[14px] text-text-mid leading-[1.8]">{u.body}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="mb-8">
            <h3 class="text-base font-bold text-text mb-2">Color Guide</h3>
            <p class="text-[14px] text-text-mid leading-[1.85] whitespace-pre-line">{editorial.colorGuide}</p>
          </div>
          <div class="mb-8">
            <h3 class="text-base font-bold text-text mb-3">Things to Consider</h3>
            <div class="space-y-2">
              {editorial.concerns.map(c => (
                <div class="flex items-start gap-2 text-[14px] text-text-mid">
                  <span class="text-warning mt-0.5 shrink-0">▸</span>
                  <span class="leading-[1.8]">{c}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
            <div class="bg-accent-bg rounded-xl p-4">
              <p class="text-sm font-bold text-accent mb-2">Recommended For</p>
              <div class="space-y-1.5">
                {editorial.recommendation.recommended.map(r => (
                  <p class="text-[13px] text-text-mid flex items-start gap-1.5">
                    <span class="text-accent shrink-0">✓</span> {r}
                  </p>
                ))}
              </div>
            </div>
            <div class="bg-surface rounded-xl p-4">
              <p class="text-sm font-bold text-text-dim mb-2">Not Recommended For</p>
              <div class="space-y-1.5">
                {editorial.recommendation.notRecommended.map(r => (
                  <p class="text-[13px] text-text-mid flex items-start gap-1.5">
                    <span class="text-text-dim shrink-0">—</span> {r}
                  </p>
                ))}
              </div>
            </div>
          </div>
          <p class="text-xs text-text-faint">
            ※ CAST/LOG Editorial Review. Based on database analysis as of {series.created_at?.slice(0, 10) || '2026-03-20'}.
          </p>
        </div>
      </section>
    )}

    <!-- Main Area -->
    <div class="flex flex-col md:flex-row gap-8 mb-12">
      <!-- Image -->
      <div class="md:w-1/2">
        <div class="aspect-square rounded-xl overflow-hidden border border-gray-100 bg-white">
          {series.representative_image ? (
            <img src={series.representative_image} alt={`${series.manufacturer} ${series.name} ${typeEn}`} width="600" height="600" decoding="async" class="w-full h-full object-scale-down p-6" />
          ) : (
            <Placeholder type={series.type} />
          )}
        </div>
        {series.colors && (series.colors || []).filter(c => c.images?.length > 0).length > 1 && (
          <div class="flex gap-2 overflow-x-auto py-3 scrollbar-hide">
            {(series.colors || []).filter(c => c.images?.length > 0).slice(0, 12).map((color, i) => (
              <div class="shrink-0 w-14 h-14 rounded-lg overflow-hidden border-2 border-transparent hover:border-accent transition-colors cursor-pointer">
                <img src={color.images[0]} alt={color.color_name} class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="md:w-1/2">
        <p class="text-sm text-text-mid tracking-wider uppercase mb-1">{series.manufacturer}</p>
        <h1 class="text-3xl font-bold text-gray-900 mb-3">{series.name}</h1>

        <div class="flex flex-wrap gap-2 mb-6">
          <a href={`/en/type/${getTypeSlug(series.type)}/`}>
            <Badge label={typeEn} variant="type" />
          </a>
          {hasLimited && <Badge label="Limited" variant="limited" />}
        </div>

        <!-- Specs -->
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm mb-6">
          {weightDisplay && (
            <div><p class="text-text-dim">Weight</p><p class="font-medium">{weightDisplay}</p></div>
          )}
          {lengthDisplay && (
            <div><p class="text-text-dim">Length</p><p class="font-medium">{lengthDisplay}</p></div>
          )}
          {series.diving_depth && (
            <div><p class="text-text-dim">Diving Depth</p><p class="font-medium">{series.diving_depth}</p></div>
          )}
          {series.action_type && (
            <div><p class="text-text-dim">Action</p><p class="font-medium">{ACTION_TYPE_EN[series.action_type] ?? series.action_type}</p></div>
          )}
          {series.release_year && (
            <div><p class="text-text-dim">Released</p><p class="font-medium">{series.release_year}</p></div>
          )}
          <div><p class="text-text-dim">Colors</p><p class="font-medium">{series.color_count}</p></div>
        </div>

        {priceDisplay && (
          <div class="border-t border-gray-100 pt-4 mb-6">
            <p class="text-text-dim text-sm">Price (MSRP)</p>
