---
/**
 * 英語版 価格帯ガイド一覧ページ — /en/guide/price/
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { priceRanges } from '../../../../data/price-ranges';

const locale = 'en' as const;

const pageTitle = 'JDM Lure Price Guide | CAST/LOG';
const pageDescription = 'Browse JDM fishing lures by price range. From budget-friendly options under $7 to premium big baits over $20. Find the perfect lure for your budget.';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.castlog.xyz/en/' },
    { '@type': 'ListItem', position: 2, name: 'Price Guide', item: 'https://www.castlog.xyz/en/guide/price/' },
  ],
};

const jsonLd = [breadcrumbLd] as unknown as Record<string, unknown>;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/en/guide/price/" jsonLd={jsonLd} locale={locale}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-mid mb-8">
      <a href="/en/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">Price Guide</span>
    </nav>

    <div class="mb-8">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-2">PRICE GUIDE</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">JDM Lure Price Guide</h1>
      <p class="text-sm text-text-mid mt-2">
        Browse {priceRanges.length} price ranges — find the right JDM lure for your budget
      </p>
    </div>

    <p class="text-sm text-gray-700 leading-relaxed mb-8">
      Japanese fishing lures span a wide price range, from budget-friendly metal jigs and soft plastics to premium handmade big baits.
      Explore lures by price range to find the best options for your fishing style and budget.
    </p>

    <div class="space-y-4">
      {priceRanges.map(range => (
        <a href={`/en/guide/price/${range.slug}/`} class="group block bg-white rounded-xl border border-gray-100 p-5 sm:p-6 shadow-card transition-all duration-200 hover:shadow-card-hover hover:border-accent">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-bold text-gray-900 group-hover:text-accent transition-colors mb-2">
                {range.nameEn ?? range.name}
              </h2>
              <p class="text-sm text-gray-600 leading-relaxed mb-3">
                {range.descriptionEn ?? range.description}
              </p>
              <div class="text-xs text-text-dim font-mono">
                {range.labelEn ?? range.label}
              </div>
            </div>
            <span class="text-accent text-lg shrink-0 group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
