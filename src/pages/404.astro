---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllLures } from '../lib/fetch-all-lures';
import { groupLuresBySeries } from '../lib/group-lures';
import { getTypeSlug } from '../lib/category-slugs';
import type { LureSeries } from '../lib/types';

// ─── 人気ルアー（カラー数上位10件）───
const lures = await fetchAllLures();
const allSeries = groupLuresBySeries(lures ?? []);

const popularLures = allSeries
  .filter(s => s.representative_image)
  .sort((a, b) => b.color_count - a.color_count)
  .slice(0, 10);

// ─── タイプ集計（上位8件）───
const typeMap = new Map<string, number>();
for (const s of allSeries) {
  if (!s.type) continue;
  typeMap.set(s.type, (typeMap.get(s.type) || 0) + 1);
}
const topTypes = [...typeMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([name, count]) => ({ name, slug: getTypeSlug(name), count }));

// ─── メーカー集計（上位8件）───
const makerMap = new Map<string, { name: string; slug: string; count: number }>();
for (const s of allSeries) {
  const e = makerMap.get(s.manufacturer_slug);
  if (e) e.count++;
  else makerMap.set(s.manufacturer_slug, { name: s.manufacturer, slug: s.manufacturer_slug, count: 1 });
}
const topMakers = [...makerMap.values()].sort((a, b) => b.count - a.count).slice(0, 8);
---

<BaseLayout
  title="ページが見つかりません - CAST/LOG"
  description="お探しのページが見つかりませんでした。"
  noindex={true}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- ─── ヘッダー ─── -->
    <div class="text-center mb-12">
      <p class="text-[80px] sm:text-[100px] font-bold text-gray-100 leading-none select-none font-mono">404</p>
      <h1 class="text-xl sm:text-2xl font-bold text-text mt-2 mb-3">
        ページが見つかりません
      </h1>
      <p class="text-text-mid text-sm">
        お探しのページは移動または削除された可能性があります。
      </p>
    </div>

    <!-- ─── 検索バー ─── -->
    <form
      action="/search/"
      method="get"
      class="max-w-md mx-auto mb-12"
    >
      <div class="relative">
        <input
          type="text"
          name="q"
          placeholder="ルアー名・メーカー名で検索..."
          class="w-full pl-4 pr-12 py-3 rounded-lg border border-border bg-white text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all"
        />
        <button
          type="submit"
          class="absolute right-1.5 top-1/2 -translate-y-1/2 p-2 rounded-md bg-accent text-white hover:bg-accent/90 transition-colors"
          aria-label="検索"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </div>
    </form>

    <!-- ─── クイックナビ ─── -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-lg mx-auto mb-16">
      <a href="/" class="flex flex-col items-center gap-1.5 p-4 rounded-lg border border-border hover:border-accent/30 hover:bg-surface transition-all duration-150">
        <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="text-xs font-medium text-text-mid">トップ</span>
      </a>
      <a href="/search/" class="flex flex-col items-center gap-1.5 p-4 rounded-lg border border-border hover:border-accent/30 hover:bg-surface transition-all duration-150">
        <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="text-xs font-medium text-text-mid">検索</span>
      </a>
      <a href="/type/" class="flex flex-col items-center gap-1.5 p-4 rounded-lg border border-border hover:border-accent/30 hover:bg-surface transition-all duration-150">
        <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
        <span class="text-xs font-medium text-text-mid">タイプ</span>
      </a>
      <a href="/maker/" class="flex flex-col items-center gap-1.5 p-4 rounded-lg border border-border hover:border-accent/30 hover:bg-surface transition-all duration-150">
        <svg class="w-5 h-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <span class="text-xs font-medium text-text-mid">メーカー</span>
      </a>
    </div>

    <!-- ─── 人気ルアー ─── -->
    <section class="mb-16">
      <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">POPULAR</p>
      <h2 class="text-[18px] font-bold text-text mb-6">カラー展開の多い人気ルアー</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        {popularLures.map(s => (
          <a href={`/${s.manufacturer_slug}/${s.slug}/`} class="group block">
            <div class="relative aspect-square rounded-lg overflow-hidden bg-surface border border-border group-hover:border-accent/30 transition-all duration-150">
              <img
                src={s.representative_image!}
                alt={`${s.manufacturer} ${s.name}`}
                class="w-full h-full object-contain p-3 transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="mt-2">
              <p class="text-[10px] text-text-dim uppercase tracking-wider font-mono">{s.manufacturer}</p>
              <p class="text-[13px] font-bold text-text line-clamp-1">{s.name}</p>
              <p class="text-[11px] text-text-dim font-mono">{s.color_count}カラー</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ─── タイプ一覧 ─── -->
    <section class="mb-16">
      <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">TYPE</p>
      <h2 class="text-[18px] font-bold text-text mb-4">ルアータイプから探す</h2>
      <div class="flex flex-wrap gap-2">
        {topTypes.map(t => (
          <a
            href={`/type/${t.slug}/`}
            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-md border border-border hover:border-accent/30 hover:bg-surface text-sm text-text-mid hover:text-text transition-all duration-150"
          >
            <span>{t.name}</span>
            <span class="text-[11px] text-text-faint font-mono">({t.count})</span>
          </a>
        ))}
        <a
          href="/type/"
          class="inline-flex items-center px-3 py-2 rounded-md text-sm text-accent hover:bg-accent/5 transition-all duration-150 font-medium"
        >
          すべて見る →
        </a>
      </div>
    </section>

    <!-- ─── メーカー一覧 ─── -->
    <section class="mb-12">
      <p class="font-mono text-[10px] font-bold text-accent tracking-[2px] uppercase mb-1">MAKER</p>
      <h2 class="text-[18px] font-bold text-text mb-4">メーカーから探す</h2>
      <div class="flex flex-wrap gap-2">
        {topMakers.map(m => (
          <a
            href={`/${m.slug}/`}
            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-md border border-border hover:border-accent/30 hover:bg-surface text-sm text-text-mid hover:text-text transition-all duration-150"
          >
            <span>{m.name}</span>
            <span class="text-[11px] text-text-faint font-mono">({m.count})</span>
          </a>
        ))}
        <a
          href="/maker/"
          class="inline-flex items-center px-3 py-2 rounded-md text-sm text-accent hover:bg-accent/5 transition-all duration-150 font-medium"
        >
          すべて見る →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
