---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ページが見つかりません - ルアーDB"
  description="お探しのページが見つかりませんでした。"
  noindex={true}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <p class="text-6xl font-bold text-gray-200 mb-4">404</p>
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3">
      ページが見つかりません
    </h1>
    <p class="text-text-secondary mb-8">
      お探しのページは移動または削除された可能性があります。
    </p>

    <!-- 検索バー -->
    <form
      action="/search/"
      method="get"
      class="max-w-md mx-auto mb-10"
    >
      <div class="relative">
        <input
          type="text"
          name="q"
          placeholder="ルアーを検索..."
          class="w-full pl-4 pr-12 py-3 rounded-full border border-gray-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
        />
        <button
          type="submit"
          class="absolute right-1.5 top-1/2 -translate-y-1/2 p-2 rounded-full bg-primary text-white hover:bg-primary/90 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </div>
    </form>

    <!-- カテゴリリンク -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-lg mx-auto">
      <a href="/" class="flex flex-col items-center gap-1.5 p-4 rounded-xl border border-gray-100 hover:border-primary/30 hover:bg-sky-50/50 transition-all">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="text-xs font-medium text-gray-700">トップ</span>
      </a>
      <a href="/type/" class="flex flex-col items-center gap-1.5 p-4 rounded-xl border border-gray-100 hover:border-primary/30 hover:bg-sky-50/50 transition-all">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
        <span class="text-xs font-medium text-gray-700">タイプ</span>
      </a>
      <a href="/maker/" class="flex flex-col items-center gap-1.5 p-4 rounded-xl border border-gray-100 hover:border-primary/30 hover:bg-sky-50/50 transition-all">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <span class="text-xs font-medium text-gray-700">メーカー</span>
      </a>
      <a href="/fish/" class="flex flex-col items-center gap-1.5 p-4 rounded-xl border border-gray-100 hover:border-primary/30 hover:bg-sky-50/50 transition-all">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
        <span class="text-xs font-medium text-gray-700">対象魚</span>
      </a>
    </div>
  </div>
</BaseLayout>
