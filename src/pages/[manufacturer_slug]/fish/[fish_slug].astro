---
/**
 * メーカー×対象魚組み合わせページ — /[manufacturer_slug]/fish/[fish_slug]/
 *
 * 特定メーカーの特定対象魚向けルアーを一覧表示し、
 * サマリー・タイプ分布・カラー系統分析・FAQ・内部リンクを提供する。
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTypeSlug, getFishSlug } from '../../../lib/category-slugs';
import { getManufacturerNameJa } from '../../../lib/manufacturer-names-ja';
import { getMakerFishPaths } from '../../../lib/paths/maker-fish-paths';
import type { MakerFishPathProps } from '../../../lib/paths/maker-fish-paths';
import type { LureSeries } from '../../../lib/types';
import type { ColorBreakdownEntry } from '../../../lib/color-categories';

export async function getStaticPaths() {
  return getMakerFishPaths();
}

const {
  manufacturerSlug,
  manufacturerName,
  manufacturerNameJa,
  fishName,
  fishSlug,
  series,
  totalCount,
  colorBreakdown,
  otherFish,
  otherMakers,
} = Astro.props as MakerFishPathProps;

// ─── ヘルパー ───

function fmtPrice(p: { min: number; max: number }): string {
  if (p.min <= 0 && p.max <= 0) return '\u2014';
  if (p.min === p.max) return `\u00A5${p.min.toLocaleString()}`;
  return `\u00A5${p.min.toLocaleString()}\u301C\u00A5${p.max.toLocaleString()}`;
}

function fmtRange(r: { min: number | null; max: number | null }, unit: string): string {
  if (r.min == null && r.max == null) return '\u2014';
  if (r.min === r.max) return `${r.min}${unit}`;
  if (r.min == null) return `\u301C${r.max}${unit}`;
  if (r.max == null) return `${r.min}${unit}\u301C`;
  return `${r.min}\u2013${r.max}${unit}`;
}

// ─── 集計 ───

const prices = series.flatMap(s => [s.price_range.min, s.price_range.max]).filter(p => p > 0);
const avgPrice = prices.length > 0 ? Math.round(prices.reduce((a, b) => a + b, 0) / prices.length) : 0;
const avgColorCount = Math.round(series.reduce((sum, s) => sum + s.color_count, 0) / totalCount);

// 主要タイプ（上位3）
const typeCount = new Map<string, number>();
for (const s of series) {
  if (s.type) {
    typeCount.set(s.type, (typeCount.get(s.type) || 0) + 1);
  }
}
const topTypes = [...typeCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([name]) => name);

// シリーズをカラー数降順ソート（代表性の高い順）
const sortedSeries = [...series].sort((a, b) => b.color_count - a.color_count);

// ─── 追加集計（コンテンツ濃度向上） ───

// 重量統計
const weights = series.flatMap(s => [s.weight_range.min, s.weight_range.max].filter(Boolean)) as number[];
const weightStats = weights.length > 0 ? {
  min: Math.min(...weights),
  max: Math.max(...weights),
  avg: Math.round(weights.reduce((a, b) => a + b, 0) / weights.length * 10) / 10,
} : null;

// サイズ統計
const lengths = series.flatMap(s => [s.length_range.min, s.length_range.max].filter(Boolean)) as number[];
const lengthStats = lengths.length > 0 ? {
  min: Math.min(...lengths),
  max: Math.max(...lengths),
  avg: Math.round(lengths.reduce((a, b) => a + b, 0) / lengths.length),
} : null;

// 価格帯分布（ヒストグラム用）
const priceBands = [
  { label: '〜¥1,000', min: 0, max: 1000, count: 0 },
  { label: '¥1,001〜2,000', min: 1001, max: 2000, count: 0 },
  { label: '¥2,001〜3,000', min: 2001, max: 3000, count: 0 },
  { label: '¥3,001〜5,000', min: 3001, max: 5000, count: 0 },
  { label: '¥5,001〜', min: 5001, max: 999999, count: 0 },
];
for (const s of series) {
  const p = s.price_range.min > 0 ? s.price_range.min : s.price_range.max;
  if (p > 0) {
    const band = priceBands.find(b => p >= b.min && p <= b.max);
    if (band) band.count++;
  }
}
const priceBandsFiltered = priceBands.filter(b => b.count > 0);
const maxBandCount = Math.max(...priceBandsFiltered.map(b => b.count), 1);

// タイプ別分布（バーチャート用）
const typeDistribution = [...typeCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({
    name,
    slug: getTypeSlug(name),
    count,
    pct: Math.round(count / totalCount * 100),
  }));
const maxTypePct = Math.max(...typeDistribution.map(t => t.pct), 1);

// ハイライト（最も○○なモデル）
const mostColors = sortedSeries[0];
const cheapest = [...series].filter(s => s.price_range.min > 0).sort((a, b) => a.price_range.min - b.price_range.min)[0];
const heaviest = [...series].filter(s => s.weight_range.max).sort((a, b) => (b.weight_range.max || 0) - (a.weight_range.max || 0))[0];
const lightest = [...series].filter(s => s.weight_range.min && s.weight_range.min > 0).sort((a, b) => (a.weight_range.min || 999) - (b.weight_range.min || 999))[0];

// 各モデルのdescription抜粋（先頭80文字）
const descSnippets = series
  .filter(s => s.description && s.description.length >= 30)
  .slice(0, 5)
  .map(s => ({ name: s.name, slug: s.slug, snippet: s.description!.slice(0, 80) + (s.description!.length > 80 ? '...' : '') }));

// ─── SEO ───

const currentYear = new Date().getFullYear();
const shouldNoindex = totalCount < 10;

const pageTitle = `${manufacturerNameJa}の${fishName}用ルアー一覧【全${totalCount}モデル】 | CAST/LOG`;
const pageDescription = `${manufacturerNameJa}（${manufacturerName}）の${fishName}用ルアー${totalCount}モデルを一覧比較。${topTypes.length > 0 ? `主なタイプは${topTypes.join('・')}。` : ''}価格・重量・カラー展開をチェックして最適な1本を見つけよう。`;

const canonicalPath = `/${manufacturerSlug}/fish/${fishSlug}/`;

// BreadcrumbList
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '\u30C8\u30C3\u30D7', item: 'https://www.castlog.xyz/' },
    { '@type': 'ListItem', position: 2, name: manufacturerNameJa, item: `https://www.castlog.xyz/${manufacturerSlug}/` },
    { '@type': 'ListItem', position: 3, name: `${fishName}用ルアー`, item: `https://www.castlog.xyz/${manufacturerSlug}/fish/${fishSlug}/` },
  ],
};

// ItemList
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${manufacturerNameJa}の${fishName}用ルアー一覧`,
  numberOfItems: totalCount,
  itemListElement: sortedSeries.slice(0, 30).map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://www.castlog.xyz/${s.manufacturer_slug}/${s.slug}/`,
    name: s.name,
    ...(s.representative_image ? { image: s.representative_image } : {}),
  })),
};

// FAQ構造化データ（5問: データ駆動で自動生成）
const faqEntries: { '@type': string; name: string; acceptedAnswer: { '@type': string; text: string } }[] = [];

// Q1: ラインナップ概要
faqEntries.push({
  '@type': 'Question',
  name: `${manufacturerNameJa}の${fishName}用ルアーは何モデルある？`,
  acceptedAnswer: {
    '@type': 'Answer',
    text: `${manufacturerNameJa}は${fishName}用ルアーを${totalCount}モデル展開している。${sortedSeries.slice(0, 3).map(s => s.name).join('、')}などが代表的なモデル。`,
  },
});

// Q2: 価格帯
if (prices.length > 0) {
  const minP = Math.min(...prices);
  const maxP = Math.max(...prices);
  faqEntries.push({
    '@type': 'Question',
    name: `${manufacturerNameJa}の${fishName}用ルアーの価格帯は？`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: `${manufacturerNameJa}の${fishName}用ルアーは\u00A5${minP.toLocaleString()}\u301C\u00A5${maxP.toLocaleString()}の価格帯で展開されている。平均価格は約\u00A5${avgPrice.toLocaleString()}。`,
    },
  });
}

// Q3: 主要タイプ
if (topTypes.length > 0) {
  faqEntries.push({
    '@type': 'Question',
    name: `${manufacturerNameJa}の${fishName}用ルアーにはどんなタイプがある？`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: `${manufacturerNameJa}の${fishName}用ルアーは${topTypes.join('、')}などのタイプが展開されている。${typeDistribution[0] ? `最も多いのは${typeDistribution[0].name}で${typeDistribution[0].count}モデル（${typeDistribution[0].pct}%）。` : ''}`,
    },
  });
}

// Q4: カラー展開
if (colorBreakdown.length > 0) {
  const topColors = colorBreakdown.filter(e => e.id !== 'other').slice(0, 3);
  faqEntries.push({
    '@type': 'Question',
    name: `${manufacturerNameJa}の${fishName}用ルアーのカラー展開の特徴は？`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: `${manufacturerNameJa}の${fishName}用ルアー全体では${topColors.map(c => `${c.label}（${c.pct}%）`).join('、')}が多い。1モデルあたり平均${avgColorCount}色展開。`,
    },
  });
}

// Q5: 選び方
faqEntries.push({
  '@type': 'Question',
  name: `${manufacturerNameJa}の${fishName}用ルアーの選び方は？`,
  acceptedAnswer: {
    '@type': 'Answer',
    text: `${manufacturerNameJa}の${fishName}用ルアーを選ぶ際は、ルアータイプ・使用するフィールド・重量・レンジを基準に比較するのがおすすめ。カラー展開の豊富さや価格帯もチェックしよう。`,
  },
});

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries,
};

const jsonLd = [breadcrumbLd, itemListLd, faqLd] as unknown as Record<string, unknown>;

// ─── データストーリー（濃化版：全てDBクエリ結果） ───

const storyP1 = `${manufacturerNameJa}の${fishName}用ルアーは全${totalCount}モデル。${topTypes.length > 0 ? `主なタイプは${topTypes.join('・')}。` : ''}${mostColors ? `カラー展開が最も豊富なのは${mostColors.name}（${mostColors.color_count}色）。` : ''}1モデルあたり平均${avgColorCount}色を展開している。`;

const storyP2Parts: string[] = [];
if (avgPrice > 0 && prices.length > 0) {
  const minP = Math.min(...prices);
  const maxP = Math.max(...prices);
  const topBand = [...priceBandsFiltered].sort((a, b) => b.count - a.count)[0];
  storyP2Parts.push(`価格帯は¥${minP.toLocaleString()}〜¥${maxP.toLocaleString()}${topBand ? `で、${topBand.label}の価格帯に${topBand.count}モデル（${Math.round(topBand.count / totalCount * 100)}%）が集中` : ''}。平均価格は¥${avgPrice.toLocaleString()}`);
}
if (cheapest && cheapest.price_range.min > 0) {
  storyP2Parts.push(`最も手頃なのは${cheapest.name}（¥${cheapest.price_range.min.toLocaleString()}〜）`);
}
const storyP2 = storyP2Parts.join('。') + '。';

const storyP3Parts: string[] = [];
if (weightStats) storyP3Parts.push(`重量は${weightStats.min}g〜${weightStats.max}gの範囲で平均${weightStats.avg}g`);
if (lengthStats) storyP3Parts.push(`全長は${lengthStats.min}mm〜${lengthStats.max}mm`);
if (lightest && heaviest && lightest.slug !== heaviest.slug) {
  storyP3Parts.push(`最軽量は${lightest.name}（${lightest.weight_range.min}g）、最重量は${heaviest.name}（${heaviest.weight_range.max}g）`);
}
if (typeDistribution.length > 1) {
  storyP3Parts.push(`タイプ構成は${typeDistribution.slice(0, 3).map(t => `${t.name}${t.pct}%`).join('、')}`);
}
const storyP3 = storyP3Parts.length > 0 ? storyP3Parts.join('。') + '。' : '';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPath}
  noindex={shouldNoindex}
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors duration-150">トップ</a>
      <span class="mx-2">/</span>
      <a href={`/${manufacturerSlug}/`} class="hover:text-accent transition-colors duration-150">{manufacturerNameJa}</a>
      <span class="mx-2">/</span>
      <span class="text-text">{fishName}用ルアー</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-6">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-1">MAKER &times; TARGET FISH</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-text">
        {manufacturerNameJa}の{fishName}用ルアー一覧<span class="text-lg sm:text-xl text-text-mid font-normal ml-2">全{totalCount}モデル</span>
      </h1>
    </div>

    <!-- サマリーカード -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-lg border border-border p-4">
        <p class="text-xs font-mono text-text-dim uppercase tracking-wider mb-1">MODELS</p>
        <p class="text-2xl font-bold text-text">{totalCount}</p>
        <p class="text-xs text-text-mid">モデル数</p>
      </div>
      <div class="bg-white rounded-lg border border-border p-4">
        <p class="text-xs font-mono text-text-dim uppercase tracking-wider mb-1">AVG PRICE</p>
        <p class="text-2xl font-bold text-text">{avgPrice > 0 ? `\u00A5${avgPrice.toLocaleString()}` : '\u2014'}</p>
        <p class="text-xs text-text-mid">平均価格</p>
      </div>
      <div class="bg-white rounded-lg border border-border p-4">
        <p class="text-xs font-mono text-text-dim uppercase tracking-wider mb-1">AVG COLORS</p>
        <p class="text-2xl font-bold text-text">{avgColorCount}<span class="text-base font-normal text-text-mid">色</span></p>
        <p class="text-xs text-text-mid">平均カラー数</p>
      </div>
      <div class="bg-white rounded-lg border border-border p-4">
        <p class="text-xs font-mono text-text-dim uppercase tracking-wider mb-1">MAIN TYPE</p>
        <p class="text-sm font-bold text-text leading-tight">{topTypes.length > 0 ? topTypes.join('・') : '\u2014'}</p>
        <p class="text-xs text-text-mid mt-1">主要タイプ</p>
      </div>
    </div>

    <!-- データストーリー -->
    <div class="bg-white rounded-lg border border-border p-5 sm:p-6 mb-8">
      <p class="text-sm text-text-mid leading-relaxed">{storyP1}</p>
      <p class="text-sm text-text-mid leading-relaxed mt-2">{storyP2}</p>
      <p class="text-sm text-text-mid leading-relaxed mt-2">{storyP3}</p>
    </div>

    <!-- ハイライト（最も○○なモデル） -->
    {(mostColors || cheapest || heaviest || lightest) && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-text mb-4">データで見る注目モデル</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {mostColors && (
            <a href={`/${mostColors.manufacturer_slug}/${mostColors.slug}/`} class="bg-white rounded-lg border border-border p-4 hover:border-accent transition-colors group">
              <p class="text-xs font-mono text-accent uppercase mb-1">MOST COLORS</p>
              <p class="text-sm font-bold text-text group-hover:text-accent transition-colors">{mostColors.name}</p>
              <p class="text-2xl font-bold text-text mt-1">{mostColors.color_count}<span class="text-sm text-text-mid font-normal">色</span></p>
            </a>
          )}
          {cheapest && cheapest.price_range.min > 0 && (
            <a href={`/${cheapest.manufacturer_slug}/${cheapest.slug}/`} class="bg-white rounded-lg border border-border p-4 hover:border-accent transition-colors group">
              <p class="text-xs font-mono text-accent uppercase mb-1">LOWEST PRICE</p>
              <p class="text-sm font-bold text-text group-hover:text-accent transition-colors">{cheapest.name}</p>
              <p class="text-2xl font-bold text-text mt-1">¥{cheapest.price_range.min.toLocaleString()}<span class="text-sm text-text-mid font-normal">〜</span></p>
            </a>
          )}
          {lightest && lightest.weight_range.min && lightest.weight_range.min > 0 && (
            <a href={`/${lightest.manufacturer_slug}/${lightest.slug}/`} class="bg-white rounded-lg border border-border p-4 hover:border-accent transition-colors group">
              <p class="text-xs font-mono text-accent uppercase mb-1">LIGHTEST</p>
              <p class="text-sm font-bold text-text group-hover:text-accent transition-colors">{lightest.name}</p>
              <p class="text-2xl font-bold text-text mt-1">{lightest.weight_range.min}<span class="text-sm text-text-mid font-normal">g</span></p>
            </a>
          )}
          {heaviest && heaviest.weight_range.max && (
            <a href={`/${heaviest.manufacturer_slug}/${heaviest.slug}/`} class="bg-white rounded-lg border border-border p-4 hover:border-accent transition-colors group">
              <p class="text-xs font-mono text-accent uppercase mb-1">HEAVIEST</p>
              <p class="text-sm font-bold text-text group-hover:text-accent transition-colors">{heaviest.name}</p>
              <p class="text-2xl font-bold text-text mt-1">{heaviest.weight_range.max}<span class="text-sm text-text-mid font-normal">g</span></p>
            </a>
          )}
        </div>
      </section>
    )}

    <!-- タイプ別分布バー -->
    {typeDistribution.length > 1 && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-text mb-4">タイプ別分布</h2>
        <div class="bg-white rounded-lg border border-border p-5">
          <div class="space-y-2">
            {typeDistribution.map(t => (
              <div class="flex items-center gap-3">
                <a href={`/${manufacturerSlug}/type/${t.slug}/`} class="w-28 text-xs text-text-mid shrink-0 truncate hover:text-accent transition-colors duration-150">{t.name}</a>
                <div class="flex-1 bg-gray-100 rounded h-5 overflow-hidden">
                  <div
                    style={`width:${Math.max((t.pct / maxTypePct) * 100, 5)}%`}
                    class="h-5 rounded bg-accent/70 transition-all duration-150 flex items-center justify-end pr-1"
                  >
                    {t.count >= 3 && <span class="text-[10px] text-white font-mono">{t.count}</span>}
                  </div>
                </div>
                <span class="text-xs text-text-dim w-16 text-right shrink-0 font-mono">{t.count}モデル</span>
                <span class="text-xs text-text-faint w-10 text-right shrink-0 font-mono">{t.pct}%</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 価格帯分布 -->
    {priceBandsFiltered.length > 1 && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-text mb-4">価格帯分布</h2>
        <div class="bg-white rounded-lg border border-border p-5">
          <div class="space-y-2">
            {priceBandsFiltered.map(band => (
              <div class="flex items-center gap-3">
                <span class="w-28 text-xs text-text-mid shrink-0 font-mono">{band.label}</span>
                <div class="flex-1 bg-gray-100 rounded h-5 overflow-hidden">
                  <div
                    style={`width:${Math.max((band.count / maxBandCount) * 100, 5)}%`}
                    class="h-5 rounded bg-accent/70 transition-all duration-150 flex items-center justify-end pr-1"
                  >
                    {band.count >= 3 && <span class="text-[10px] text-white font-mono">{band.count}</span>}
                  </div>
                </div>
                <span class="text-xs text-text-dim w-16 text-right shrink-0 font-mono">{band.count}モデル</span>
                <span class="text-xs text-text-faint w-10 text-right shrink-0 font-mono">{Math.round(band.count / totalCount * 100)}%</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 代表モデルの公式説明 -->
    {descSnippets.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-text mb-4">代表モデルの特徴</h2>
        <div class="space-y-3">
          {descSnippets.map(d => (
            <a href={`/${manufacturerSlug}/${d.slug}/`} class="block bg-white rounded-lg border border-border p-4 hover:border-accent transition-colors group">
              <p class="text-sm font-bold text-text group-hover:text-accent transition-colors mb-1">{d.name}</p>
              <p class="text-xs text-text-mid leading-relaxed">{d.snippet}</p>
            </a>
          ))}
        </div>
        <p class="text-xs text-text-faint mt-2">※ 各メーカー公式サイトの商品説明より抜粋</p>
      </section>
    )}

    <!-- 商品一覧テーブル -->
    <section class="mb-12">
      <h2 class="text-lg font-bold text-text mb-4">全{totalCount}モデル一覧</h2>
      <div class="overflow-x-auto -mx-4 px-4">
        <table class="w-full text-sm border-collapse min-w-[640px]">
          <thead>
            <tr class="border-b-2 border-border">
              <th class="py-3 pr-4 text-left text-xs font-semibold text-text-dim">商品名</th>
              <th class="py-3 px-2 text-left text-xs font-semibold text-text-dim">タイプ</th>
              <th class="py-3 px-2 text-right text-xs font-semibold text-text-dim">価格帯</th>
              <th class="py-3 px-2 text-right text-xs font-semibold text-text-dim">重量</th>
              <th class="py-3 px-2 text-right text-xs font-semibold text-text-dim">カラー数</th>
              <th class="py-3 pl-2 text-right text-xs font-semibold text-text-dim"></th>
            </tr>
          </thead>
          <tbody>
            {sortedSeries.map((s, i) => (
              <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-surface/50' : ''} hover:bg-surface transition-colors duration-150`}>
                <td class="py-3 pr-4">
                  <a href={`/${s.manufacturer_slug}/${s.slug}/`} class="text-sm font-semibold text-text hover:text-accent transition-colors duration-150">
                    {s.name}
                  </a>
                </td>
                <td class="py-3 px-2 text-xs text-text-mid whitespace-nowrap">{s.type || '\u2014'}</td>
                <td class="py-3 px-2 text-right text-sm text-text-mid font-mono whitespace-nowrap">{fmtPrice(s.price_range)}</td>
                <td class="py-3 px-2 text-right text-sm text-text-mid font-mono whitespace-nowrap">{fmtRange(s.weight_range, 'g')}</td>
                <td class="py-3 px-2 text-right text-sm text-text-mid font-mono">{s.color_count}色</td>
                <td class="py-3 pl-2 text-right">
                  <a href={`/${s.manufacturer_slug}/${s.slug}/`} class="text-xs text-accent hover:underline whitespace-nowrap">詳細→</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- カラー系統分析バー -->
    {colorBreakdown.filter(e => e.id !== 'other').length > 0 && (
      <section class="mb-12">
        <h2 class="text-lg font-bold text-text mb-4">カラー系統分析</h2>
        <p class="text-sm text-text-mid mb-4">
          {manufacturerNameJa}の{fishName}用ルアー全{totalCount}モデルのカラーラインナップを系統別に集計。
        </p>
        <div class="bg-white rounded-lg border border-border p-5">
          {/* 横バーチャート */}
          <div class="space-y-2">
            {colorBreakdown.filter(e => e.id !== 'other').map(cat => {
              const maxPct = Math.max(...colorBreakdown.filter(e => e.id !== 'other').map(e => e.pct), 1);
              return (
                <div class="flex items-center gap-3">
                  <span class="w-24 text-xs text-text-mid shrink-0 truncate">{cat.label}</span>
                  <div class="flex-1 bg-gray-100 rounded h-4 overflow-hidden">
                    <div
                      style={`width:${Math.max((cat.pct / maxPct) * 100, 3)}%;background-color:${cat.cssColor}`}
                      class="h-4 rounded transition-all duration-150"
                    />
                  </div>
                  <span class="text-xs text-text-dim w-12 text-right shrink-0 font-mono">{cat.pct}%</span>
                  <span class="text-xs text-text-dim w-10 text-right shrink-0 font-mono">{cat.count}色</span>
                </div>
              );
            })}
          </div>
          {colorBreakdown.some(e => e.id === 'other' && e.count > 0) && (
            <div class="mt-2 pt-2 border-t border-gray-100">
              <span class="text-xs text-text-faint">その他: {colorBreakdown.find(e => e.id === 'other')?.count}色（{colorBreakdown.find(e => e.id === 'other')?.pct}%）</span>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- よくある質問 -->
    <section class="mb-12">
      <h2 class="text-lg font-bold text-text mb-4">よくある質問</h2>
      <div class="space-y-2">
        {faqEntries.map((faq, i) => (
          <details class="group bg-white rounded-lg border border-border overflow-hidden" open={i === 0}>
            <summary class="flex items-center justify-between px-4 py-3 cursor-pointer hover:bg-surface transition-colors duration-150">
              <span class="text-sm font-semibold text-text pr-4">{faq.name}</span>
              <svg class="w-4 h-4 text-text-dim shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-4 pb-3 text-sm text-text-mid leading-relaxed border-t border-gray-50">
              {faq.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- 内部リンク -->
    <section class="mt-12 pt-8 border-t border-border">
      <h2 class="text-lg font-bold text-text mb-4">関連ページ</h2>

      {/* 同メーカーの他対象魚 */}
      {otherFish.length > 0 && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-text-mid mb-3">{manufacturerNameJa}の他の対象魚</h3>
          <div class="flex flex-wrap gap-2">
            {otherFish.slice(0, 10).map(f => (
              <a
                href={`/${manufacturerSlug}/fish/${f.fishSlug}/`}
                class="px-3 py-1.5 bg-white text-text-mid rounded border border-border text-xs hover:border-accent hover:text-accent transition-colors duration-150"
              >
                {f.fishName}（{f.count}）
              </a>
            ))}
          </div>
        </div>
      )}

      {/* 同対象魚の他メーカー */}
      {otherMakers.length > 0 && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-text-mid mb-3">{fishName}用ルアーの他メーカー</h3>
          <div class="flex flex-wrap gap-2">
            {otherMakers.map(m => (
              <a
                href={`/${m.manufacturerSlug}/fish/${fishSlug}/`}
                class="px-3 py-1.5 bg-white text-text-mid rounded border border-border text-xs hover:border-accent hover:text-accent transition-colors duration-150"
              >
                {getManufacturerNameJa(m.manufacturerSlug, m.manufacturerName)}（{m.count}）
              </a>
            ))}
          </div>
        </div>
      )}

      {/* ナビゲーションボタン */}
      <div class="flex flex-wrap gap-3 mt-4">
        <a href={`/${manufacturerSlug}/`} class="px-4 py-2 bg-accent text-white rounded text-sm font-medium hover:opacity-90 transition-opacity duration-150">
          {manufacturerNameJa}の全ルアー一覧→
        </a>
        <a href={`/fish/${fishSlug}/`} class="px-4 py-2 bg-white text-text-mid rounded text-sm border border-border hover:border-accent hover:text-accent transition-colors duration-150">
          {fishName}用ルアー一覧
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
