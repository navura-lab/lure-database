---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LureCard from '../../components/LureCard.astro';
import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../../lib/category-slugs';
import { manufacturerDescriptions, manufacturerOfficialUrls } from '../../data/manufacturer-descriptions';
import { guideArticles } from '../../data/guides';
import { contentArticles } from '../../data/articles/_index.js';
import type { LureSeries } from '../../lib/types';

export async function getStaticPaths() {
  const lures = await fetchAllLures();

  const allSeries = groupLuresBySeries(lures ?? []);

  // メーカースラグでグルーピング
  const manufacturerMap = new Map<string, { manufacturer: string; series: LureSeries[] }>();
  for (const s of allSeries) {
    const existing = manufacturerMap.get(s.manufacturer_slug);
    if (existing) {
      existing.series.push(s);
    } else {
      manufacturerMap.set(s.manufacturer_slug, {
        manufacturer: s.manufacturer,
        series: [s],
      });
    }
  }

  // 各メーカーの対象魚・タイプを集計（関連メーカー算出用）
  const manufacturerProfiles = new Map<string, { fish: Set<string>; types: Set<string>; name: string; count: number }>();
  for (const [slug, data] of manufacturerMap) {
    const fish = new Set<string>();
    const types = new Set<string>();
    for (const s of data.series) {
      if (s.type) types.add(s.type);
      for (const f of s.target_fish) fish.add(f);
    }
    manufacturerProfiles.set(slug, { fish, types, name: data.manufacturer, count: data.series.length });
  }

  return [...manufacturerMap.entries()].map(([slug, data]) => {
    // 関連メーカー: 対象魚・タイプの重複度でスコアリング
    const profile = manufacturerProfiles.get(slug)!;
    const scored: { slug: string; name: string; count: number; score: number }[] = [];
    for (const [otherSlug, otherProfile] of manufacturerProfiles) {
      if (otherSlug === slug) continue;
      let score = 0;
      for (const f of profile.fish) { if (otherProfile.fish.has(f)) score += 2; }
      for (const t of profile.types) { if (otherProfile.types.has(t)) score += 1; }
      if (score > 0) scored.push({ slug: otherSlug, name: otherProfile.name, count: otherProfile.count, score });
    }
    scored.sort((a, b) => b.score - a.score || b.count - a.count);
    const relatedManufacturers = scored.slice(0, 8).map(({ slug, name, count }) => ({ slug, name, count }));

    return {
      params: { manufacturer_slug: slug },
      props: { manufacturer: data.manufacturer, series: data.series, relatedManufacturers },
    };
  });
}

const { manufacturer, series, relatedManufacturers } = Astro.props as {
  manufacturer: string;
  series: LureSeries[];
  relatedManufacturers: { slug: string; name: string; count: number }[];
};

const manufacturerSlug = Astro.params.manufacturer_slug as string;
const editorialText = manufacturerDescriptions[manufacturerSlug] ?? '';
const officialUrl = manufacturerOfficialUrls[manufacturerSlug] ?? null;

// ─── 集計データの算出 ───

const totalColors = series.reduce((sum, s) => sum + s.color_count, 0);

// カテゴリ別シリーズ数（多い順）
const typeCounts = new Map<string, number>();
for (const s of series) {
  if (s.type) typeCounts.set(s.type, (typeCounts.get(s.type) || 0) + 1);
}
const typeBreakdown = [...typeCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([type, count]) => ({ type, count }));

// 対象魚リスト（出現回数順、上位10件）
const fishCounts = new Map<string, number>();
for (const s of series) {
  for (const fish of s.target_fish) {
    fishCounts.set(fish, (fishCounts.get(fish) || 0) + 1);
  }
}
const allTargetFish = [...fishCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([fish]) => fish)
  .slice(0, 12);

// 価格帯（0を除外）
const prices = series
  .flatMap(s => [s.price_range.min, s.price_range.max])
  .filter(p => p > 0);
const priceRange = prices.length > 0
  ? { min: Math.min(...prices), max: Math.max(...prices) }
  : null;

// 重量帯（0を除外）
const weights = series
  .flatMap(s => [s.weight_range.min, s.weight_range.max])
  .filter(w => w > 0);
const weightRange = weights.length > 0
  ? { min: Math.min(...weights), max: Math.max(...weights) }
  : null;

// 全長帯（0を除外）
const lengths = series
  .flatMap(s => [s.length_range.min, s.length_range.max])
  .filter(l => l > 0);
const lengthRange = lengths.length > 0
  ? { min: Math.min(...lengths), max: Math.max(...lengths) }
  : null;

// ─── SEO: meta description（リッチ化）───

const topTypes = typeBreakdown.slice(0, 3).map(t => t.type).join('、');
const topFish = allTargetFish.slice(0, 3).join('・');
const priceText = priceRange ? `価格¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}` : '';

const pageDescription = [
  `${manufacturer}のルアー全${series.length}シリーズ・${totalColors}カラーを一覧で掲載。`,
  topTypes ? `${topTypes}等を展開。` : '',
  topFish ? `${topFish}向けルアーが充実。` : '',
  priceText ? `${priceText}。` : '',
  '各モデルのスペック・カラーバリエーション・価格を比較できる。',
].filter(Boolean).join('');

// ─── SEO: 概要テキスト（ページ内表示用）───

const summaryParts: string[] = [];
summaryParts.push(`${manufacturer}は${series.length}シリーズ・${totalColors}カラーのルアーをラインナップ`);
if (typeBreakdown.length > 0) {
  const typeNames = typeBreakdown.slice(0, 5).map(t => t.type).join('、');
  summaryParts.push(`${typeNames}など${typeBreakdown.length > 5 ? `${typeBreakdown.length}種類` : ''}のルアータイプを展開`);
}
if (allTargetFish.length > 0) {
  const fishNames = allTargetFish.slice(0, 5).join('・');
  summaryParts.push(`${fishNames}などをターゲットとする`);
}
if (priceRange) {
  summaryParts.push(`価格帯は¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}`);
}
const summaryText = summaryParts.join('。') + '。';

// ─── 代表シリーズ TOP 5（カラー展開数上位）───

const topSeries = [...series]
  .sort((a, b) => b.color_count - a.color_count)
  .slice(0, 5);

// ─── E-E-A-T 出典表記用 ───

const now = new Date();
const eatYear = now.getFullYear();
const eatMonth = now.getMonth() + 1;

// ─── 関連特集記事（魚種 or タイプが一致）───

const makerFish = new Set(series.flatMap(s => Array.isArray(s.target_fish) ? s.target_fish : []));
const makerTypes = new Set(series.map(s => s.type));

const relatedContentArticles = contentArticles
  .filter(a =>
    a.targetFish.some(f => makerFish.has(f)) ||
    a.targetTypes.some(t => makerTypes.has(t))
  )
  .slice(0, 5);

// ─── FAQ JSON-LD（リッチスニペット用）───

const faqItems: { q: string; a: string }[] = [];

if (typeBreakdown.length > 0) {
  const typeNames = typeBreakdown.slice(0, 5).map(t => `${t.type}（${t.count}シリーズ）`).join('、');
  faqItems.push({
    q: `${manufacturer}のルアーにはどんなタイプがある？`,
    a: `${manufacturer}は${typeBreakdown.length}タイプのルアーを展開。${typeNames}などがラインナップされている。`,
  });
}

if (allTargetFish.length > 0) {
  const fishNames = allTargetFish.slice(0, 6).join('、');
  faqItems.push({
    q: `${manufacturer}のルアーで狙える魚種は？`,
    a: `${manufacturer}のルアーは${fishNames}などをターゲットとしている。${series.length}シリーズから狙いたい魚種に合ったルアーを選べる。`,
  });
}

if (priceRange) {
  faqItems.push({
    q: `${manufacturer}のルアーの価格帯は？`,
    a: `${manufacturer}のルアーは¥${priceRange.min.toLocaleString()}〜¥${priceRange.max.toLocaleString()}の価格帯。${totalColors}カラーの豊富なバリエーションから選択できる。`,
  });
}

// 人気ルアー FAQ
if (topSeries.length > 0) {
  const top3Names = topSeries.slice(0, 3).map(s => `${s.name}（${s.color_count}カラー）`).join('、');
  faqItems.push({
    q: `${manufacturer}で人気のルアーは？`,
    a: `${manufacturer}でカラー展開数が多い人気シリーズは${top3Names}。カラーバリエーションの豊富さはフィールドや状況に応じた使い分けに役立つ。`,
  });
}

// 最新ルアー FAQ
const latestSeries = [...series]
  .filter(s => s.release_year != null)
  .sort((a, b) => (b.release_year ?? 0) - (a.release_year ?? 0))
  .slice(0, 3);
if (latestSeries.length > 0) {
  const latestNames = latestSeries.map(s => `${s.name}（${s.release_year}年）`).join('、');
  faqItems.push({
    q: `${manufacturer}の最新ルアーは？`,
    a: `${manufacturer}の最新モデルは${latestNames}。最新のルアーテクノロジーを搭載したラインナップとなっている。`,
  });
}

const faqLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
} : null;

// ─── JSON-LD: CollectionPage + BreadcrumbList ───

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${manufacturer} ルアー一覧`,
  url: `https://www.castlog.xyz/${manufacturerSlug}/`,
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: series.length,
    itemListElement: series.slice(0, 50).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.castlog.xyz/${s.manufacturer_slug}/${s.slug}/`,
      name: s.name,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'トップ',
      item: 'https://www.castlog.xyz/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'メーカー一覧',
      item: 'https://www.castlog.xyz/maker/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: manufacturer,
      item: `https://www.castlog.xyz/${manufacturerSlug}/`,
    },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])] as unknown as Record<string, unknown>;

// ─── 関連ガイド・ランキングリンク（内部リンク強化）───

const relatedGuides = guideArticles.filter(g =>
  g.targetFish.some(f => allTargetFish.includes(f))
).slice(0, 4);

// 魚種×タイプの組み合わせでランキングページURLを生成
const relatedRankings: { slug: string; label: string }[] = [];
const fishForRanking = allTargetFish.slice(0, 4);
const typesForRanking = typeBreakdown.slice(0, 4);
for (const fish of fishForRanking) {
  for (const t of typesForRanking) {
    const slug = `${getFishSlug(fish)}-${getTypeSlug(t.type)}`;
    relatedRankings.push({ slug, label: `${fish}×${t.type}` });
  }
}

// スペックサマリー表示用
const specItems: { label: string; value: string }[] = [];
if (priceRange) {
  specItems.push({ label: '価格帯', value: `¥${priceRange.min.toLocaleString()} 〜 ¥${priceRange.max.toLocaleString()}` });
}
if (weightRange) {
  specItems.push({ label: '重さ', value: `${weightRange.min}g 〜 ${weightRange.max}g` });
}
if (lengthRange) {
  specItems.push({ label: '全長', value: `${lengthRange.min}mm 〜 ${lengthRange.max}mm` });
}
specItems.push({ label: 'カラー数', value: `${totalColors}色` });

// ─── SEO: title タグ（「メーカー名 ルアー 一覧」パターン最適化）───

const topTypeNames = typeBreakdown.slice(0, 2).map(t => t.type).join('・');
const titleParts = [
  `${manufacturer} ルアー 一覧 全${series.length}シリーズ`,
  topTypeNames || '',
];
const pageTitle = titleParts.filter(Boolean).join(' | ') + ' - CAST/LOG';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath={`/${manufacturerSlug}/`} jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href="/maker/" class="hover:text-accent transition-colors">メーカー一覧</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{manufacturer}</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{manufacturer}</h1>
      <p class="text-sm text-text-mid mt-1">
        {series.length}シリーズ・{totalColors}カラー
      </p>
    </div>

    <!-- メーカー概要セクション -->
    <div class="bg-white rounded-xl border border-gray-100 p-5 sm:p-6 mb-8 shadow-sm">

      <!-- ① 概要テキスト -->
      <p class="text-sm text-gray-700 leading-relaxed mb-2">
        {summaryText}
      </p>
      <p class="text-xs text-text-dim mb-4">
        出典: CAST/LOGルアーデータベース（{eatYear}年{eatMonth}月更新）
      </p>

      {editorialText && (
        <p class="text-sm text-gray-600 leading-relaxed mb-5 border-l-2 border-slate-200 pl-4">
          {editorialText}
        </p>
      )}

      {officialUrl && (
        <p class="text-sm mb-5">
          <a href={officialUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-accent hover:underline">
            {manufacturer} 公式サイト
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </p>
      )}

      <!-- ② カテゴリ別シリーズ数 -->
      {typeBreakdown.length > 0 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">ルアータイプ</h2>
          <div class="flex flex-wrap gap-2">
            {typeBreakdown.map(t => (
              <a href={`/type/${getTypeSlug(t.type)}/`} class="inline-flex items-center gap-1 px-3 py-1 bg-accent-bg text-accent rounded-full text-xs font-medium border border-accent-bg hover:bg-accent-bg transition-colors">
                {t.type}
                <span class="text-accent">{t.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- ②-b カテゴリ分布チャート -->
      {typeBreakdown.length > 2 && (
        <div class="mb-5">
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">カテゴリ分布</h2>
          <div class="space-y-1.5">
            {typeBreakdown.slice(0, 8).map(t => {
              const pct = Math.round((t.count / series.length) * 100);
              return (
                <div class="flex items-center gap-2">
                  <span class="w-24 text-xs text-gray-600 shrink-0 truncate">{t.type}</span>
                  <div class="flex-1 bg-gray-100 rounded h-3 overflow-hidden">
                    <div class="h-3 bg-accent/60 rounded" style={`width:${Math.max(pct, 4)}%`} />
                  </div>
                  <span class="text-xs text-gray-500 w-8 text-right shrink-0">{t.count}</span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <!-- ③ スペックサマリー -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
        {specItems.map(item => (
          <div>
            <p class="text-xs text-text-dim">{item.label}</p>
            <p class="text-sm font-semibold text-gray-900">{item.value}</p>
          </div>
        ))}
      </div>

      <!-- ④ 対象魚タグ -->
      {allTargetFish.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold text-text-dim uppercase tracking-wider mb-2">対象魚</h2>
          <div class="flex flex-wrap gap-1.5">
            {allTargetFish.map(fish => (
              <a href={`/fish/${getFishSlug(fish)}/`} class="px-2.5 py-1 bg-gray-50 text-gray-700 rounded-full text-xs border border-gray-100 hover:bg-gray-100 transition-colors">
                {fish}
              </a>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- 代表シリーズ TOP 5 -->
    {topSeries.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-gray-900 mb-4">代表シリーズ TOP 5</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
          {topSeries.map(s => (
            <LureCard series={s} isNew={false} priority={true} />
          ))}
        </div>
      </section>
    )}

    <!-- シリーズ見出し + 検索・ソート -->
    <div class="flex flex-col gap-4 mb-6">
      <h2 class="text-lg font-bold text-gray-900">全{series.length}シリーズ</h2>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
        <!-- ソート -->
        <div class="flex gap-2">
          <button
            id="sort-name"
            class="px-3 py-1.5 text-xs font-mono rounded border border-accent bg-accent text-white transition-colors"
            data-active="true"
          >
            50音順
          </button>
          <button
            id="sort-colors"
            class="px-3 py-1.5 text-xs font-mono rounded border border-border text-text-mid hover:border-accent hover:text-accent transition-colors"
            data-active="false"
          >
            カラー数順
          </button>
        </div>

        <!-- 検索 -->
        <div class="relative flex-1 max-w-xs">
          <input
            id="series-search"
            type="text"
            placeholder="シリーズ名を検索..."
            class="w-full pl-8 pr-3 py-1.5 text-sm border border-border rounded focus:outline-none focus:border-accent transition-colors"
          />
          <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-text-dim" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- タイプフィルター -->
      {typeBreakdown.length > 1 && (
        <div class="flex flex-wrap gap-1.5" id="type-filter">
          <button
            class="type-filter-btn px-2.5 py-1 text-xs font-mono rounded-full border border-accent bg-accent text-white transition-colors"
            data-type="all"
            data-active="true"
          >
            すべて {series.length}
          </button>
          {typeBreakdown.map(t => (
            <button
              class="type-filter-btn px-2.5 py-1 text-xs font-mono rounded-full border border-border text-text-mid hover:border-accent hover:text-accent transition-colors"
              data-type={t.type}
              data-active="false"
            >
              {t.type} {t.count}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- 商品グリッド -->
    <div id="series-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {series.map(s => (
        <LureCard series={s} isNew={false} />
      ))}
    </div>

    <!-- 検索結果なし -->
    <div id="no-results" class="hidden text-center py-12 text-text-dim">
      <p class="text-lg">該当するシリーズが見つかりません</p>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const sortNameBtn = document.getElementById('sort-name');
        const sortColorsBtn = document.getElementById('sort-colors');
        const searchInput = document.getElementById('series-search');
        const seriesGrid = document.getElementById('series-grid');
        const noResults = document.getElementById('no-results');
        const typeFilterBtns = document.querySelectorAll('.type-filter-btn');
        let activeType = 'all';

        // ソート切替
        function setActiveSort(activeBtn, inactiveBtn) {
          activeBtn.classList.add('bg-accent', 'text-white', 'border-accent');
          activeBtn.classList.remove('text-text-mid', 'border-border');
          activeBtn.dataset.active = 'true';
          inactiveBtn.classList.remove('bg-accent', 'text-white', 'border-accent');
          inactiveBtn.classList.add('text-text-mid', 'border-border');
          inactiveBtn.dataset.active = 'false';
        }

        function getCards() {
          return [...seriesGrid.querySelectorAll('[data-series]')];
        }

        function sortCards(compareFn) {
          const cards = getCards();
          cards.sort(compareFn);
          cards.forEach(c => seriesGrid.appendChild(c));
          applyFilters();
        }

        sortNameBtn?.addEventListener('click', () => {
          if (sortNameBtn.dataset.active === 'true') return;
          setActiveSort(sortNameBtn, sortColorsBtn);
          sortCards((a, b) => {
            const aData = JSON.parse(a.dataset.series);
            const bData = JSON.parse(b.dataset.series);
            return aData.name.localeCompare(bData.name, 'ja');
          });
        });

        sortColorsBtn?.addEventListener('click', () => {
          if (sortColorsBtn.dataset.active === 'true') return;
          setActiveSort(sortColorsBtn, sortNameBtn);
          sortCards((a, b) => {
            const aColors = parseInt(a.querySelector('.text-text-mid')?.textContent?.match(/(\d+)カラー/)?.[1] || '0');
            const bColors = parseInt(b.querySelector('.text-text-mid')?.textContent?.match(/(\d+)カラー/)?.[1] || '0');
            return bColors - aColors;
          });
        });

        // タイプフィルター
        typeFilterBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            typeFilterBtns.forEach(b => {
              b.classList.remove('bg-accent', 'text-white', 'border-accent');
              b.classList.add('text-text-mid', 'border-border');
              b.dataset.active = 'false';
            });
            btn.classList.add('bg-accent', 'text-white', 'border-accent');
            btn.classList.remove('text-text-mid', 'border-border');
            btn.dataset.active = 'true';
            activeType = btn.dataset.type;
            applyFilters();
          });
        });

        // 検索
        let searchTimeout;
        searchInput?.addEventListener('input', () => {
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(applyFilters, 150);
        });

        function applyFilters() {
          const query = searchInput?.value.toLowerCase().trim() || '';
          const cards = getCards();
          let visibleCount = 0;

          cards.forEach(card => {
            try {
              const data = JSON.parse(card.dataset.series);
              const matchesSearch = !query || data.name.toLowerCase().includes(query);
              const matchesType = activeType === 'all' || data.type === activeType;
              const visible = matchesSearch && matchesType;
              card.style.display = visible ? '' : 'none';
              if (visible) visibleCount++;
            } catch (e) {
              card.style.display = '';
              visibleCount++;
            }
          });

          noResults.style.display = visibleCount === 0 ? '' : 'none';
        }
      });
    </script>

    <!-- 関連ガイド記事（内部リンク → ガイドページのインデックス促進） -->
    {relatedGuides.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連ガイド</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedGuides.map(g => (
            <a href={`/guide/${g.slug}/`} class="flex items-center gap-3 px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
              <div>
                <p class="text-sm font-semibold text-gray-900">{g.title.split('【')[0]}</p>
                <p class="text-xs text-text-dim mt-0.5">{g.targetFish.join('・')}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連記事（contentArticles: 魚種/タイプ一致） -->
    {relatedContentArticles.length > 0 && (
      <section class="mt-8">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連記事</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedContentArticles.map(a => (
            <a href={`/article/${a.slug}/`} class="flex items-start gap-3 p-3 bg-white rounded-lg border border-gray-100 hover:border-accent transition-colors">
              <span class="text-accent shrink-0 mt-0.5">▸</span>
              <div>
                <p class="text-sm font-medium text-gray-900">{a.h1}</p>
                <p class="text-xs text-text-mid mt-1 line-clamp-2">{a.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連カタログ（内部リンク → ランキングページのインデックス促進） -->
    {relatedRankings.length > 0 && (
      <section class="mt-8 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">カタログで探す</h2>
        <div class="flex flex-wrap gap-2">
          {relatedRankings.slice(0, 12).map(r => (
            <a href={`/ranking/${r.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {r.label}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連メーカー（内部リンク相互強化） -->
    {relatedManufacturers.length > 0 && (
      <section class="mt-8 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">関連メーカー</h2>
        <p class="text-sm text-text-mid mb-4">
          {manufacturer}と同じ対象魚・ルアータイプを扱うメーカー
        </p>
        <div class="flex flex-wrap gap-2">
          {relatedManufacturers.map(m => (
            <a href={`/${m.slug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white text-gray-700 rounded-full text-sm border border-gray-200 hover:border-accent hover:text-accent transition-colors">
              {m.name}
              <span class="text-xs text-gray-400">{m.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
