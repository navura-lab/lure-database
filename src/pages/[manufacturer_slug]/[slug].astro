---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Placeholder from '../../components/Placeholder.astro';
import LureCard from '../../components/LureCard.astro';

import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { computeCanonicalGroups } from '../../lib/canonical-groups';
import { getTypeSlug, getFishSlug } from '../../lib/category-slugs';
import { guideArticles } from '../../data/guides';
import { youtubeVideos } from '../../data/youtube-videos';
import { lureUsageGuides } from '../../data/lure-usage-guides';
import { typeDescriptions } from '../../data/type-descriptions';
import { contentArticles } from '../../data/articles/_index.js';
import type { ContentArticle } from '../../data/articles/_types.js';
import { computeColorBreakdown, type ColorBreakdownEntry } from '../../lib/color-categories';
import type { LureSeries } from '../../lib/types';

export async function getStaticPaths() {
  const lures = await fetchAllLures();

  const allSeries = groupLuresBySeries(lures ?? []);

  // タイプ別・メーカー別・魚種別のインデックスを構築
  const byType = new Map<string, LureSeries[]>();
  const byMaker = new Map<string, LureSeries[]>();
  const byFish = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    if (s.type) {
      const arr = byType.get(s.type) || [];
      arr.push(s);
      byType.set(s.type, arr);
    }
    const makerArr = byMaker.get(s.manufacturer_slug) || [];
    makerArr.push(s);
    byMaker.set(s.manufacturer_slug, makerArr);
    for (const fish of s.target_fish) {
      const fishArr = byFish.get(fish) || [];
      fishArr.push(s);
      byFish.set(fish, fishArr);
    }
  }

  // 魚種×タイプの複合インデックス（カテゴリ内順位計算用）
  const byFishType = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    for (const fish of s.target_fish) {
      const key = `${fish}|${s.type}`;
      const arr = byFishType.get(key) || [];
      arr.push(s);
      byFishType.set(key, arr);
    }
  }

  // 記事のtargetLureSlugs → ルアーslugの逆引きMap
  const articlesByLureSlug = new Map<string, ContentArticle[]>();
  for (const article of contentArticles) {
    for (const lureSlug of (article.targetLureSlugs || [])) {
      const arr = articlesByLureSlug.get(lureSlug) || [];
      arr.push(article);
      articlesByLureSlug.set(lureSlug, arr);
    }
  }

  // カラーバリアント重複対策: 同一descriptionグループのcanonical URL計算
  const canonicalGroups = computeCanonicalGroups(allSeries);

  // 決定的ソート: カラー数降順 → 名前昇順（一貫した内部リンク構造）
  const deterministicSort = (a: LureSeries, b: LureSeries) =>
    b.color_count - a.color_count || a.name.localeCompare(b.name);

  return allSeries.map(series => {
    // 同タイプの関連ルアー（自分除外、カラー数順、最大6件）
    const relatedByType = (byType.get(series.type) || [])
      .filter(s => !(s.slug === series.slug && s.manufacturer_slug === series.manufacturer_slug))
      .sort(deterministicSort)
      .slice(0, 6);

    // 同メーカーの関連ルアー（自分・タイプ重複除外、最大6件）
    const usedSlugs = new Set(relatedByType.map(s => `${s.manufacturer_slug}/${s.slug}`));
    usedSlugs.add(`${series.manufacturer_slug}/${series.slug}`);
    const relatedByMaker = (byMaker.get(series.manufacturer_slug) || [])
      .filter(s => !usedSlugs.has(`${s.manufacturer_slug}/${s.slug}`))
      .sort(deterministicSort)
      .slice(0, 6);

    // 同ターゲット魚の関連ルアー（自分・既出除外、最大6件）
    for (const s of relatedByMaker) usedSlugs.add(`${s.manufacturer_slug}/${s.slug}`);
    const primaryFish = series.target_fish[0];
    const relatedByFish = primaryFish
      ? (byFish.get(primaryFish) || [])
          .filter(s => !usedSlugs.has(`${s.manufacturer_slug}/${s.slug}`))
          .sort(deterministicSort)
          .slice(0, 6)
      : [];

    // カテゴリ内ポジション（主要魚種×タイプで順位計算）
    const ftKey = primaryFish ? `${primaryFish}|${series.type}` : null;
    const categoryPeers = ftKey ? (byFishType.get(ftKey) || []) : [];
    const sortedPeers = [...categoryPeers].sort(deterministicSort);
    const categoryRank = sortedPeers.findIndex(
      s => s.slug === series.slug && s.manufacturer_slug === series.manufacturer_slug
    ) + 1;

    // カラー系統分析（ビルド時計算）
    const colorBreakdown = computeColorBreakdown(series.colors.map(c => c.color_name));

    // 関連記事（targetLureSlugs逆引き + 魚種/タイプマッチ）
    const directArticles = articlesByLureSlug.get(series.slug) || [];
    const topicArticles = contentArticles.filter(a =>
      !directArticles.includes(a) && (
        a.targetFish.some(f => series.target_fish.includes(f)) ||
        a.targetTypes.includes(series.type)
      )
    ).slice(0, 3);
    const relatedContentArticles = [...directArticles, ...topicArticles].slice(0, 5);

    // canonicalGroupsに登録されていれば、そのページは別slugの正規ページを参照する
    const pageKey = `${series.manufacturer_slug}/${series.slug}`;
    const canonicalPathOverride = canonicalGroups.get(pageKey) || null;

    // 比較テーブル用: 同魚種×同タイプのピア（自分除外、上位5件）
    const categoryComparisonPeers = sortedPeers
      .filter(s => !(s.slug === series.slug && s.manufacturer_slug === series.manufacturer_slug))
      .slice(0, 5);

    return {
      params: { manufacturer_slug: series.manufacturer_slug, slug: series.slug },
      props: {
        series, relatedByType, relatedByMaker, relatedByFish, canonicalPathOverride,
        categoryRank,
        categoryTotal: categoryPeers.length,
        categoryFish: primaryFish || '',
        colorBreakdown,
        relatedContentArticles,
        categoryComparisonPeers,
      },
    };
  });
}

const {
  series, relatedByType, relatedByMaker, relatedByFish, canonicalPathOverride,
  categoryRank, categoryTotal, categoryFish, colorBreakdown, relatedContentArticles,
  categoryComparisonPeers,
} = Astro.props as {
  series: LureSeries;
  relatedByType: LureSeries[];
  relatedByMaker: LureSeries[];
  relatedByFish: LureSeries[];
  canonicalPathOverride: string | null;
  categoryRank: number;
  categoryTotal: number;
  categoryFish: string;
  colorBreakdown: ColorBreakdownEntry[];
  relatedContentArticles: ContentArticle[];
  categoryComparisonPeers: LureSeries[];
};

const hasLimited = series.colors.some(c => c.is_limited);

const hasPrice = series.price_range.max > 0;
const priceDisplay = hasPrice
  ? series.price_range.min === series.price_range.max
    ? `¥${series.price_range.min.toLocaleString()}`
    : `¥${series.price_range.min.toLocaleString()} ~ ¥${series.price_range.max.toLocaleString()}`
  : null;

const weightDisplay = (() => {
  if (!series.weight_range.min) return null;
  if (series.weight_range.min === series.weight_range.max) return `${series.weight_range.min}g`;
  return `${series.weight_range.min} ~ ${series.weight_range.max}g`;
})();

const lengthDisplay = (() => {
  if (!series.length_range.min) return null;
  if (series.length_range.min === series.length_range.max) return `${series.length_range.min}mm`;
  return `${series.length_range.min} ~ ${series.length_range.max}mm`;
})();

function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
  return match ? match[1] : null;
}

const youtubeId = series.official_video_url
  ? getYouTubeId(series.official_video_url)
  : null;
const embedUrl = youtubeId ? `https://www.youtube.com/embed/${youtubeId}` : null;

// YouTube関連動画（youtube-collector.tsで収集済み）
const videoKey = `${series.manufacturer_slug}/${series.slug}`;
const relatedVideos = (youtubeVideos[videoKey] || [])
  // 公式動画と重複しないようフィルタ
  .filter(v => v.videoId !== youtubeId)
  .slice(0, 3);

// --- SEO: Title ---
// GSCクエリ分析: 「商品名」「メーカー名 商品名」「商品名 タイプ」パターンが多い
// 例: 「ハグゴス」「リトルジャック ハグゴス」「ハグゴス エギ」
// カタカナ名を先頭に配置し、typeも含めてCTR改善

// 名前のSEO最適化: 日本語検索で上位を取るため、カタカナ名を先頭に配置
// 対応パターン:
//   1. ENGLISH　-カタカナ-         → カタカナ（ENGLISH）
//   2. ENGLISH（カタカナ）SUFFIX   → カタカナ（ENGLISH）SUFFIX
//   3. ENGLISH(カタカナ)SUFFIX     → カタカナ（ENGLISH）SUFFIX
//   4. ENGLISH -カタカナNN-        → カタカナNN（ENGLISH）
//   5. ENGLISH カタカナ            → カタカナ（ENGLISH）
function optimizeTitleName(name: string): string {
  // パターン1: ENGLISH全角スペース-カタカナ- (例: HUGGOS　-ハグゴス-)
  const m1 = name.match(/^([A-Za-z0-9\s.'-]+)[　\s]+[-ー]([^\x00-\x7F]+)[-ー]$/);
  if (m1) return `${m1[2]}（${m1[1].trim()}）`;

  // パターン4: ENGLISH -カタカナ+数字- (例: Gillary-01 -ギラリー01-)
  const m4 = name.match(/^([A-Za-z0-9\s.'-]+)[　\s]+[-ー]([^\x00-\x7F][^\x00-\x7F0-9]*[0-9]*)[-ー]$/);
  if (m4) return `${m4[2]}（${m4[1].trim()}）`;

  // パターン2/3: ENGLISH（カタカナ）SUFFIX (例: VIROLA HARD（ヴィローラハード) 50)
  const m2 = name.match(/^([A-Za-z0-9\s.'-]+)[（(]([^\x00-\x7F][^)）]*)[)）]\s*(.*)$/);
  if (m2) {
    const suffix = m2[3] ? ` ${m2[3]}` : '';
    return `${m2[2]}（${m2[1].trim()}）${suffix}`;
  }

  // パターン5: ENGLISH スペース カタカナ (例: Clear-S Popper クリア-S ポッパー, Fable ファブル)
  const m5 = name.match(/^([A-Za-z0-9\s.'-]+?)\s+([^\x00-\x7F].+)$/);
  if (m5) return `${m5[2]}（${m5[1].trim()}）`;

  return name;
}

const seoName = optimizeTitleName(series.name);
// type（エギ、ミノー等）をtitleに含めてロングテールクエリに対応
const typeInTitle = series.type && !seoName.includes(series.type) ? ` ${series.type}` : '';
// KP分析: 「[商品名] おすすめ カラー」パターンが20-140/月/商品
// 「カラー」「一覧」をtitleに含めCTR向上、具体的なカラー数で差別化
const pageTitle = `${seoName} ${series.manufacturer}${typeInTitle} 全${series.color_count}色カラー一覧 | CAST/LOG`;

// --- SEO: Description ---
const specs = [
  series.type,
  weightDisplay ? `重さ${weightDisplay}` : null,
  lengthDisplay ? `全長${lengthDisplay}` : null,
  `${series.color_count}カラー`,
].filter(Boolean).join('・');

// meta description: 160文字以内に切り詰め。先頭70文字に商品名・カラー数・タイプを配置
// Google表示上限は約155文字。それ以降は切り捨てられるため冗長な説明文は省略
function truncateDescription(raw: string, maxLen: number = 155): string {
  if (raw.length <= maxLen) return raw;
  // 句点で切る（最大長以内の最後の句点）
  const cut = raw.lastIndexOf('。', maxLen - 1);
  if (cut > 80) return raw.slice(0, cut + 1);
  // 句点がなければ読点で
  const cut2 = raw.lastIndexOf('、', maxLen - 1);
  if (cut2 > 80) return raw.slice(0, cut2) + '。';
  // どちらもなければ強制切り
  return raw.slice(0, maxLen - 1) + '…';
}

// カテゴリ順位をdescriptionに反映（上位10位以内なら訴求力UP）
const rankLabel = categoryRank > 0 && categoryRank <= 10 && categoryFish
  ? `${categoryFish}向け${series.type}${categoryTotal}選中${categoryRank}位。`
  : '';
const rawDescription = series.description
  ? `${seoName}（${series.manufacturer}の${series.type}）全${series.color_count}色を徹底比較。${rankLabel}${series.description}${hasPrice ? `価格${priceDisplay}。` : ''}`
  : `${seoName}（${series.manufacturer}の${series.type}）全${series.color_count}色のおすすめカラーを比較｜${rankLabel}${specs}${hasPrice ? `・価格${priceDisplay}` : ''}を掲載。`;
const pageDescription = truncateDescription(rawDescription);

// --- SEO: 自然言語スペック要約（ページ内表示用）---
const specParts: string[] = [];
specParts.push(`${series.manufacturer}が展開する${series.type}`);
if (weightDisplay) specParts.push(`重さ${weightDisplay}`);
if (lengthDisplay) specParts.push(`全長${lengthDisplay}`);
if (series.diving_depth) specParts.push(`潜行深度${series.diving_depth}`);
if (series.action_type) specParts.push(`${series.action_type}タイプ`);
if (hasPrice) specParts.push(`価格は${priceDisplay}`);
const specsSummary = `${series.name}とは、${specParts.join('、')}のルアーである。全${series.color_count}カラーをラインナップ${series.target_fish.length > 0 ? `し、${series.target_fish.slice(0, 5).join('・')}などをターゲットとする` : ''}。`;

// --- SEO: JSON-LD Product schema ---
// 画像配列: メイン画像 + カラー画像（最大8枚）
const productImages: string[] = [];
if (series.representative_image) productImages.push(series.representative_image);
for (const color of series.colors) {
  if (color.images && color.images.length > 0) {
    productImages.push(color.images[0]);
  }
  if (productImages.length >= 9) break;
}
const uniqueImages = [...new Set(productImages)];

// offers: 単一価格→Offer、価格レンジ→AggregateOffer
const offersLd = hasPrice
  ? series.price_range.min === series.price_range.max
    ? {
        '@type': 'Offer',
        priceCurrency: 'JPY',
        price: series.price_range.min,
        availability: 'https://schema.org/InStock',
        url: `https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`,
      }
    : {
        '@type': 'AggregateOffer',
        priceCurrency: 'JPY',
        lowPrice: series.price_range.min,
        highPrice: series.price_range.max,
        offerCount: series.color_count,
        availability: 'https://schema.org/InStock',
      }
  : undefined;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${series.manufacturer} ${series.name}`,
  description: series.description || `${series.manufacturer}の${series.type}「${series.name}」。${specs}。`,
  brand: {
    '@type': 'Brand',
    name: series.manufacturer,
  },
  category: series.type,
  sku: `${series.manufacturer_slug}-${series.slug}`,
  url: `https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`,
  ...(uniqueImages.length > 0 ? { image: uniqueImages } : {}),
  ...(offersLd ? { offers: offersLd } : {}),
  additionalProperty: [
    ...(series.weight_range.min ? [{
      '@type': 'PropertyValue',
      name: '重量',
      value: weightDisplay,
    }] : []),
    ...(series.length_range.min ? [{
      '@type': 'PropertyValue',
      name: '全長',
      value: lengthDisplay,
    }] : []),
    ...(series.diving_depth ? [{
      '@type': 'PropertyValue',
      name: '潜行深度',
      value: series.diving_depth,
    }] : []),
    ...(series.action_type ? [{
      '@type': 'PropertyValue',
      name: 'アクション',
      value: series.action_type,
    }] : []),
  ],
};

// BreadcrumbList JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'トップ',
      item: 'https://www.lure-db.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'メーカー一覧',
      item: 'https://www.lure-db.com/maker/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: series.manufacturer,
      item: `https://www.lure-db.com/${series.manufacturer_slug}/`,
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: series.name,
      item: `https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`,
    },
  ],
};

// FAQ schema for featured snippets
const faqEntries: { '@type': string; name: string; acceptedAnswer: { '@type': string; text: string } }[] = [];

// Q1: スペック情報（GEO対応: 詳細データ+文脈を追加）
if (series.type) {
  const rankInfo = categoryRank > 0 && categoryFish
    ? `CAST/LOGデータベースには${categoryFish}対応の${series.type}が${categoryTotal}シリーズ登録されており、${series.name}はカラー展開数で${categoryRank}位です。`
    : '';
  const answer = [
    `${series.name}とは、${series.manufacturer}が製造する${series.type}です。`,
    weightDisplay ? `重量は${weightDisplay}、` : '',
    lengthDisplay ? `全長は${lengthDisplay}、` : '',
    series.diving_depth ? `潜行深度は${series.diving_depth}、` : '',
    series.action_type ? `アクションは${series.action_type}タイプ、` : '',
    `全${series.color_count}カラーがラインナップされています。`,
    rankInfo,
  ].filter(Boolean).join('');
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}のスペックは？`,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  });
}

// Q2: 価格情報
if (hasPrice) {
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}の価格は？`,
    acceptedAnswer: { '@type': 'Answer', text: `${series.name}の価格は${priceDisplay}（税込）です。` },
  });
}

// Q3: 対象魚（GEO対応: タイプ情報・用途文脈を追加）
if (series.target_fish.length > 0) {
  const fishContext = series.type && series.type !== 'その他'
    ? `${series.type}として設計されており、`
    : '';
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}で釣れる魚は？`,
    acceptedAnswer: { '@type': 'Answer', text: `${series.name}は${fishContext}${series.target_fish.join('、')}などをターゲットにしたルアーです。${series.target_fish.length >= 3 ? `特に${series.target_fish[0]}での使用実績が多い。` : ''}` },
  });
}

// Q4: カラーバリエーション（GEO対応: カラー系統分析データを反映）
if (series.color_count > 0) {
  const sampleColors = series.colors.slice(0, 5).map(c => c.color_name).join('、');
  const topCategory = colorBreakdown.length > 0 && colorBreakdown[0].id !== 'other'
    ? `カラー系統では${colorBreakdown[0].label}が${colorBreakdown[0].count}色（${colorBreakdown[0].pct}%）と最も多い構成です。`
    : '';
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}のおすすめカラーは？`,
    acceptedAnswer: { '@type': 'Answer', text: `${series.name}は全${series.color_count}カラーを展開しています。${sampleColors}などがラインナップ。${topCategory}` },
  });
}

// Q5: 特徴・使い方（description がある場合）
if (series.description) {
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}の特徴は？`,
    acceptedAnswer: { '@type': 'Answer', text: series.description },
  });
}

const faqLd = faqEntries.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries,
} : null;

// VideoObject schema for YouTube embeds（公式 + 関連動画）
const videoLdItems: Record<string, unknown>[] = [];
if (youtubeId) {
  videoLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: `${series.manufacturer} ${series.name} 公式動画`,
    description: series.description || `${series.manufacturer}の${series.type}「${series.name}」の紹介動画。`,
    thumbnailUrl: `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`,
    embedUrl: `https://www.youtube.com/embed/${youtubeId}`,
    uploadDate: series.created_at,
  });
}
for (const rv of relatedVideos) {
  videoLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: rv.title,
    description: `${series.name}に関する動画（${rv.channelTitle}）`,
    thumbnailUrl: rv.thumbnailUrl,
    embedUrl: `https://www.youtube.com/embed/${rv.videoId}`,
    uploadDate: rv.publishedAt,
  });
}

// --- SEO: 使い方セクション用テキスト生成（AIガイド優先、フォールバックはテンプレート） ---
const guideKey = `${series.manufacturer_slug}/${series.slug}`;
const aiGuide = lureUsageGuides[guideKey] || '';
const typeSlug = getTypeSlug(series.type);
const typeDesc = typeDescriptions[typeSlug] || '';
let usageText = '';
if (aiGuide) {
  // AI生成ガイドを優先
  usageText = aiGuide;
} else if (series.type && series.type !== 'その他') {
  // フォールバック: テンプレート生成
  const usageTextParts: string[] = [];
  usageTextParts.push(`${series.name}は${series.manufacturer}の${series.type}。`);
  if (typeDesc) usageTextParts.push(typeDesc);
  if (series.action_type) usageTextParts.push(`アクションタイプは${series.action_type}。`);
  if (series.diving_depth) usageTextParts.push(`潜行深度は${series.diving_depth}。`);
  if (series.target_fish.length > 0) usageTextParts.push(`${series.target_fish.slice(0, 3).join('・')}をターゲットに使用できる。`);
  usageText = usageTextParts.join('');
}

// --- SEO: インプレ動画フィルタ ---
const impressionKeywords = ['インプレ', '実釣', 'レビュー', '使ってみた', '釣れた', '釣果', 'インプレッション'];
const allVideosForLure = youtubeVideos[videoKey] || [];
const impressionVideos = allVideosForLure.filter(v =>
  impressionKeywords.some(kw => v.title.includes(kw))
).slice(0, 3);

// --- アフィリエイトリンク ---
const rakutenAffiliateUrl = `https://af.moshimo.com/af/c/click?a_id=1181365&p_id=54&pc_id=54&pl_id=616&url=${encodeURIComponent(`https://search.rakuten.co.jp/search/mall/${series.name}/`)}`;

// Combine JSON-LD as array
const combinedJsonLd = [jsonLd, breadcrumbLd, ...(faqLd ? [faqLd] : []), ...videoLdItems] as unknown as Record<string, unknown>;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPathOverride || `/${series.manufacturer_slug}/${series.slug}/`}
  ogImage={series.representative_image || undefined}
  ogType="product"
  jsonLd={combinedJsonLd}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href={`/${series.manufacturer_slug}/`} class="hover:text-accent transition-colors">{series.manufacturer}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{series.name}</span>
    </nav>

    <!-- メインエリア -->
    <div class="flex flex-col md:flex-row gap-8 mb-12">
      <!-- 画像 -->
      <div class="md:w-1/2">
        <div class="aspect-square rounded-xl overflow-hidden border border-gray-100 bg-white">
          {series.representative_image ? (
            <img
              src={series.representative_image}
              alt={`${series.manufacturer} ${series.name} ${series.type}`}
              width="600"
              height="600"
              decoding="async"
              class="w-full h-full object-scale-down p-6"
            />
          ) : (
            <Placeholder type={series.type} />
          )}
        </div>
      </div>

      <!-- 情報 -->
      <div class="md:w-1/2">
        <p class="text-sm text-text-mid tracking-wider uppercase mb-1">
          {series.manufacturer}
        </p>
        <h1 class="text-3xl font-bold text-gray-900 mb-3">
          {series.name}
        </h1>

        <div class="flex flex-wrap gap-2 mb-6">
          <a href={`/type/${getTypeSlug(series.type)}/`}>
            <Badge label={series.type} variant="type" />
          </a>
          {hasLimited && <Badge label="限定あり" variant="limited" />}
        </div>

        <!-- スペック -->
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm mb-6">
          {weightDisplay && (
            <div>
              <p class="text-text-dim">重さ</p>
              <p class="font-medium">{weightDisplay}</p>
            </div>
          )}
          {lengthDisplay && (
            <div>
              <p class="text-text-dim">長さ</p>
              <p class="font-medium">{lengthDisplay}</p>
            </div>
          )}
          {series.diving_depth && (
            <div>
              <p class="text-text-dim">潜行深度</p>
              <p class="font-medium">{series.diving_depth}</p>
            </div>
          )}
          {series.action_type && (
            <div>
              <p class="text-text-dim">アクション</p>
              <p class="font-medium">{series.action_type}</p>
            </div>
          )}
          {series.release_year && (
            <div>
              <p class="text-text-dim">発売年</p>
              <p class="font-medium">{series.release_year}年</p>
            </div>
          )}
          <div>
            <p class="text-text-dim">カラー数</p>
            <p class="font-medium">{series.color_count}色</p>
          </div>
        </div>

        <!-- 価格 -->
        {priceDisplay && (
          <div class="border-t border-gray-100 pt-4 mb-6">
            <p class="text-text-dim text-sm">価格</p>
            <p class="text-2xl font-bold text-gray-900">{priceDisplay}</p>
          </div>
        )}

        <!-- 説明 -->
        {series.description && (
          <p class="text-gray-700 leading-relaxed">
            {series.description}
          </p>
        )}
      </div>
    </div>

    <!-- 商品概要セクション -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-3">{series.name}の特徴・スペック</h2>
      <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
        <p class="text-sm text-gray-600 leading-relaxed">
          {specsSummary}
        </p>
        <p class="text-xs text-text-faint mt-3 border-t border-gray-50 pt-3">
          出典: CAST/LOGルアーデータベース（{series.created_at?.slice(0, 10) || '2026-03-12'}時点）。メーカー公式情報・販売店データに基づく。
        </p>
      </div>
    </section>

    <!-- カテゴリ内ポジション -->
    {categoryRank > 0 && categoryTotal > 2 && categoryFish && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-3">{categoryFish}向け{series.type}カテゴリでの位置付け</h2>
        <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
          <p class="text-sm text-gray-700 leading-relaxed mb-4">
            CAST/LOGには{categoryFish}対応の{series.type}が<span class="font-bold text-accent">{categoryTotal}シリーズ</span>登録されている。
            {series.name}はカラー展開数で<span class="font-bold">{categoryTotal}シリーズ中{categoryRank}位</span>（全{series.color_count}色）だ。
          </p>
          <div class="flex items-center gap-2 text-xs text-text-dim">
            <span class="inline-flex items-center gap-1 px-2 py-1 bg-accent/10 text-accent rounded font-mono font-medium">
              #{categoryRank} / {categoryTotal}
            </span>
            <span>カラー展開数順</span>
          </div>
        </div>
      </section>
    )}

    <!-- 使い方・おすすめアクション -->
    {usageText && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-3">{series.name}の使い方・アクション</h2>
        <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
          <p class="text-sm text-gray-600 leading-relaxed">{usageText}</p>
          {(weightDisplay || series.diving_depth) && (
            <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 gap-3">
              {weightDisplay && (
                <div class="bg-gray-50 rounded-lg p-3 text-center">
                  <p class="text-xs text-text-dim mb-1">ウェイト</p>
                  <p class="text-sm font-mono font-medium">{weightDisplay}</p>
                </div>
              )}
              {lengthDisplay && (
                <div class="bg-gray-50 rounded-lg p-3 text-center">
                  <p class="text-xs text-text-dim mb-1">レングス</p>
                  <p class="text-sm font-mono font-medium">{lengthDisplay}</p>
                </div>
              )}
              {series.diving_depth && (
                <div class="bg-gray-50 rounded-lg p-3 text-center">
                  <p class="text-xs text-text-dim mb-1">潜行深度</p>
                  <p class="text-sm font-mono font-medium">{series.diving_depth}</p>
                </div>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    <!-- よくある質問（FAQ） -->
    {faqEntries.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}のよくある質問</h2>
        <div class="space-y-2">
          {faqEntries.map((faq, i) => (
            <details class="group bg-white rounded-lg border border-gray-100 overflow-hidden" open={i === 0}>
              <summary class="flex items-center justify-between px-4 py-3 cursor-pointer hover:bg-gray-50 transition-colors">
                <span class="text-sm font-semibold text-gray-900 pr-4">{faq.name}</span>
                <svg class="w-4 h-4 text-text-dim shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-3 text-sm text-gray-600 leading-relaxed border-t border-gray-50">
                {faq.acceptedAnswer.text}
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- カラー系統分析 -->
    {colorBreakdown.filter(c => c.id !== 'other').length > 1 && (
      <section class="mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}のカラー系統分析</h2>
        <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
          <p class="text-sm text-gray-600 mb-4">
            全{series.color_count}色を系統別に分類。{colorBreakdown[0]?.label}が{colorBreakdown[0]?.count}色（{colorBreakdown[0]?.pct}%）と最も多い。
          </p>
          <div class="space-y-2">
            {colorBreakdown.filter(c => c.id !== 'other').map(cat => (
              <div class="flex items-center gap-3">
                <span class="w-28 text-xs text-text-mid shrink-0 text-right">{cat.label}</span>
                <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
                  <div
                    style={`width:${Math.max(cat.pct, 2)}%;background-color:${cat.cssColor}`}
                    class="h-5 rounded-full transition-all"
                  />
                </div>
                <span class="text-xs font-mono text-text-mid w-14 shrink-0">{cat.count}色 <span class="text-text-faint">({cat.pct}%)</span></span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- カラーバリエーション -->
    <section class="mb-12">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="text-xl font-bold text-gray-900">{series.name}のカラーバリエーション</h2>
        <span class="text-sm text-text-mid">{series.color_count}色</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {series.colors.map(color => (
          <div class="group">
            <div class="aspect-square rounded-xl overflow-hidden border border-gray-100 bg-white mb-2 transition-all duration-200 group-hover:border-accent group-hover:shadow-card-hover">
              {color.images && color.images.length > 0 ? (
                <img
                  src={color.images[0]}
                  alt={`${series.manufacturer} ${series.name} ${color.color_name} ${series.type}`}
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="400"
                  class="w-full h-full object-scale-down p-3"
                />
              ) : (
                <Placeholder size="sm" />
              )}
            </div>
            <p class="text-sm font-medium text-gray-900 truncate">{color.color_name}</p>
            <!-- ウェイトバッジ横並び -->
            {color.weights.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-1">
                {color.weights.map(w => (
                  <span class="px-2 py-0.5 bg-gray-50 text-xs text-gray-600 rounded-full border border-gray-100">
                    {w.weight && `${w.weight}g`}{w.weight && w.length && ' / '}{w.length && `${w.length}mm`}
                  </span>
                ))}
              </div>
            )}
            <div class="flex items-center gap-2 mt-0.5">
              {color.is_limited && <Badge label="限定" variant="limited" />}
              {color.is_discontinued && <Badge label="廃盤" variant="discontinued" />}
            </div>
            {color.weights.length === 1 && color.weights[0].price > 0 && (
              <p class="text-sm font-bold text-gray-900 mt-1">¥{color.weights[0].price.toLocaleString()}</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- 購入・価格情報 -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}の購入・価格情報</h2>
      <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
        {hasPrice && (
          <div class="flex items-baseline gap-3 mb-4">
            <span class="text-sm text-text-dim">メーカー希望価格</span>
            <span class="text-xl font-bold text-gray-900 font-mono">{priceDisplay}</span>
            <span class="text-xs text-text-dim">（税込）</span>
          </div>
        )}
        <div class="flex flex-wrap gap-3">
          <a
            href={rakutenAffiliateUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#BF0000] text-white rounded font-mono text-sm font-bold hover:bg-[#A00000] transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            楽天市場で探す
          </a>
        </div>
        <p class="text-xs text-text-faint mt-3">※ リンク先で在庫・価格をご確認ください。</p>
      </div>
    </section>

    <!-- 公式動画 -->
    {embedUrl && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}の公式動画</h2>
        <div class="aspect-video rounded-xl overflow-hidden border border-gray-100">
          <iframe
            src={embedUrl}
            title={`${series.name} 公式動画`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
      </section>
    )}

    <!-- 関連YouTube動画（youtube-collector.tsで収集） -->
    {relatedVideos.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}の関連動画</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {relatedVideos.map(video => (
            <a
              href={`https://www.youtube.com/watch?v=${video.videoId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group block bg-white rounded-lg border border-gray-100 overflow-hidden hover:border-accent hover:shadow-card-hover transition-all duration-150"
            >
              <div class="relative aspect-video bg-gray-100">
                <img
                  src={video.thumbnailUrl}
                  alt={video.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all">
                    <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-3">
                <p class="text-sm font-medium text-gray-900 line-clamp-2 group-hover:text-accent transition-colors">{video.title}</p>
                <div class="flex items-center gap-2 mt-1.5">
                  <span class="text-xs text-text-dim font-mono">{video.channelTitle}</span>
                  <span class="text-xs text-text-faint">·</span>
                  <span class="text-xs text-text-dim font-mono">{video.viewCount.toLocaleString()}回再生</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- インプレ・口コミまとめ -->
    {impressionVideos.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}のインプレ・口コミまとめ</h2>
        <p class="text-sm text-text-mid mb-4">{series.name}に関するインプレ・実釣動画を{impressionVideos.length}件まとめました。</p>
        <div class="space-y-3">
          {impressionVideos.map(video => (
            <a
              href={`https://www.youtube.com/watch?v=${video.videoId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex gap-4 bg-white rounded-lg border border-gray-100 p-3 hover:border-accent hover:shadow-sm transition-all"
            >
              <div class="relative w-40 shrink-0 aspect-video rounded overflow-hidden bg-gray-100">
                <img
                  src={video.thumbnailUrl}
                  alt={video.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-8 h-8 bg-red-600 rounded-full flex items-center justify-center opacity-80 group-hover:opacity-100 transition-opacity">
                    <svg class="w-3.5 h-3.5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 line-clamp-2 group-hover:text-accent transition-colors">{video.title}</p>
                <div class="flex items-center gap-2 mt-1.5">
                  <span class="text-xs text-text-dim font-mono">{video.channelTitle}</span>
                  <span class="text-xs text-text-faint">·</span>
                  <span class="text-xs text-text-dim font-mono">{video.viewCount.toLocaleString()}回再生</span>
                </div>
                <span class="inline-block mt-1.5 text-xs text-text-faint font-mono">{video.publishedAt.split('T')[0]}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 対象魚 -->
    {series.target_fish.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}で狙える魚種</h2>
        <div class="flex flex-wrap gap-2">
          {series.target_fish.map(fish => (
            <a href={`/fish/${getFishSlug(fish)}/`} class="px-3 py-1.5 bg-gray-50 text-gray-700 rounded-full text-sm border border-gray-100 hover:bg-gray-100 transition-colors">
              {fish}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連ルアー: 同ターゲット魚 -->
    {relatedByFish.length > 0 && series.target_fish[0] && (
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">
            {series.target_fish[0]}向けルアー
          </h2>
          <a href={`/fish/${getFishSlug(series.target_fish[0])}/`} class="text-sm text-accent hover:text-accent-dark transition-colors">
            {series.target_fish[0]}向けルアーをもっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {relatedByFish.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </section>
    )}

    <!-- 関連ルアー: 同タイプ -->
    {relatedByType.length > 0 && (
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">
            その他の{series.type}
          </h2>
          <a href={`/type/${getTypeSlug(series.type)}/`} class="text-sm text-accent hover:text-accent-dark transition-colors">
            {series.type}をもっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {relatedByType.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </section>
    )}

    <!-- 似たルアーの比較（同魚種×同タイプ） -->
    {(() => {
      const peers = categoryComparisonPeers.length > 0 ? categoryComparisonPeers : relatedByType.slice(0, 5);
      const isFishType = categoryComparisonPeers.length > 0 && categoryFish;
      const tableLabel = isFishType
        ? `${categoryFish}向け${series.type}の比較`
        : `${series.name}と似たルアーの比較`;
      const tableNote = isFishType
        ? `※ ${categoryFish}×${series.type}カテゴリ内のスペック比較。カラー展開数順。`
        : `※ 同タイプのルアーをスペックで比較。カラー展開数順。`;
      return peers.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl font-bold text-gray-900 mb-4">{tableLabel}</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border border-gray-100 rounded-lg overflow-hidden">
              <thead>
                <tr class="bg-gray-50 text-left">
                  <th class="px-3 py-2 font-medium text-text-dim text-xs">ルアー名</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs">メーカー</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs text-right">重量</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs text-right">全長</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs">レンジ</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs">アクション</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs text-right">カラー数</th>
                  <th class="px-3 py-2 font-medium text-text-dim text-xs text-right">価格</th>
                </tr>
              </thead>
              <tbody>
                {/* 自分自身を先頭行に表示 */}
                <tr class="border-t border-gray-50 bg-accent/5">
                  <td class="px-3 py-2 font-medium text-gray-900">{series.name}</td>
                  <td class="px-3 py-2 text-text-mid font-mono text-xs">{series.manufacturer}</td>
                  <td class="px-3 py-2 text-right font-mono text-xs">{weightDisplay || '-'}</td>
                  <td class="px-3 py-2 text-right font-mono text-xs">{lengthDisplay || '-'}</td>
                  <td class="px-3 py-2 text-text-mid text-xs">{series.diving_depth || '-'}</td>
                  <td class="px-3 py-2 text-text-mid text-xs">{series.action_type || '-'}</td>
                  <td class="px-3 py-2 text-right font-mono text-xs">{series.color_count}</td>
                  <td class="px-3 py-2 text-right font-mono text-xs">{priceDisplay || '-'}</td>
                </tr>
                {peers.map(s => {
                  const w = s.weight_range.min
                    ? s.weight_range.min === s.weight_range.max
                      ? `${s.weight_range.min}g`
                      : `${s.weight_range.min}~${s.weight_range.max}g`
                    : '-';
                  const l = s.length_range.min
                    ? s.length_range.min === s.length_range.max
                      ? `${s.length_range.min}mm`
                      : `${s.length_range.min}~${s.length_range.max}mm`
                    : '-';
                  const p = s.price_range.max > 0
                    ? s.price_range.min === s.price_range.max
                      ? `¥${s.price_range.min.toLocaleString()}`
                      : `¥${s.price_range.min.toLocaleString()}~`
                    : '-';
                  return (
                    <tr class="border-t border-gray-50 hover:bg-gray-50 transition-colors">
                      <td class="px-3 py-2">
                        <a href={`/${s.manufacturer_slug}/${s.slug}/`} class="text-accent hover:underline font-medium">{s.name}</a>
                      </td>
                      <td class="px-3 py-2 text-text-mid font-mono text-xs">{s.manufacturer}</td>
                      <td class="px-3 py-2 text-right font-mono text-xs">{w}</td>
                      <td class="px-3 py-2 text-right font-mono text-xs">{l}</td>
                      <td class="px-3 py-2 text-text-mid text-xs">{s.diving_depth || '-'}</td>
                      <td class="px-3 py-2 text-text-mid text-xs">{s.action_type || '-'}</td>
                      <td class="px-3 py-2 text-right font-mono text-xs">{s.color_count}</td>
                      <td class="px-3 py-2 text-right font-mono text-xs">{p}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-text-faint mt-2">{tableNote}</p>
        </section>
      );
    })()}

    <!-- 関連ルアー: 同メーカー -->
    {relatedByMaker.length > 0 && (
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">
            {series.manufacturer}のその他のルアー
          </h2>
          <a href={`/${series.manufacturer_slug}/`} class="text-sm text-accent hover:text-accent-dark transition-colors">
            {series.manufacturer}をもっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {relatedByMaker.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </section>
    )}

    <!-- 関連ガイド記事 -->
    {(() => {
      const guides = guideArticles.filter(g =>
        g.targetFish.some(f => series.target_fish.includes(f)) ||
        g.targetTypes.includes(series.type)
      );
      return guides.length > 0 ? (
        <section class="mb-12 pt-8 border-t border-gray-100">
          <h2 class="text-xl font-bold text-gray-900 mb-4">関連ガイド記事</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {guides.map(guide => (
              <a href={`/guide/${guide.slug}/`} class="group flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
                <div>
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors">{guide.title.split('【')[0]}</p>
                  <p class="text-xs text-text-dim mt-0.5">{guide.targetFish.join('・')}</p>
                </div>
                <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            ))}
          </div>
        </section>
      ) : null;
    })()}

    <!-- 関連特集記事 -->
    {relatedContentArticles.length > 0 && (
      <section class="mb-12 pt-8 border-t border-gray-100">
        <h2 class="text-xl font-bold text-gray-900 mb-4">関連特集記事</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedContentArticles.map(article => (
            <a href={`/article/${article.slug}/`} class="group flex items-start gap-3 px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
              <span class:list={[
                'shrink-0 text-[10px] font-mono font-bold px-1.5 py-0.5 rounded mt-0.5',
                article.type === 'color-guide' ? 'bg-blue-50 text-blue-600' :
                article.type === 'review-analysis' ? 'bg-green-50 text-green-600' :
                article.type === 'selection-guide' ? 'bg-orange-50 text-orange-600' :
                'bg-gray-50 text-gray-600'
              ]}>
                {article.type === 'color-guide' ? 'カラー' :
                 article.type === 'review-analysis' ? 'レビュー' :
                 article.type === 'selection-guide' ? '選び方' : 'ガイド'}
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors truncate">{article.title}</p>
                <p class="text-xs text-text-dim mt-0.5 truncate">{article.targetFish.join('・')}</p>
              </div>
              <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- SNSシェア -->
    <div class="flex items-center gap-3 pt-6 border-t border-gray-100 mb-6">
      <span class="text-xs text-text-dim font-mono">SHARE:</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${series.manufacturer} ${series.name} | CAST/LOG`)}&url=${encodeURIComponent(`https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        X(Twitter)
      </a>
      <a
        href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        LINE
      </a>
    </div>

    <!-- メーカーページへのナビゲーション -->
    <div class="mb-4">
      <a
        href={`/${series.manufacturer_slug}/`}
        class="inline-flex items-center gap-1.5 text-sm text-accent hover:text-accent-dark transition-colors font-medium"
      >
        <span>←</span>
        <span>{series.manufacturer}のルアー一覧を見る</span>
      </a>
    </div>

  </div>
</BaseLayout>
