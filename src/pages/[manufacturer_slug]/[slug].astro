              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors truncate">{article.title}</p>
                <p class="text-xs text-text-dim mt-0.5 truncate">{article.targetFish.join('・')}</p>
              </div>
              <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- SNSシェア -->
    <div class="flex items-center gap-3 pt-6 border-t border-gray-100 mb-6">
      <span class="text-xs text-text-dim font-mono">SHARE:</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${series.manufacturer} ${series.name} | CAST/LOG`)}&url=${encodeURIComponent(`https://castlog.xyz/${series.manufacturer_slug}/${series.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        X(Twitter)
      </a>
      <a
        href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://castlog.xyz/${series.manufacturer_slug}/${series.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        LINE
      </a>
    </div>

    <!-- メーカーページへのナビゲーション -->
    <div class="mb-4">
      <a
        href={`/${series.manufacturer_slug}/`}
        class="inline-flex items-center gap-1.5 text-sm text-accent hover:text-accent-dark transition-colors font-medium"
      >
        <span>←</span>
        <span>{series.manufacturer}のルアー一覧を見る</span>
      </a>
    </div>

  </div>
</BaseLayout>
