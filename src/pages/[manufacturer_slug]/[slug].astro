---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Placeholder from '../../components/Placeholder.astro';
import LureCard from '../../components/LureCard.astro';

import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';
import { getTypeSlug, getFishSlug } from '../../lib/category-slugs';
import { guideArticles } from '../../data/guides';
import { youtubeVideos } from '../../data/youtube-videos';
import type { LureSeries } from '../../lib/types';

export async function getStaticPaths() {
  const lures = await fetchAllLures();

  const allSeries = groupLuresBySeries(lures ?? []);

  // タイプ別・メーカー別・魚種別のインデックスを構築
  const byType = new Map<string, LureSeries[]>();
  const byMaker = new Map<string, LureSeries[]>();
  const byFish = new Map<string, LureSeries[]>();
  for (const s of allSeries) {
    if (s.type) {
      const arr = byType.get(s.type) || [];
      arr.push(s);
      byType.set(s.type, arr);
    }
    const makerArr = byMaker.get(s.manufacturer_slug) || [];
    makerArr.push(s);
    byMaker.set(s.manufacturer_slug, makerArr);
    for (const fish of s.target_fish) {
      const fishArr = byFish.get(fish) || [];
      fishArr.push(s);
      byFish.set(fish, fishArr);
    }
  }

  // 決定的ソート: カラー数降順 → 名前昇順（一貫した内部リンク構造）
  const deterministicSort = (a: LureSeries, b: LureSeries) =>
    b.color_count - a.color_count || a.name.localeCompare(b.name);

  return allSeries.map(series => {
    // 同タイプの関連ルアー（自分除外、カラー数順、最大4件）
    const relatedByType = (byType.get(series.type) || [])
      .filter(s => !(s.slug === series.slug && s.manufacturer_slug === series.manufacturer_slug))
      .sort(deterministicSort)
      .slice(0, 4);

    // 同メーカーの関連ルアー（自分・タイプ重複除外、最大4件）
    const usedSlugs = new Set(relatedByType.map(s => `${s.manufacturer_slug}/${s.slug}`));
    usedSlugs.add(`${series.manufacturer_slug}/${series.slug}`);
    const relatedByMaker = (byMaker.get(series.manufacturer_slug) || [])
      .filter(s => !usedSlugs.has(`${s.manufacturer_slug}/${s.slug}`))
      .sort(deterministicSort)
      .slice(0, 4);

    // 同ターゲット魚の関連ルアー（自分・既出除外、最大4件）
    for (const s of relatedByMaker) usedSlugs.add(`${s.manufacturer_slug}/${s.slug}`);
    const primaryFish = series.target_fish[0];
    const relatedByFish = primaryFish
      ? (byFish.get(primaryFish) || [])
          .filter(s => !usedSlugs.has(`${s.manufacturer_slug}/${s.slug}`))
          .sort(deterministicSort)
          .slice(0, 4)
      : [];

    return {
      params: { manufacturer_slug: series.manufacturer_slug, slug: series.slug },
      props: { series, relatedByType, relatedByMaker, relatedByFish },
    };
  });
}

const { series, relatedByType, relatedByMaker, relatedByFish } = Astro.props as {
  series: LureSeries;
  relatedByType: LureSeries[];
  relatedByMaker: LureSeries[];
  relatedByFish: LureSeries[];
};

const hasLimited = series.colors.some(c => c.is_limited);

const hasPrice = series.price_range.max > 0;
const priceDisplay = hasPrice
  ? series.price_range.min === series.price_range.max
    ? `¥${series.price_range.min.toLocaleString()}`
    : `¥${series.price_range.min.toLocaleString()} ~ ¥${series.price_range.max.toLocaleString()}`
  : null;

const weightDisplay = (() => {
  if (!series.weight_range.min) return null;
  if (series.weight_range.min === series.weight_range.max) return `${series.weight_range.min}g`;
  return `${series.weight_range.min} ~ ${series.weight_range.max}g`;
})();

const lengthDisplay = (() => {
  if (!series.length_range.min) return null;
  if (series.length_range.min === series.length_range.max) return `${series.length_range.min}mm`;
  return `${series.length_range.min} ~ ${series.length_range.max}mm`;
})();

function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
  return match ? match[1] : null;
}

const youtubeId = series.official_video_url
  ? getYouTubeId(series.official_video_url)
  : null;
const embedUrl = youtubeId ? `https://www.youtube.com/embed/${youtubeId}` : null;

// YouTube関連動画（youtube-collector.tsで収集済み）
const videoKey = `${series.manufacturer_slug}/${series.slug}`;
const relatedVideos = (youtubeVideos[videoKey] || [])
  // 公式動画と重複しないようフィルタ
  .filter(v => v.videoId !== youtubeId)
  .slice(0, 3);

// --- SEO: Title ---
// GSCクエリ分析: 「商品名」「メーカー名 商品名」「商品名 スペック/カラー/価格」パターンが多い
// titleに「スペック・カラー・価格」を含めてCTR改善
const pageTitle = `${series.name}（${series.manufacturer}）スペック・カラー・価格 | CAST/LOG`;

// --- SEO: Description ---
const specs = [
  series.type,
  weightDisplay ? `重さ${weightDisplay}` : null,
  lengthDisplay ? `全長${lengthDisplay}` : null,
  `${series.color_count}カラー`,
].filter(Boolean).join('・');

// meta description: リライト済みdescriptionがあればフル活用（150-250文字=meta descriptionに最適）
// 先頭に「メーカー名の商品名（タイプ）」を置き、スペック・カラー・価格キーワードを含める
const pageDescription = series.description
  ? `${series.manufacturer}の${series.type}「${series.name}」｜${series.description}${series.color_count}カラー展開。`
  : `${series.manufacturer}の${series.type}「${series.name}」（${specs}）のスペック・全${series.color_count}カラーバリエーション${hasPrice ? `・価格${priceDisplay}` : ''}を掲載。CAST/LOG`;

// --- SEO: 自然言語スペック要約（ページ内表示用）---
const specParts: string[] = [];
specParts.push(`${series.manufacturer}が展開する${series.type}`);
if (weightDisplay) specParts.push(`重さ${weightDisplay}`);
if (lengthDisplay) specParts.push(`全長${lengthDisplay}`);
if (series.diving_depth) specParts.push(`潜行深度${series.diving_depth}`);
if (series.action_type) specParts.push(`${series.action_type}タイプ`);
if (hasPrice) specParts.push(`価格は${priceDisplay}`);
const specsSummary = `${series.name}は${specParts.join('、')}。全${series.color_count}カラーをラインナップ${series.target_fish.length > 0 ? `し、${series.target_fish.slice(0, 5).join('・')}などをターゲットとする` : ''}。`;

// --- SEO: JSON-LD Product schema ---
// 画像配列: メイン画像 + カラー画像（最大8枚）
const productImages: string[] = [];
if (series.representative_image) productImages.push(series.representative_image);
for (const color of series.colors) {
  if (color.images && color.images.length > 0) {
    productImages.push(color.images[0]);
  }
  if (productImages.length >= 9) break;
}
const uniqueImages = [...new Set(productImages)];

// offers: 単一価格→Offer、価格レンジ→AggregateOffer
const offersLd = hasPrice
  ? series.price_range.min === series.price_range.max
    ? {
        '@type': 'Offer',
        priceCurrency: 'JPY',
        price: series.price_range.min,
        availability: 'https://schema.org/InStock',
        url: `https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`,
      }
    : {
        '@type': 'AggregateOffer',
        priceCurrency: 'JPY',
        lowPrice: series.price_range.min,
        highPrice: series.price_range.max,
        offerCount: series.color_count,
        availability: 'https://schema.org/InStock',
      }
  : undefined;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${series.manufacturer} ${series.name}`,
  description: series.description || `${series.manufacturer}の${series.type}「${series.name}」。${specs}。`,
  brand: {
    '@type': 'Brand',
    name: series.manufacturer,
  },
  category: series.type,
  sku: `${series.manufacturer_slug}-${series.slug}`,
  url: `https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`,
  ...(uniqueImages.length > 0 ? { image: uniqueImages } : {}),
  ...(offersLd ? { offers: offersLd } : {}),
  additionalProperty: [
    ...(series.weight_range.min ? [{
      '@type': 'PropertyValue',
      name: '重量',
      value: weightDisplay,
    }] : []),
    ...(series.length_range.min ? [{
      '@type': 'PropertyValue',
      name: '全長',
      value: lengthDisplay,
    }] : []),
    ...(series.diving_depth ? [{
      '@type': 'PropertyValue',
      name: '潜行深度',
      value: series.diving_depth,
    }] : []),
    ...(series.action_type ? [{
      '@type': 'PropertyValue',
      name: 'アクション',
      value: series.action_type,
    }] : []),
  ],
};

// BreadcrumbList JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'トップ',
      item: 'https://www.lure-db.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'メーカー一覧',
      item: 'https://www.lure-db.com/maker/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: series.manufacturer,
      item: `https://www.lure-db.com/${series.manufacturer_slug}/`,
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: series.name,
      item: `https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`,
    },
  ],
};

// FAQ schema for featured snippets
const faqEntries: { '@type': string; name: string; acceptedAnswer: { '@type': string; text: string } }[] = [];

// Q1: スペック情報
if (series.type) {
  const answer = [
    `${series.name}は${series.manufacturer}が製造する${series.type}です。`,
    weightDisplay ? `重量は${weightDisplay}、` : '',
    lengthDisplay ? `全長は${lengthDisplay}、` : '',
    series.diving_depth ? `潜行深度は${series.diving_depth}、` : '',
    `全${series.color_count}カラーがラインナップされています。`,
  ].filter(Boolean).join('');
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}のスペックは？`,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  });
}

// Q2: 価格情報
if (hasPrice) {
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}の価格は？`,
    acceptedAnswer: { '@type': 'Answer', text: `${series.name}の価格は${priceDisplay}（税込）です。` },
  });
}

// Q3: 対象魚
if (series.target_fish.length > 0) {
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}で釣れる魚は？`,
    acceptedAnswer: { '@type': 'Answer', text: `${series.name}は${series.target_fish.join('、')}などをターゲットにしたルアーです。` },
  });
}

// Q4: カラーバリエーション
if (series.color_count > 0) {
  const sampleColors = series.colors.slice(0, 5).map(c => c.color_name).join('、');
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}のカラーバリエーションは？`,
    acceptedAnswer: { '@type': 'Answer', text: `${series.name}は全${series.color_count}カラーを展開しています。${sampleColors}などがラインナップされています。` },
  });
}

// Q5: 特徴・使い方（description がある場合）
if (series.description) {
  faqEntries.push({
    '@type': 'Question',
    name: `${series.name}の特徴は？`,
    acceptedAnswer: { '@type': 'Answer', text: series.description },
  });
}

const faqLd = faqEntries.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries,
} : null;

// VideoObject schema for YouTube embeds（公式 + 関連動画）
const videoLdItems: Record<string, unknown>[] = [];
if (youtubeId) {
  videoLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: `${series.manufacturer} ${series.name} 公式動画`,
    description: series.description || `${series.manufacturer}の${series.type}「${series.name}」の紹介動画。`,
    thumbnailUrl: `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`,
    embedUrl: `https://www.youtube.com/embed/${youtubeId}`,
    uploadDate: series.created_at,
  });
}
for (const rv of relatedVideos) {
  videoLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: rv.title,
    description: `${series.name}に関する動画（${rv.channelTitle}）`,
    thumbnailUrl: rv.thumbnailUrl,
    embedUrl: `https://www.youtube.com/embed/${rv.videoId}`,
    uploadDate: rv.publishedAt,
  });
}

// Combine JSON-LD as array
const combinedJsonLd = [jsonLd, breadcrumbLd, ...(faqLd ? [faqLd] : []), ...videoLdItems] as unknown as Record<string, unknown>;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/${series.manufacturer_slug}/${series.slug}/`}
  ogImage={series.representative_image || undefined}
  ogType="product"
  jsonLd={combinedJsonLd}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- パンくず -->
    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <a href={`/${series.manufacturer_slug}/`} class="hover:text-accent transition-colors">{series.manufacturer}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{series.name}</span>
    </nav>

    <!-- メインエリア -->
    <div class="flex flex-col md:flex-row gap-8 mb-12">
      <!-- 画像 -->
      <div class="md:w-1/2">
        <div class="aspect-square rounded-xl overflow-hidden border border-gray-100 bg-white">
          {series.representative_image ? (
            <img
              src={series.representative_image}
              alt={`${series.manufacturer} ${series.name} ${series.type}`}
              width="600"
              height="600"
              decoding="async"
              class="w-full h-full object-scale-down p-6"
            />
          ) : (
            <Placeholder type={series.type} />
          )}
        </div>
      </div>

      <!-- 情報 -->
      <div class="md:w-1/2">
        <p class="text-sm text-text-mid tracking-wider uppercase mb-1">
          {series.manufacturer}
        </p>
        <h1 class="text-3xl font-bold text-gray-900 mb-3">
          {series.name}
        </h1>

        <div class="flex flex-wrap gap-2 mb-6">
          <a href={`/type/${getTypeSlug(series.type)}/`}>
            <Badge label={series.type} variant="type" />
          </a>
          {hasLimited && <Badge label="限定あり" variant="limited" />}
        </div>

        <!-- スペック -->
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm mb-6">
          {weightDisplay && (
            <div>
              <p class="text-text-dim">重さ</p>
              <p class="font-medium">{weightDisplay}</p>
            </div>
          )}
          {lengthDisplay && (
            <div>
              <p class="text-text-dim">長さ</p>
              <p class="font-medium">{lengthDisplay}</p>
            </div>
          )}
          {series.diving_depth && (
            <div>
              <p class="text-text-dim">潜行深度</p>
              <p class="font-medium">{series.diving_depth}</p>
            </div>
          )}
          {series.action_type && (
            <div>
              <p class="text-text-dim">アクション</p>
              <p class="font-medium">{series.action_type}</p>
            </div>
          )}
          {series.release_year && (
            <div>
              <p class="text-text-dim">発売年</p>
              <p class="font-medium">{series.release_year}年</p>
            </div>
          )}
          <div>
            <p class="text-text-dim">カラー数</p>
            <p class="font-medium">{series.color_count}色</p>
          </div>
        </div>

        <!-- 価格 -->
        {priceDisplay && (
          <div class="border-t border-gray-100 pt-4 mb-6">
            <p class="text-text-dim text-sm">価格</p>
            <p class="text-2xl font-bold text-gray-900">{priceDisplay}</p>
          </div>
        )}

        <!-- 説明 -->
        {series.description && (
          <p class="text-gray-700 leading-relaxed">
            {series.description}
          </p>
        )}
      </div>
    </div>

    <!-- 商品概要セクション -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-3">{series.name}の特徴・スペック</h2>
      <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
        <p class="text-sm text-gray-600 leading-relaxed">
          {specsSummary}
        </p>
      </div>
    </section>

    <!-- よくある質問（FAQ） -->
    {faqEntries.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}のよくある質問</h2>
        <div class="space-y-2">
          {faqEntries.map((faq, i) => (
            <details class="group bg-white rounded-lg border border-gray-100 overflow-hidden" open={i === 0}>
              <summary class="flex items-center justify-between px-4 py-3 cursor-pointer hover:bg-gray-50 transition-colors">
                <span class="text-sm font-semibold text-gray-900 pr-4">{faq.name}</span>
                <svg class="w-4 h-4 text-text-dim shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-3 text-sm text-gray-600 leading-relaxed border-t border-gray-50">
                {faq.acceptedAnswer.text}
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- カラーバリエーション -->
    <section class="mb-12">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="text-xl font-bold text-gray-900">{series.name}のカラーバリエーション</h2>
        <span class="text-sm text-text-mid">{series.color_count}色</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {series.colors.map(color => (
          <div class="group">
            <div class="aspect-square rounded-xl overflow-hidden border border-gray-100 bg-white mb-2 transition-all duration-200 group-hover:border-accent group-hover:shadow-card-hover">
              {color.images && color.images.length > 0 ? (
                <img
                  src={color.images[0]}
                  alt={`${series.name} ${color.color_name}`}
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="400"
                  class="w-full h-full object-scale-down p-3"
                />
              ) : (
                <Placeholder size="sm" />
              )}
            </div>
            <p class="text-sm font-medium text-gray-900 truncate">{color.color_name}</p>
            <!-- ウェイトバッジ横並び -->
            {color.weights.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-1">
                {color.weights.map(w => (
                  <span class="px-2 py-0.5 bg-gray-50 text-xs text-gray-600 rounded-full border border-gray-100">
                    {w.weight && `${w.weight}g`}{w.weight && w.length && ' / '}{w.length && `${w.length}mm`}
                  </span>
                ))}
              </div>
            )}
            <div class="flex items-center gap-2 mt-0.5">
              {color.is_limited && <Badge label="限定" variant="limited" />}
              {color.is_discontinued && <Badge label="廃盤" variant="discontinued" />}
            </div>
            {color.weights.length === 1 && color.weights[0].price > 0 && (
              <p class="text-sm font-bold text-gray-900 mt-1">¥{color.weights[0].price.toLocaleString()}</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- 公式動画 -->
    {embedUrl && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}の公式動画</h2>
        <div class="aspect-video rounded-xl overflow-hidden border border-gray-100">
          <iframe
            src={embedUrl}
            title={`${series.name} 公式動画`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
      </section>
    )}

    <!-- 関連YouTube動画（youtube-collector.tsで収集） -->
    {relatedVideos.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}の関連動画</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {relatedVideos.map(video => (
            <a
              href={`https://www.youtube.com/watch?v=${video.videoId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group block bg-white rounded-lg border border-gray-100 overflow-hidden hover:border-accent hover:shadow-card-hover transition-all duration-150"
            >
              <div class="relative aspect-video bg-gray-100">
                <img
                  src={video.thumbnailUrl}
                  alt={video.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all">
                    <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-3">
                <p class="text-sm font-medium text-gray-900 line-clamp-2 group-hover:text-accent transition-colors">{video.title}</p>
                <div class="flex items-center gap-2 mt-1.5">
                  <span class="text-xs text-text-dim font-mono">{video.channelTitle}</span>
                  <span class="text-xs text-text-faint">·</span>
                  <span class="text-xs text-text-dim font-mono">{video.viewCount.toLocaleString()}回再生</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 対象魚 -->
    {series.target_fish.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{series.name}で狙える魚種</h2>
        <div class="flex flex-wrap gap-2">
          {series.target_fish.map(fish => (
            <a href={`/fish/${getFishSlug(fish)}/`} class="px-3 py-1.5 bg-gray-50 text-gray-700 rounded-full text-sm border border-gray-100 hover:bg-gray-100 transition-colors">
              {fish}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 関連ルアー: 同ターゲット魚 -->
    {relatedByFish.length > 0 && series.target_fish[0] && (
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">
            {series.target_fish[0]}向けルアー
          </h2>
          <a href={`/fish/${getFishSlug(series.target_fish[0])}/`} class="text-sm text-accent hover:text-accent-dark transition-colors">
            {series.target_fish[0]}向けルアーをもっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {relatedByFish.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </section>
    )}

    <!-- 関連ルアー: 同タイプ -->
    {relatedByType.length > 0 && (
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">
            その他の{series.type}
          </h2>
          <a href={`/type/${getTypeSlug(series.type)}/`} class="text-sm text-accent hover:text-accent-dark transition-colors">
            {series.type}をもっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {relatedByType.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </section>
    )}

    <!-- 関連ルアー: 同メーカー -->
    {relatedByMaker.length > 0 && (
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">
            {series.manufacturer}のその他のルアー
          </h2>
          <a href={`/${series.manufacturer_slug}/`} class="text-sm text-accent hover:text-accent-dark transition-colors">
            {series.manufacturer}をもっと見る →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {relatedByMaker.map(s => (
            <LureCard series={s} isNew={false} />
          ))}
        </div>
      </section>
    )}

    <!-- 関連ガイド記事 -->
    {(() => {
      const guides = guideArticles.filter(g =>
        g.targetFish.some(f => series.target_fish.includes(f)) ||
        g.targetTypes.includes(series.type)
      );
      return guides.length > 0 ? (
        <section class="mb-12 pt-8 border-t border-gray-100">
          <h2 class="text-xl font-bold text-gray-900 mb-4">関連ガイド記事</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {guides.map(guide => (
              <a href={`/guide/${guide.slug}/`} class="group flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-100 hover:border-accent hover:shadow-sm transition-all">
                <div>
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors">{guide.title.split('【')[0]}</p>
                  <p class="text-xs text-text-dim mt-0.5">{guide.targetFish.join('・')}</p>
                </div>
                <span class="text-accent text-sm shrink-0 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            ))}
          </div>
        </section>
      ) : null;
    })()}

    <!-- SNSシェア -->
    <div class="flex items-center gap-3 pt-6 border-t border-gray-100 mb-6">
      <span class="text-xs text-text-dim font-mono">SHARE:</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${series.manufacturer} ${series.name} | CAST/LOG`)}&url=${encodeURIComponent(`https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        X(Twitter)
      </a>
      <a
        href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://www.lure-db.com/${series.manufacturer_slug}/${series.slug}/`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-dim border border-border rounded hover:border-accent hover:text-accent transition-colors"
      >
        LINE
      </a>
    </div>

    <!-- メーカーページへのナビゲーション -->
    <div class="mb-4">
      <a
        href={`/${series.manufacturer_slug}/`}
        class="inline-flex items-center gap-1.5 text-sm text-accent hover:text-accent-dark transition-colors font-medium"
      >
        <span>←</span>
        <span>{series.manufacturer}のルアー一覧を見る</span>
      </a>
    </div>

  </div>
</BaseLayout>
