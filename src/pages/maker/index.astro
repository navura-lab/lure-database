---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import { fetchAllLures } from '../../lib/fetch-all-lures';
import { groupLuresBySeries } from '../../lib/group-lures';

const lures = await fetchAllLures();
const allSeries = groupLuresBySeries(lures ?? []);

// メーカー別に集計
const makerStats = new Map<string, {
  name: string;
  slug: string;
  seriesCount: number;
  colorCount: number;
  topTypes: { name: string; count: number }[];
  image: string | null;
}>();

for (const s of allSeries) {
  const existing = makerStats.get(s.manufacturer_slug);
  if (existing) {
    existing.seriesCount++;
    existing.colorCount += s.color_count;
    if (!existing.image && s.representative_image) existing.image = s.representative_image;
  } else {
    makerStats.set(s.manufacturer_slug, {
      name: s.manufacturer,
      slug: s.manufacturer_slug,
      seriesCount: 1,
      colorCount: s.color_count,
      topTypes: [],
      image: s.representative_image,
    });
  }
}

// 各メーカーの上位3タイプを算出
for (const [slug, stats] of makerStats) {
  const typeCount = new Map<string, number>();
  for (const s of allSeries) {
    if (s.manufacturer_slug === slug && s.type) {
      typeCount.set(s.type, (typeCount.get(s.type) || 0) + 1);
    }
  }
  stats.topTypes = [...typeCount.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 3)
    .map(([name, count]) => ({ name, count }));
}

const makerList = [...makerStats.values()].sort((a, b) => b.seriesCount - a.seriesCount);
const totalSeries = makerList.reduce((sum, m) => sum + m.seriesCount, 0);
const totalColors = makerList.reduce((sum, m) => sum + m.colorCount, 0);

const topMakerNames = makerList.slice(0, 5).map(m => m.name).join('、');
const pageDescription = `ルアーメーカー${makerList.length}社の製品一覧。${topMakerNames}等、全${totalSeries}シリーズ・${totalColors.toLocaleString()}カラーを掲載。メーカー別にルアーのスペック・カラー・価格を比較。`;

const pageTitle = `ルアーメーカー一覧 ${makerList.length}社 - ${topMakerNames}等 - CAST/LOG`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://www.lure-db.com/' },
    { '@type': 'ListItem', position: 2, name: 'メーカー一覧', item: 'https://www.lure-db.com/maker/' },
  ],
};

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `ルアーメーカー一覧`,
  url: 'https://www.lure-db.com/maker/',
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: makerList.length,
    itemListElement: makerList.map((m, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://www.lure-db.com/${m.slug}/`,
      name: m.name,
    })),
  },
};

const jsonLd = [breadcrumbLd, collectionLd] as unknown as Record<string, unknown>;

const introText = `国内${makerList.length}メーカーのルアーをシリーズ数順で一覧表示。DAIWA・SHIMANO・JACKALLをはじめ、${totalSeries}シリーズ・${totalColors.toLocaleString()}カラーを網羅。各メーカーの得意ジャンルや製品ラインナップを比較して、あなたにぴったりのルアーを見つけよう。`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/maker/"
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="text-sm text-text-mid mb-8">
      <a href="/" class="hover:text-accent transition-colors">トップ</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">メーカー一覧</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">メーカー一覧</h1>
      <p class="text-sm text-text-mid mt-1">
        {makerList.length}メーカー・{totalSeries}シリーズ
      </p>
      <p class="text-sm text-gray-600 leading-relaxed mt-3 max-w-3xl">
        {introText}
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {makerList.map(m => (
        <a
          href={`/${m.slug}/`}
          class="group block bg-white rounded-xl border border-gray-100 overflow-hidden shadow-card transition-all duration-200 hover:shadow-card-hover hover:scale-[1.01]"
        >
          <div class="p-4 sm:p-5">
            <h2 class="text-sm sm:text-base font-bold text-gray-900 group-hover:text-accent transition-colors mb-2">
              {m.name}
            </h2>
            <div class="flex items-center gap-3 text-xs text-text-mid mb-3">
              <span>{m.seriesCount}シリーズ</span>
              <span>{m.colorCount}カラー</span>
            </div>
            {m.topTypes.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {m.topTypes.map(t => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] sm:text-xs font-medium bg-accent-bg text-accent border border-accent">
                    {t.name}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
