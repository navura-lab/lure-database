  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path((?!api/|_astro/|favicon\\.svg|robots\\.txt|sitemap).*[^/])",
      "destination": "/:path/",
      "permanent": true
    },
    { "source": "/type/lure/", "destination": "/type/", "permanent": true },
    { "source": "/type/plug/", "destination": "/type/", "permanent": true },
