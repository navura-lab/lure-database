    { "source": "/type/surf-lure/", "destination": "/type/", "permanent": true },
    { "source": "/type/mebaring/", "destination": "/type/", "permanent": true },
    { "source": "/type/chining/", "destination": "/type/", "permanent": true },
    { "source": "/type/blade-jig/", "destination": "/type/metal-jig/", "permanent": true },
    { "source": "/type/area-trout-lure/", "destination": "/type/spoon/", "permanent": true },
    { "source": "/type/rockfish-lure/", "destination": "/type/worm/", "permanent": true },
    { "source": "/type/metal-sutte/", "destination": "/type/sutte/", "permanent": true },
    { "source": "/type/sinking-minnow/", "destination": "/type/minnow/", "permanent": true },
    { "source": "/type/vibration-jighead/", "destination": "/type/jighead/", "permanent": true },
    { "source": "/type/metal-vibration/", "destination": "/type/metal-vib/", "permanent": true },
    { "source": "/type/hitotsu-tenya/", "destination": "/type/tenya/", "permanent": true },
    { "source": "/type/float/", "destination": "/type/other/", "permanent": true },
    { "source": "/type/octopus-bait/", "destination": "/type/egi/", "permanent": true },
    { "source": "/type/area-minnow/", "destination": "/type/minnow/", "permanent": true },
    { "source": "/type/pencil/", "destination": "/type/pencilbait/", "permanent": true },
    { "source": "/type/ayu-lure/", "destination": "/type/minnow/", "permanent": true },
    { "source": "/type/tachiuo-lure/", "destination": "/type/metal-jig/", "permanent": true },
    { "source": "/type/lure-parts/", "destination": "/type/other/", "permanent": true },
    { "source": "/type/rolling-jighead/", "destination": "/type/jighead/", "permanent": true },
    { "source": "/type/spintail-jig/", "destination": "/type/spintail/", "permanent": true },
    { "source": "/type/octopus-egi/", "destination": "/type/egi/", "permanent": true },
    { "source": "/type/catfish-lure/", "destination": "/type/topwater/", "permanent": true },
    { "source": "/type/iron-jighead/", "destination": "/type/jighead/", "permanent": true },
    { "source": "/type/dodger/", "destination": "/type/other/", "permanent": true },
    { "source": "/type/area-topwater/", "destination": "/type/topwater/", "permanent": true },
    { "source": "/type/jig-minnow/", "destination": "/type/minnow/", "permanent": true },
    { "source": "/type/swim-jig/", "destination": "/type/rubber-jig/", "permanent": true },
    { "source": "/type/sinker/", "destination": "/type/other/", "permanent": true },
    { "source": "/type/tai-raba/", "destination": "/type/tai-rubber/", "permanent": true },
    { "source": "/type/keimura/", "destination": "/type/other/", "permanent": true },
    { "source": "/type/wakebait/", "destination": "/type/topwater/", "permanent": true },
    { "source": "/type/feather-jig/", "destination": "/type/spoon/", "permanent": true },
    { "source": "/type/skipbait/", "destination": "/type/topwater/", "permanent": true },
    { "source": "/type/spin-jig/", "destination": "/type/rubber-jig/", "permanent": true },
    { "source": "/type/chata-bait/", "destination": "/type/chatterbait/", "permanent": true },
    { "source": "/type/native-minnow/", "destination": "/type/minnow/", "permanent": true },
    { "source": "/type/hook/", "destination": "/type/other/", "permanent": true },
    { "source": "/spro/response-76-medium-heavy-moderate-fast-spinning/", "destination": "/spro/", "permanent": true },
    { "source": "/spro/team-6-76-medium-light-moderate-spinning/", "destination": "/spro/", "permanent": true },
    { "source": "/spro/team-6-73-medium-heavy-moderate-casting/", "destination": "/spro/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/sitemap(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    }
  ]
}
