{
  "name": "lure-database",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist/client && npx tsx scripts/generate-sitemaps.ts && node -e \"const{cpSync,existsSync}=require('fs');const src='dist/client/pagefind';const dst='.vercel/output/static/pagefind';if(existsSync(src)&&existsSync('.vercel/output/static')){cpSync(src,dst,{recursive:true});console.log('Pagefind copied to .vercel/output/static/pagefind')}\"",
    "preview": "astro preview",
    "astro": "astro",
    "discover": "tsx scripts/discover-products.ts",
    "discover:dry": "tsx scripts/discover-products.ts --dry-run",
    "pipeline": "tsx scripts/pipeline.ts",
    "pipeline:one": "tsx scripts/pipeline.ts --limit 1",
    "check:redirects": "npx tsx scripts/check-missing-redirects.ts",
    "fix:redirects": "npx tsx scripts/check-missing-redirects.ts --fix"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.4",
    "@aws-sdk/client-s3": "^3.990.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.17.1",
    "dotenv": "^17.3.1",
    "lite-youtube-embed": "^0.3.4",
    "playwright": "^1.58.2",
    "satori": "^0.25.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "pagefind": "^1.4.0"
  }
}
